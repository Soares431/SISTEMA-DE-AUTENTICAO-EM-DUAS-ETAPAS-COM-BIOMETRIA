{
  "_README": "Template de produção do Int1. Copie este arquivo para 'appsettings.Production.json' no servidor e substitua os <PLACEHOLDERS>. NÃO comitar 'appsettings.Production.json' com valores reais.",

  "SQLiteConnection": {
    "SQLiteConnectionString": "Data Source=C:\\5cta\\Banco\\banco.db"
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "C:\\5cta\\logs\\int1-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

