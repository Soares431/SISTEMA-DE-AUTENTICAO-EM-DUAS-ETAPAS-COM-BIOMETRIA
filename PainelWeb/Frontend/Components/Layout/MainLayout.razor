@* =============================================================================
   MainLayout.razor - Layout principal da aplicação
   Estrutura: Sidebar (NavMenu) + Área principal (Header + Conteúdo)
   Features: Toggle sidebar (recolher/expandir), Alternância de tema (dark/light)
   Usa IJSRuntime para comunicar com o themeManager do app.js
   ============================================================================= *@
@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject ITokenStore TokenStore

@if (!verificado)
{
    <div style="background: #0f1729; width: 100vw; height: 100vh;"></div>
}
else
{
    <div class="app-layout">
        <NavMenu IsCollapsed="@sidebarCollapsed" OnToggle="ToggleSidebar" />
        <div class="main-area">
            <header class="top-header">
                <button class="toggle-btn" @onclick="ToggleSidebar" title="Toggle sidebar">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="3" y1="12" x2="21" y2="12" />
                        <line x1="3" y1="6" x2="21" y2="6" />
                        <line x1="3" y1="18" x2="21" y2="18" />
                    </svg>
                </button>
                <div class="header-spacer"></div>
                <div class="header-user">
                    <button class="toggle-btn" style="margin-right: 0.5rem;" @onclick="ToggleTheme" title="Alternar tema">
                        @if (isDarkTheme)
                        {
                            <Icon Name="sun" Size="18" />
                        }
                        else
                        {
                            <Icon Name="moon" Size="18" />
                        }
                    </button>
                    <div class="status-dot"></div>
                    <span>@TokenStore.NomeCompleto</span>
                </div>
            </header>
            <main class="main-content">
                @Body
            </main>
        </div>
    </div>

    <div id="blazor-error-ui">
        Ocorreu um erro não tratado na aplicação. <a href="" class="dismiss">🗙</a>
    </div>
}

@code {
    [Inject] IJSRuntime JS { get; set; } = default!;
    private bool sidebarCollapsed = false;
    private bool isDarkTheme = true;
    private bool verificado = false;

    // Roda ANTES do primeiro render. Quando o usuário navega entre páginas usando enhanced
    // navigation, o circuito (e portanto o ITokenStore Scoped) é preservado. Se já estamos
    // autenticados aqui, marcamos verificado=true imediatamente — assim o @Body renderiza
    // no primeiro frame ao invés de mostrar a tela azul (overlay enquanto OnAfterRender
    // espera o JS interop). Esse era exatamente o bug dos "links que levavam à tela azul".
    protected override void OnInitialized()
    {
        if (TokenStore.EstaAutenticado)
        {
            verificado = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (!TokenStore.EstaAutenticado)
            {
                // Circuito reconectou e perdeu o estado em memória —
                // tenta restaurar a sessão do sessionStorage antes de redirecionar
                try
                {
                    var stored = await JS.InvokeAsync<StoredAuth?>("authStorage.load");
                    if (stored != null && !string.IsNullOrEmpty(stored.Token))
                    {
                        TokenStore.Token = stored.Token;
                        TokenStore.AdminId = stored.AdminId;
                        TokenStore.NomeCompleto = stored.Nome;
                    }
                    else
                    {
                        Nav.NavigateTo("/login", forceLoad: false);
                        return;
                    }
                }
                catch
                {
                    Nav.NavigateTo("/login", forceLoad: false);
                    return;
                }
            }

            verificado = true;
            var currentTheme = await JS.InvokeAsync<string>("window.themeManager.getTheme");
            isDarkTheme = currentTheme == "dark";
            StateHasChanged();
            // Remove o overlay após confirmar autenticação e renderizar o dashboard
            await JS.InvokeVoidAsync("removeAppLoading");
        }
    }

    // Classe auxiliar para desserializar o objeto retornado por authStorage.load().
    // JsonPropertyName explícito porque System.Text.Json é case-sensitive por padrão
    // e o JS retorna camelCase. Sem isso a desserialização vira tudo vazio em silêncio
    // e o guard cai no else → NavigateTo("/login") com o circuit num estado intermediário,
    // o que deixa o MainLayout em "verificado=false" (tela azul).
    private class StoredAuth
    {
        [System.Text.Json.Serialization.JsonPropertyName("token")]
        public string Token { get; set; } = "";

        [System.Text.Json.Serialization.JsonPropertyName("adminId")]
        public int AdminId { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("nome")]
        public string Nome { get; set; } = "";
    }

    private void ToggleSidebar()
    {
        sidebarCollapsed = !sidebarCollapsed;
    }

    private async Task ToggleTheme()
    {
        isDarkTheme = !isDarkTheme;
        var newTheme = isDarkTheme ? "dark" : "light";
        await JS.InvokeVoidAsync("window.themeManager.setTheme", newTheme);
    }
}