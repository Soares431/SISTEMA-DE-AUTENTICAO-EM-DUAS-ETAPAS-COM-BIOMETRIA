@inject NavigationManager Nav
@inject IJSRuntime JS
@inject ITokenStore TokenStore

<nav class="sidebar @(IsCollapsed ? "collapsed" : "") @(mobileOpen ? "open" : "")">
    <div class="sidebar-header">
        <a href="/" class="sidebar-header-logo">
            <div class="logo-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
            </div>
            <div class="sidebar-header-text">
                <h2>5º CTA</h2>
                <span>Controle de Acesso</span>
            </div>
        </a>
    </div>

    <div class="sidebar-content">
        <div class="sidebar-group">
            <div class="sidebar-group-label">Principal</div>
            <ul class="sidebar-menu">
                <li class="sidebar-menu-item">
                    <NavLink href="/" Match="NavLinkMatch.All" class="sidebar-link">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                        <span class="sidebar-label">Dashboard</span>
                    </NavLink>
                </li>
                <li class="sidebar-menu-item">
                    <NavLink href="/ambientes" Match="NavLinkMatch.Prefix">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg>
                        <span class="sidebar-label">Ambientes</span>
                    </NavLink>
                </li>
                <li class="sidebar-menu-item">
                    <NavLink href="/dispositivos" Match="NavLinkMatch.Prefix">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                        <span class="sidebar-label">Dispositivos T50</span>
                    </NavLink>
                </li>
                <li class="sidebar-menu-item">
                    <NavLink href="/pessoas" Match="NavLinkMatch.Prefix">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        <span class="sidebar-label">Pessoas</span>
                    </NavLink>
                </li>
                <li class="sidebar-menu-item">
                    <NavLink href="/cameras" Match="NavLinkMatch.Prefix">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>
                        <span class="sidebar-label">Câmeras</span>
                    </NavLink>
                </li>
            </ul>
        </div>

        <div class="sidebar-group">
            <div class="sidebar-group-label">Gerenciamento</div>
            <ul class="sidebar-menu">
                <li class="sidebar-menu-item">
                    <NavLink href="/historico" Match="NavLinkMatch.Prefix">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        <span class="sidebar-label">Histórico de Acessos</span>
                    </NavLink>
                </li>
                <li class="sidebar-menu-item">
                    <NavLink href="/logs" Match="NavLinkMatch.Prefix">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>
                        <span class="sidebar-label">Logs do Sistema</span>
                    </NavLink>
                </li>
                <li class="sidebar-menu-item">
                    <NavLink href="/admins" Match="NavLinkMatch.Prefix">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
                        <span class="sidebar-label">Administradores</span>
                    </NavLink>
                </li>
            </ul>
        </div>

        <div class="sidebar-group">
            <div class="sidebar-group-label">Sistema</div>
            <ul class="sidebar-menu">
                <li class="sidebar-menu-item">
                    <NavLink href="/configuracoes" Match="NavLinkMatch.Prefix">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                        <span class="sidebar-label">Configurações</span>
                    </NavLink>
                </li>
                <li class="sidebar-menu-item">
                    <NavLink href="/ajuda" Match="NavLinkMatch.Prefix">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                        <span class="sidebar-label">Ajuda</span>
                    </NavLink>
                </li>
            </ul>
        </div>
    </div>

    <div class="sidebar-footer">
        <ul class="sidebar-menu">
            <li class="sidebar-menu-item">
                <button class="sidebar-link" style="width:100%;text-align:left;background:none;border:none;cursor:pointer;padding:0;" @onclick="HandleLogout">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    <span class="sidebar-label">Sair</span>
                </button>
            </li>
        </ul>
    </div>
</nav>

@code {
    [Parameter] public bool IsCollapsed { get; set; }
    [Parameter] public EventCallback OnToggle { get; set; }
    private bool mobileOpen = false;

    private async Task HandleLogout()
    {

        await JS.InvokeVoidAsync("authStorage.clear");
        TokenStore.Token = null;
        TokenStore.AdminId = 0;
        TokenStore.NomeCompleto = "";
        Nav.NavigateTo("/login", forceLoad: false);
    }
}

