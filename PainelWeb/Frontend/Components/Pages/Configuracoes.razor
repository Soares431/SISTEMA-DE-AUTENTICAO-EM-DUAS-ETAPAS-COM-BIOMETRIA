@* =============================================================================
   Configuracoes.razor - Configurações globais do sistema
   Features: Retenção de dados (período e estatísticas de armazenamento),
             Período de inativação automática, alertas, botão de salvar.
   Rota: /configuracoes
   ============================================================================= *@
@page "/configuracoes"
@using WebAbil8_Sistema_Verificação_dupla.slnx.Model
@inject IConfiguracaoRepository ConfigRepo
@inject ITentativaAcessoRepository TentativaRepo
@inject ILogAdminRepository LogRepo
@inject ITokenStore TokenStore

<div class="space-y">
    <div><h1 class="text-2xl font-bold">Configurações</h1><p class="text-muted">Gerencie as configurações globais do sistema</p></div>

    <div class="grid grid-2">
        <div class="card">
            <div class="card-header"><div class="card-title"><Icon Name="database" Size="20" /> Retenção de Dados</div><p class="card-description">Configure por quanto tempo os dados serão armazenados no sistema</p></div>
            <div class="card-content space-y-sm">
                <div class="form-group">
                    <label class="form-label">Retenção de Tentativas de Acesso</label>
                    <select class="form-select" @bind="retencaoTentativas">
                        <option value="30">30 dias</option>
                        <option value="60">60 dias</option>
                        <option value="90">90 dias</option>
                        <option value="180">180 dias (máximo)</option>
                    </select>
                    <p class="text-sm text-muted">Tentativas de acesso mais antigas serão removidas automaticamente</p>
                </div>
                <div class="form-group">
                    <label class="form-label">Retenção de Logs de Auditoria</label>
                    <select class="form-select" @bind="retencaoLogs">
                        <option value="90">90 dias</option>
                        <option value="180">180 dias</option>
                        <option value="365">1 ano (máximo)</option>
                    </select>
                    <p class="text-sm text-muted">Logs administrativos mais antigos serão removidos automaticamente</p>
                </div>
                <div class="alert alert-warning"><Icon Name="alert-triangle" Size="16" CssClass="text-warning" /><div><p class="alert-title">Atenção</p><p class="alert-desc">Reduzir o período de retenção pode resultar na perda permanente de dados históricos.</p></div></div>
                <hr class="separator" />
                <div>
                    <label class="form-label">Estatísticas de Armazenamento</label>
                    <div class="grid grid-2" style="gap: 0.75rem;">
                        <div class="info-row"><div><p class="text-muted text-sm">Registros de Acesso</p><p class="text-xl font-bold">@totalTentativas</p></div></div>
                        <div class="info-row"><div><p class="text-muted text-sm">Logs do Sistema</p><p class="text-xl font-bold">@totalLogs</p></div></div>
                        <div class="info-row" style="grid-column: span 2;"><div><p class="text-muted text-sm">Retenção Tentativas</p><p class="text-xl font-bold">@retencaoTentativas dias</p></div></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header"><div class="card-title"><Icon Name="clock" Size="20" /> Comportamento do Sistema</div><p class="card-description">Configure o tempo de espera de gravação e o período de inativação automática</p></div>
            <div class="card-content space-y-sm">
                <div class="form-group">
                    <label class="form-label">Tempo de Espera de Gravação (segundos)</label>
                    <input type="number" class="form-input" min="30" max="120" @bind="tempoEsperaGravacao" />
                    <p class="text-sm text-muted">Tempo padrão que o sistema aguarda a câmera ONVIF capturar a gravação após um acesso liberado (30-120s). Pode ser sobrescrito por ambiente.</p>
                </div>
                <div class="form-group">
                    <label class="form-label">Período de Inativação Automática</label>
                    <select class="form-select" @bind="periodoInativacaoMeses">
                        <option value="3">3 meses</option>
                        <option value="6">6 meses</option>
                        <option value="12">12 meses (1 ano)</option>
                        <option value="18">18 meses</option>
                        <option value="24">24 meses (2 anos — padrão)</option>
                    </select>
                    <p class="text-sm text-muted">Pessoas sem acesso por este período serão inativadas automaticamente e removidas de todos os ambientes</p>
                </div>
                <div class="alert alert-info"><Icon Name="info" Size="16" CssClass="text-primary" /><div><p class="alert-title">Informação</p><p class="alert-desc">A inativação automática executa diariamente às 03:00. Pessoas inativadas precisam ser adicionadas a um ambiente novamente para reativar o acesso.</p></div></div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><div class="card-title"><Icon Name="settings" Size="20" /> Salvar Configurações</div></div>
        <div class="card-content flex items-center justify-between">
            <p class="text-muted">Clique no botão para salvar todas as alterações realizadas nas configurações</p>
            <button class="btn btn-primary" @onclick="HandleSave" disabled="@isSaving"><Icon Name="save" Size="16" /> @(isSaving ? "Salvando..." : "Salvar Configurações")</button>
        </div>
    </div>
</div>

@* Toast flutuante — aparece sobre o conteúdo e some sozinho em 2.5s. Posição fixa no canto. *@
@if (mensagemSucesso != null)
{
    <div style="position:fixed; top:1.25rem; right:1.25rem; z-index:9999; background:#16a34a; color:white; padding:0.75rem 1.25rem; border-radius:8px; box-shadow:0 6px 20px rgba(0,0,0,0.2); display:flex; align-items:center; gap:0.5rem; font-size:0.9rem; pointer-events:none;">
        <Icon Name="check-circle" Size="16" /> <span>@mensagemSucesso</span>
    </div>
}

@code {
    private string retencaoTentativas = "90";
    private string retencaoLogs = "180";
    private string periodoInativacaoMeses = "24";
    private int tempoEsperaGravacao = 60;
    private bool isSaving = false;
    private string? mensagemSucesso = null;
    private int totalTentativas = 0;
    private int totalLogs = 0;
    private Configuracao? config = null;

    protected override async Task OnInitializedAsync()
    {
        config = await ConfigRepo.BuscarPorChave();
        if (config != null)
        {
            retencaoTentativas = config.RetencaoGravacoesTentativasDias.ToString();
            retencaoLogs = config.RetencaoLogsDias.ToString();
            periodoInativacaoMeses = config.PeriodoInativacaoMeses.ToString();
            tempoEsperaGravacao = config.TempoEsperaGravacaoSeg;
        }

        var tentativas = TentativaRepo.ListarTodos();
        totalTentativas = tentativas.Count;
        totalLogs = LogRepo.ListarTodos().Count;
    }

    private async Task HandleSave()
    {
        isSaving = true;
        mensagemSucesso = null;
        StateHasChanged();

        if (config != null)
        {
            config.RetencaoGravacoesTentativasDias = int.Parse(retencaoTentativas);
            config.RetencaoLogsDias = int.Parse(retencaoLogs);
            config.PeriodoInativacaoMeses = Math.Clamp(int.Parse(periodoInativacaoMeses), 3, 24);
            config.TempoEsperaGravacaoSeg = Math.Clamp(tempoEsperaGravacao, 30, 120);
            await ConfigRepo.Atualizar(config);
            LogRepo.Registrar(TokenStore.AdminId, "Atualizar", "Configuracao", config.Id);
            mensagemSucesso = "Configurações salvas com sucesso.";
        }

        isSaving = false;
        StateHasChanged();

        // Toast some sozinho em 2.5s sem bloquear a UI nem reordenar o layout
        _ = Task.Run(async () =>
        {
            await Task.Delay(2500);
            await InvokeAsync(() =>
            {
                mensagemSucesso = null;
                StateHasChanged();
            });
        });
    }
}
