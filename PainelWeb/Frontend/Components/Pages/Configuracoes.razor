@* =============================================================================
   Configuracoes.razor - Configurações globais do sistema
   Features: Retenção de dados (período e estatísticas de armazenamento),
             Tempo de espera de gravação (global e por ambiente),
             Alertas informativos, botão de salvar com loading state
   Rota: /configuracoes
   ============================================================================= *@
@page "/configuracoes"

<div class="space-y">
    <div><h1 class="text-2xl font-bold">Configurações</h1><p class="text-muted">Gerencie as configurações globais do sistema</p></div>

    <div class="grid grid-2">
        <div class="card"><div class="card-header"><div class="card-title"><Icon Name="database" Size="20" /> Retenção de Dados</div><p class="card-description">Configure por quanto tempo os dados serão armazenados no sistema</p></div>
            <div class="card-content space-y-sm">
                <div class="form-group"><label class="form-label">Período de Retenção</label>
                    <select class="form-select" @bind="retencao"><option value="30">30 dias</option><option value="60">60 dias</option><option value="90">90 dias</option><option value="180">180 dias</option><option value="365">1 ano</option><option value="730">2 anos</option></select>
                    <p class="text-sm text-muted"> Histórico de acessos e gravações mais antigos serão removidos automaticamente</p>
                </div>
                <div class="alert alert-warning"><Icon Name="alert-triangle" Size="16" CssClass="text-warning" /><div><p class="alert-title">Atenção</p><p class="alert-desc">Alterar o período de retenção pode resultar na perda permanente de dados históricos.</p></div></div>
                <hr class="separator" />
                <div><label class="form-label">Estatísticas de Armazenamento</label>
                    <div class="grid grid-2" style="gap: 0.75rem;">
                        <div class="info-row"><div><p class="text-muted text-sm">Registros de Acesso</p><p class="text-xl font-bold">45.230</p></div></div>
                        <div class="info-row"><div><p class="text-muted text-sm">Gravações</p><p class="text-xl font-bold">12.5 GB</p></div></div>
                        <div class="info-row"><div><p class="text-muted text-sm">Logs do Sistema</p><p class="text-xl font-bold">8.421</p></div></div>
                        <div class="info-row"><div><p class="text-muted text-sm">Dados Biométricos</p><p class="text-xl font-bold">342</p></div></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card"><div class="card-header"><div class="card-title"><Icon Name="clock" Size="20" /> Tempo de Espera de Gravação</div><p class="card-description">Configure o tempo padrão que o sistema aguarda após uma tentativa de acesso para salvar a gravação</p></div>
            <div class="card-content space-y-sm">
                <div class="form-group"><label class="form-label">Tempo de Espera (segundos)</label>
                    <div class="flex items-center gap-4"><input type="number" class="form-input w-32" @bind="tempoEspera" min="1" max="60" /><span class="text-muted">segundos</span></div>
                    <p class="text-sm text-muted">Este valor pode ser sobrescrito individualmente para cada ambiente</p>
                </div>
                <div class="alert alert-info"><Icon Name="info" Size="16" CssClass="text-primary" /><div><p class="alert-title">Informação</p><p class="alert-desc">Valores muito baixos podem resultar em gravações incompletas. Recomendamos manter entre 5 e 15 segundos.</p></div></div>
                <hr class="separator" />
                <div><label class="form-label">Configuração por Ambiente</label><div class="space-y-xs">
                    <div class="info-row flex justify-between"><span>Recepção Principal</span><span class="font-mono text-muted">10s (padrão)</span></div>
                    <div class="info-row flex justify-between"><span>Sala de Servidores</span><span class="font-mono text-muted">15s</span></div>
                    <div class="info-row flex justify-between"><span>Diretoria</span><span class="font-mono text-muted">20s</span></div>
                </div></div>
            </div>
        </div>
    </div>

    <div class="card"><div class="card-header"><div class="card-title"><Icon Name="settings" Size="20" /> Salvar Configurações</div></div>
        <div class="card-content flex items-center justify-between">
            <p class="text-muted">Clique no botão para salvar todas as alterações realizadas nas configurações</p>
            <button class="btn btn-primary" @onclick="HandleSave" disabled="@isSaving"><Icon Name="save" Size="16" /> @(isSaving ? "Salvando..." : "Salvar Configurações")</button>
        </div></div>
</div>

@code {
    private string retencao = "180"; private int tempoEspera = 10; private bool isSaving = false;
    private async Task HandleSave() { isSaving = true; StateHasChanged(); await Task.Delay(1000); isSaving = false; }
}
