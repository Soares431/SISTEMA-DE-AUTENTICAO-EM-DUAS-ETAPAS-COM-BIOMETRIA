@* =============================================================================
   Logs.razor - Logs de auditoria do sistema
   Features: Filtros por categoria, usuário e busca textual,
             tabela de logs com badges coloridos por tipo de ação,
             ícones dinâmicos por categoria, botão de exportar,
             ordenação por coluna, navegação clicável para entidades
   Rota: /logs
   ============================================================================= *@
@page "/logs"
@using WebAbil8_Sistema_Verificação_dupla.slnx.Model
@inject ILogAdminRepository LogRepo
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IConfiguration Config
@inject ITokenStore TokenStore

<div class="space-y">
    <div class="flex items-center justify-between" style="flex-wrap: wrap; gap: 1rem;">
        <div><h1 class="text-2xl font-bold">Logs do Sistema</h1><p class="text-muted">Auditoria de ações administrativas</p></div>
        <div class="flex gap-2">
            <button class="btn btn-outline" @onclick="ExportarCsv"><Icon Name="download" Size="16" /> CSV</button>
            <button class="btn btn-outline" @onclick="ExportarPdf"><Icon Name="file-text" Size="16" /> PDF</button>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><div class="card-title"><Icon Name="filter" Size="20" /> Filtros</div></div>
        <div class="card-content">
            <div class="grid grid-4" style="gap: 1rem;">
                <div class="input-icon-wrapper" style="grid-column: span 2;"><Icon Name="search" /><input class="form-input" placeholder="Buscar por ação, entidade ou admin..." @bind="search" @bind:event="oninput" /></div>
                <select class="form-select" @bind="acaoFilter">
                    <option value="todos">Todas as Ações</option>
                    @foreach (var a in Acoes)
                    {
                        <option value="@a">@a</option>
                    }
                </select>
                <select class="form-select" @bind="entidadeFilter">
                    <option value="todos">Todas as Entidades</option>
                    @foreach (var e in Entidades)
                    {
                        <option value="@e">@e</option>
                    }
                </select>
                <select class="form-select" @bind="adminFilter">
                    <option value="todos">Todos os Admins</option>
                    @foreach (var a in Admins)
                    {
                        <option value="@a.Id">@a.NomeCompleto</option>
                    }
                </select>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-content pt-6">
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th @onclick="@(() => AlternarOrdem("dataHora"))" style="cursor:pointer;user-select:none">Data/Hora @SortIcon("dataHora")</th>
                            <th @onclick="@(() => AlternarOrdem("admin"))" style="cursor:pointer;user-select:none">Admin @SortIcon("admin")</th>
                            <th @onclick="@(() => AlternarOrdem("acao"))" style="cursor:pointer;user-select:none">Ação @SortIcon("acao")</th>
                            <th @onclick="@(() => AlternarOrdem("entidade"))" style="cursor:pointer;user-select:none">Entidade @SortIcon("entidade")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Sorted)
                        {
                            <tr>
                                <td><div class="flex items-center gap-2"><Icon Name="clock" Size="16" CssClass="text-muted" /><div><p class="font-mono text-sm">@DateHelper.Local(log.DataHora).ToString("dd/MM/yyyy")</p><p class="font-mono text-xs text-muted">@DateHelper.Local(log.DataHora).ToString("HH:mm:ss")</p></div></div></td>
                                <td>
                                    <span class="flex items-center gap-2">
                                        <Icon Name="user" Size="16" CssClass="text-muted" />
                                        <a href="/admins/@log.AdminId" class="text-primary" style="text-decoration:none;cursor:pointer">
                                            @(log.Administrador?.NomeCompleto ?? $"Admin {log.AdminId}")
                                        </a>
                                    </span>
                                </td>
                                <td><span class="badge @GetAcaoBadge(log.Acao)"><Icon Name="@GetAcaoIcon(log.Acao)" Size="12" /> @log.Acao</span></td>
                                <td>
                                    @{
                                        var entHref = log.EntidadeAfetada switch
                                        {
                                            "Pessoa" when log.EntidadeId.HasValue => $"/pessoas/{log.EntidadeId}",
                                            "Ambiente" when log.EntidadeId.HasValue => $"/ambientes/{log.EntidadeId}",
                                            "Administrador" when log.EntidadeId.HasValue => $"/admins/{log.EntidadeId}",
                                            "Configuracao" => "/configuracoes",
                                            _ => (string?)null
                                        };
                                    }
                                    @if (entHref != null) {
                                        <a href="@entHref" class="text-muted" style="text-decoration:none">@log.EntidadeAfetada</a>
                                    } else {
                                        @log.EntidadeAfetada
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private string search = "";
    private string acaoFilter = "todos";
    private string entidadeFilter = "todos";
    private string adminFilter = "todos";
    private string sortColumn = "dataHora";
    private bool sortAsc = false;
    private List<LogAdmin> todosLogs = new();

    protected override void OnInitialized()
    {
        todosLogs = LogRepo.ListarTodos();
    }

    private string[] Acoes => todosLogs.Select(l => l.Acao).Distinct().Order().ToArray();
    private string[] Entidades => todosLogs.Select(l => l.EntidadeAfetada).Distinct().Order().ToArray();
    private IEnumerable<Administrador> Admins => todosLogs
        .Where(l => l.Administrador != null)
        .Select(l => l.Administrador!)
        .GroupBy(a => a.Id)
        .Select(g => g.First())
        .OrderBy(a => a.NomeCompleto);

    private IEnumerable<LogAdmin> Filtered => todosLogs.Where(l =>
        (string.IsNullOrEmpty(search) ||
         l.Acao.Contains(search, StringComparison.OrdinalIgnoreCase) ||
         l.EntidadeAfetada.Contains(search, StringComparison.OrdinalIgnoreCase) ||
         (l.Administrador?.NomeCompleto.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false)) &&
        (acaoFilter == "todos" || l.Acao == acaoFilter) &&
        (entidadeFilter == "todos" || l.EntidadeAfetada == entidadeFilter) &&
        (adminFilter == "todos" || l.AdminId.ToString() == adminFilter));

    private IEnumerable<LogAdmin> Sorted => sortColumn switch
    {
        "admin" => sortAsc ? Filtered.OrderBy(l => l.Administrador?.NomeCompleto ?? "") : Filtered.OrderByDescending(l => l.Administrador?.NomeCompleto ?? ""),
        "acao" => sortAsc ? Filtered.OrderBy(l => l.Acao) : Filtered.OrderByDescending(l => l.Acao),
        "entidade" => sortAsc ? Filtered.OrderBy(l => l.EntidadeAfetada) : Filtered.OrderByDescending(l => l.EntidadeAfetada),
        _ => sortAsc ? Filtered.OrderBy(l => l.DataHora) : Filtered.OrderByDescending(l => l.DataHora),
    };

    private void AlternarOrdem(string coluna)
    {
        if (sortColumn == coluna) sortAsc = !sortAsc;
        else { sortColumn = coluna; sortAsc = true; }
    }

    private string SortIcon(string coluna) =>
        sortColumn == coluna ? (sortAsc ? " ▲" : " ▼") : "";

    private string GetAcaoBadge(string acao) => acao switch
    {
        "Remocao" => "badge-destructive",
        "Inativacao" => "badge-warning",
        "ResetBiometria" => "badge-warning",
        "Adicionar" => "badge-success",
        "Atualizar" => "badge-primary",
        _ => "badge-muted"
    };

    private string GetAcaoIcon(string acao) => acao switch
    {
        "Remocao" => "trash",
        "Inativacao" => "user-x",
        "ResetBiometria" => "fingerprint",
        "Adicionar" => "user-plus",
        "Atualizar" => "edit",
        _ => "activity"
    };

    private async Task ExportarCsv()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Data/Hora,Admin,Acao,Entidade");
        foreach (var log in Sorted)
        {
            var admin = log.Administrador?.NomeCompleto ?? $"Admin {log.AdminId}";
            sb.AppendLine($"{DateHelper.Local(log.DataHora):dd/MM/yyyy HH:mm:ss},\"{admin}\",{log.Acao},{log.EntidadeAfetada}");
        }
        await JS.InvokeVoidAsync("downloadCsv",
            $"logs_{DateTime.Now:yyyyMMdd_HHmm}{SufixoFiltros()}.csv",
            sb.ToString());
    }

    private async Task ExportarPdf()
    {
        var apiUrl = Config["BancoApiUrl"] ?? "http://localhost:5018/";
        var qs = MontarQueryFiltros();
        await JS.InvokeVoidAsync("baixarPdf",
            apiUrl + "api/export/logs.pdf" + qs,
            TokenStore.Token,
            $"logs{SufixoFiltros()}.pdf");
    }

    private string MontarQueryFiltros()
    {
        var q = new List<string>();
        if (!string.IsNullOrEmpty(search))    q.Add($"search={Uri.EscapeDataString(search)}");
        if (acaoFilter != "todos")            q.Add($"acao={Uri.EscapeDataString(acaoFilter)}");
        if (entidadeFilter != "todos")        q.Add($"entidade={Uri.EscapeDataString(entidadeFilter)}");
        if (adminFilter != "todos")           q.Add($"adminId={adminFilter}");
        return q.Count > 0 ? "?" + string.Join("&", q) : "";
    }

    private string SufixoFiltros()
    {
        var s = new List<string>();
        if (acaoFilter != "todos")            s.Add(Slug(acaoFilter));
        if (entidadeFilter != "todos")        s.Add(Slug(entidadeFilter));
        if (adminFilter != "todos")           s.Add($"adm-{adminFilter}");
        if (!string.IsNullOrEmpty(search))    s.Add($"busca-{Slug(search)}");
        return s.Count > 0 ? "_" + string.Join("_", s) : "";
    }

    private static string Slug(string s) =>
        new string((s ?? "").Where(c => char.IsLetterOrDigit(c) || c == '-').ToArray()).ToLower();
}
