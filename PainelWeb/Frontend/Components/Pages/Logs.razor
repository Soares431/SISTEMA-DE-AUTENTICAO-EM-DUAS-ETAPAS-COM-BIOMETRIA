@* =============================================================================
   Logs.razor - Logs de auditoria do sistema
   Features: Filtros por categoria, usuário e busca textual,
             tabela de logs com badges coloridos por tipo de ação,
             ícones dinâmicos por categoria, botão de exportar
   Rota: /logs
   ============================================================================= *@
@page "/logs"
@using WebAbil8_Sistema_Verificação_dupla.slnx.Model
@inject ILogAdminRepository LogRepo
@inject IJSRuntime JS

<div class="space-y">
    <div class="flex items-center justify-between" style="flex-wrap: wrap; gap: 1rem;">
        <div><h1 class="text-2xl font-bold">Logs do Sistema</h1><p class="text-muted">Auditoria de ações administrativas</p></div>
        <button class="btn btn-outline" @onclick="ExportarCsv"><Icon Name="download" Size="16" /> Exportar CSV</button>
    </div>

    <div class="card">
        <div class="card-header"><div class="card-title"><Icon Name="filter" Size="20" /> Filtros</div></div>
        <div class="card-content">
            <div class="grid grid-4" style="gap: 1rem;">
                <div class="input-icon-wrapper" style="grid-column: span 2;"><Icon Name="search" /><input class="form-input" placeholder="Buscar por ação, entidade ou admin..." @bind="search" @bind:event="oninput" /></div>
                <select class="form-select" @bind="acaoFilter">
                    <option value="todos">Todas as Ações</option>
                    @foreach (var a in Acoes)
                    {
                        <option value="@a">@a</option>
                    }
                </select>
                <select class="form-select" @bind="entidadeFilter">
                    <option value="todos">Todas as Entidades</option>
                    @foreach (var e in Entidades)
                    {
                        <option value="@e">@e</option>
                    }
                </select>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-content pt-6">
            <div class="table-wrapper">
                <table>
                    <thead><tr><th>Data/Hora</th><th>Admin</th><th>Ação</th><th>Entidade</th><th>ID Entidade</th></tr></thead>
                    <tbody>
                        @foreach (var log in Filtered)
                        {
                            <tr>
                                <td><div class="flex items-center gap-2"><Icon Name="clock" Size="16" CssClass="text-muted" /><div><p class="font-mono text-sm">@log.DataHora.ToString("dd/MM/yyyy")</p><p class="font-mono text-xs text-muted">@log.DataHora.ToString("HH:mm:ss")</p></div></div></td>
                                <td><span class="flex items-center gap-2"><Icon Name="user" Size="16" CssClass="text-muted" /> @(log.Administrador?.NomeCompleto ?? $"Admin {log.AdminId}")</span></td>
                                <td><span class="badge @GetAcaoBadge(log.Acao)"><Icon Name="@GetAcaoIcon(log.Acao)" Size="12" /> @log.Acao</span></td>
                                <td class="text-muted">@log.EntidadeAfetada</td>
                                <td class="font-mono text-sm text-muted">@(log.EntidadeId?.ToString() ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private string search = "";
    private string acaoFilter = "todos";
    private string entidadeFilter = "todos";
    private List<LogAdmin> todosLogs = new();

    protected override void OnInitialized()
    {
        todosLogs = LogRepo.ListarTodos();
    }

    private string[] Acoes => todosLogs.Select(l => l.Acao).Distinct().ToArray();
    private string[] Entidades => todosLogs.Select(l => l.EntidadeAfetada).Distinct().ToArray();

    private IEnumerable<LogAdmin> Filtered => todosLogs.Where(l =>
        (string.IsNullOrEmpty(search) ||
         l.Acao.Contains(search, StringComparison.OrdinalIgnoreCase) ||
         l.EntidadeAfetada.Contains(search, StringComparison.OrdinalIgnoreCase)) &&
        (acaoFilter == "todos" || l.Acao == acaoFilter) &&
        (entidadeFilter == "todos" || l.EntidadeAfetada == entidadeFilter));

    private string GetAcaoBadge(string acao) => acao switch
    {
        "Remocao" => "badge-destructive",
        "Inativacao" => "badge-warning",
        "ResetBiometria" => "badge-warning",
        "Adicionar" => "badge-success",
        "Atualizar" => "badge-primary",
        _ => "badge-muted"
    };

    private string GetAcaoIcon(string acao) => acao switch
    {
        "Remocao" => "trash",
        "Inativacao" => "user-x",
        "ResetBiometria" => "fingerprint",
        "Adicionar" => "user-plus",
        "Atualizar" => "edit",
        _ => "activity"
    };

    private async Task ExportarCsv()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Data/Hora,AdminId,Acao,Entidade,ID Entidade");
        foreach (var log in Filtered)
        {
            sb.AppendLine($"{log.DataHora:dd/MM/yyyy HH:mm:ss},{log.AdminId},{log.Acao},{log.EntidadeAfetada},{log.EntidadeId?.ToString() ?? ""}");
        }
        await JS.InvokeVoidAsync("downloadCsv", $"logs_{DateTime.Now:yyyyMMdd_HHmm}.csv", sb.ToString());
    }
}