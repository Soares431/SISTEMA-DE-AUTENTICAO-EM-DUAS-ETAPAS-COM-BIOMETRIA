@* =============================================================================
   Home.razor - Página Dashboard (Página Inicial)
   Features: 4 cards de estatísticas, gráfico de acessos por hora (Chart.js),
             painel de alertas T50, tabela de últimos acessos negados
   Rota: / (raiz da aplicação)
   ============================================================================= *@
@page "/"
@inject IJSRuntime JS
@inject ITentativaAcessoRepository TentativaRepo
@inject IPessoaRepository PessoaRepo
@inject IDispositivoT50Repository DispositivoRepo
@using WebAbil8_Sistema_Verificação_dupla.slnx.Model
<div class="space-y">
    <div>
        <h1 class="text-2xl font-bold">Dashboard</h1>
        <p class="text-muted">Resumo do dia - @DateTime.Now.ToString("dd/MM/yyyy")</p>
    </div>

    <!-- Stats -->
    <div class="grid grid-4">
        <div class="card">
            <div class="card-header card-header-row">
                <span class="text-sm font-medium text-muted">Entradas Permitidas</span>
                <div class="icon-bg icon-bg-success"><Icon Name="check-circle" Size="16" /></div>
            </div>
            <div class="card-content">
                <div class="stat-value">@totalPermitidos</div>
                <p class="text-xs text-muted">acessos hoje</p>
            </div>
        </div>
        <div class="card">
            <div class="card-header card-header-row">
                <span class="text-sm font-medium text-muted">Acessos Negados</span>
                <div class="icon-bg icon-bg-destructive"><Icon Name="x-circle" Size="16" /></div>
            </div>
            <div class="card-content">
                <div class="stat-value">@totalNegados</div>
                <p class="text-xs text-muted">acessos hoje</p>
            </div>
        </div>
        <div class="card">
            <div class="card-header card-header-row">
                <span class="text-sm font-medium text-muted">Alertas T50</span>
                <div class="icon-bg icon-bg-warning"><Icon Name="alert-triangle" Size="16" /></div>
            </div>
            <div class="card-content">
                <div class="stat-value">@totalAlertas</div>
                <p class="text-xs text-muted">dispositivos</p>
            </div>
        </div>
        <div class="card">
            <div class="card-header card-header-row">
                <span class="text-sm font-medium text-muted">Pessoas Ativas</span>
                <div class="icon-bg icon-bg-primary"><Icon Name="users" Size="16" /></div>
            </div>
            <div class="card-content">
                <div class="stat-value">@totalPessoas</div>
                <p class="text-xs text-muted">cadastradas</p>
            </div>
        </div>
    </div>

    <!-- Chart + Alerts -->
    <div class="grid grid-2">
        <div class="card">
            <div class="card-header">
                <div class="card-title">Acessos por Hora</div>
                <p class="card-description">Distribuição de entradas ao longo do dia</p>
            </div>
            <div class="card-content">
                <canvas id="dashboardChart" style="width:100%; height:300px;"></canvas>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <div class="card-title"><Icon Name="alert-triangle" CssClass="text-warning" /> Alertas Ativos</div>
                <p class="card-description">Dispositivos T50 precisando de atenção</p>
            </div>
            <div class="card-content space-y-sm">
                @if (!alertasT50.Any())
                {
                    <p class="text-sm text-muted">Nenhum alerta ativo no momento.</p>
                }
                @foreach (var disp in alertasT50)
                {
                    <div style="display: flex; align-items: flex-start; gap: 1rem; padding: 0.75rem; border: 1px solid var(--border); border-radius: var(--radius); background: color-mix(in srgb, var(--muted) 30%, transparent);">
                        <div class="icon-bg icon-bg-warning"><Icon Name="building" Size="16" /></div>
                        <div style="flex: 1;">
                            <div class="flex items-center gap-2">
                                <span class="font-medium">@disp.Nome</span>
                                <span class="badge badge-warning">Alerta</span>
                            </div>
                            <p class="text-sm text-muted">IP: @disp.EnderecoIP</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Recent Denied -->
    <div class="card">
        <div class="card-header card-header-row">
            <div>
                <div class="card-title"><Icon Name="x-circle" CssClass="text-destructive" /> Últimos Acessos Negados</div>
                <p class="card-description">Tentativas de acesso negadas hoje</p>
            </div>
            <a href="/historico" class="btn btn-outline btn-sm">Ver todos</a>
        </div>
        <div class="card-content">
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>Pessoa</th>
                            <th>Ambiente</th>
                            <th>Motivo</th>
                            <th>Hora</th>
                            <th>Gravação</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in ultimosNegados)
                        {
                            <tr>
                                <td><span class="flex items-center gap-2"><Icon Name="user" Size="16" CssClass="text-muted" /> @(item.Pessoa?.Nome ?? "Desconhecido")</span></td>
                                <td><span class="flex items-center gap-2 text-muted"><Icon Name="map-pin" Size="16" /> Ambiente @item.AmbienteId</span></td>
                                <td><span class="badge badge-destructive">@(item.MotivoNegacao ?? "-")</span></td>
                                <td><span class="flex items-center gap-2 text-muted"><Icon Name="clock" Size="16" /> @item.DataHora.ToString("HH:mm")</span></td>
                                <td>
                                    @if (item.GravacaoPath != null)
                                    {
                                        <button class="btn btn-ghost btn-sm text-primary">Ver vídeo</button>
                                    }
                                    else
                                    {
                                        <span class="text-sm text-muted">Indisponível</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private int totalPermitidos = 0;
    private int totalNegados = 0;
    private int totalAlertas = 0;
    private int totalPessoas = 0;
    private List<WebAbil8_Sistema_Verificação_dupla.slnx.Model.TentativaAcesso> ultimosNegados = new();
    private List<WebAbil8_Sistema_Verificação_dupla.slnx.Model.DispositivoT50> alertasT50 = new();

    protected override async Task OnInitializedAsync()
    {
        var hoje = DateTime.UtcNow.Date;
        var amanha = hoje.AddDays(1);

        var tentativasHoje = TentativaRepo.ListarComFiltros(null, null, null, hoje, amanha);
        totalPermitidos = tentativasHoje.Count(t => t.AcessoLiberado);
        totalNegados = tentativasHoje.Count(t => !t.AcessoLiberado);

        ultimosNegados = TentativaRepo.ListarComFiltros(null, null, false, hoje, amanha)
            .OrderByDescending(t => t.DataHora)
            .Take(5)
            .ToList();

        var pessoas = await PessoaRepo.ListarTodos();
        totalPessoas = pessoas.Count(p => p.Status == "ativo");

        var dispositivos = DispositivoRepo.ListarTodos();
        alertasT50 = dispositivos.Where(d => d.DigitaisCadastradas >= 950).ToList();
        totalAlertas = alertasT50.Count;
    }

    private string GetGravidadeBadge(string gravidade) => gravidade switch
    {
        "alta" => "badge-destructive",
        "media" => "badge-warning",
        _ => "badge-muted"
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("renderDashboardChart", "dashboardChart");
        }
    }
}
