
@page "/"
@implements IDisposable
@inject IJSRuntime JS
@inject ITentativaAcessoRepository TentativaRepo
@inject IPessoaRepository PessoaRepo
@inject IDispositivoT50Repository DispositivoRepo
@inject IConfiguration Config
@inject ITokenStore TokenStore
@using WebAbil8_Sistema_Verificação_dupla.slnx.Model
<div class="space-y">
    <div>
        <h1 class="text-2xl font-bold">Dashboard</h1>
        <p class="text-muted">@(DateHelper.Local(DateTime.UtcNow).Hour < 12 ? "Bom dia" : DateHelper.Local(DateTime.UtcNow).Hour < 18 ? "Boa tarde" : "Boa noite") - @DateHelper.Local(DateTime.UtcNow).ToString("dd/MM/yyyy")</p>
    </div>

    
    <div class="grid grid-4">
        <div class="card">
            <div class="card-header card-header-row">
                <span class="text-sm font-medium text-muted">Entradas Permitidas</span>
                <div class="icon-bg icon-bg-success"><Icon Name="check-circle" Size="16" /></div>
            </div>
            <div class="card-content">
                <div class="stat-value">@totalPermitidos</div>
                <p class="text-xs text-muted">acessos hoje</p>
            </div>
        </div>
        <div class="card">
            <div class="card-header card-header-row">
                <span class="text-sm font-medium text-muted">Acessos Negados</span>
                <div class="icon-bg icon-bg-destructive"><Icon Name="x-circle" Size="16" /></div>
            </div>
            <div class="card-content">
                <div class="stat-value">@totalNegados</div>
                <p class="text-xs text-muted">acessos hoje</p>
            </div>
        </div>
        <div class="card">
            <div class="card-header card-header-row">
                <span class="text-sm font-medium text-muted">T50 em Alerta</span>
                <div class="icon-bg icon-bg-warning"><Icon Name="alert-triangle" Size="16" /></div>
            </div>
            <div class="card-content">
                <div class="stat-value">@totalAlertas</div>
                <p class="text-xs text-muted">dispositivo(s) em alerta</p>
            </div>
        </div>
        <div class="card">
            <div class="card-header card-header-row">
                <span class="text-sm font-medium text-muted">Pessoas Ativas</span>
                <div class="icon-bg icon-bg-primary"><Icon Name="users" Size="16" /></div>
            </div>
            <div class="card-content">
                <div class="stat-value">@totalPessoas</div>
                <p class="text-xs text-muted">cadastradas</p>
            </div>
        </div>
    </div>

    
    <div class="grid grid-2">
        <div class="card">
            <div class="card-header card-header-row">
                <div>
                    <div class="card-title">Acessos por Hora</div>
                    <p class="card-description">
                        @if (IsHoje)
                        {
                            <span>Todos os horários — 00h a 23h</span>
                        }
                        else
                        {
                            <span>Histórico de @dataGrafico.ToString("dd/MM/yyyy") · auto-refresh pausado</span>
                        }
                    </p>
                </div>
                <div class="flex items-center gap-2" style="flex-wrap: wrap;">
                    
                    <input type="date" class="form-input" style="width: auto; padding: 0.25rem 0.5rem; font-size: 0.8rem;"
                           max="@DateTime.Now.ToString("yyyy-MM-dd")"
                           value="@dataGrafico.ToString("yyyy-MM-dd")"
                           @onchange="HandleDataChanged" />
                    @if (!IsHoje)
                    {
                        <button class="btn btn-outline btn-sm" @onclick="VoltarParaHoje" title="Voltar para hoje">Hoje</button>
                    }
                    
                    <span id="dashboard-clock" class="text-xs text-muted" style="font-variant-numeric: tabular-nums; min-width: 7ch;"></span>
                    @if (_ultimaAtualizacao != default)
                    {
                        <span class="text-xs text-muted" title="Última vez que os dados foram buscados do banco">· dados @_ultimaAtualizacao.ToString("HH:mm:ss")</span>
                    }
                    <button class="btn btn-ghost btn-sm" @onclick="HandleRefresh" disabled="@_carregando" title="Atualizar agora">
                        <Icon Name="refresh" Size="14" />
                    </button>
                </div>
            </div>
            <div class="card-content">
                
                <div class="flex items-center justify-center gap-6" style="margin-bottom: 1rem; font-size: 0.75rem; font-weight: 500;">
                    <div class="flex items-center gap-2">
                        <span style="display: block; width: 10px; height: 10px; border-radius: 50%; background-color: var(--chart-1);"></span>
                        <span style="color: var(--chart-1);">Permitidos</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <span style="display: block; width: 10px; height: 10px; border-radius: 50%; background-color: var(--chart-3);"></span>
                        <span style="color: var(--chart-3);">Negados</span>
                    </div>
                </div>
                <div style="position: relative; height: 320px; width: 100%;">
                    <canvas id="dashboardChart"></canvas>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <div class="card-title"><Icon Name="alert-triangle" CssClass="text-warning" /> Alertas Ativos</div>
                <p class="card-description">Dispositivos T50 precisando de atenção</p>
            </div>
            <div class="card-content space-y-sm">
                @if (!alertasT50.Any())
                {
                    <p class="text-sm text-muted">Nenhum alerta ativo no momento.</p>
                }
                @foreach (var disp in alertasT50)
                {
                    var offline = !disp.EstaOnline;
                    var iconBg = offline ? "icon-bg-destructive" : "icon-bg-warning";
                    var badgeClass = offline ? "badge-destructive" : "badge-warning";
                    var badgeText = offline ? "Offline" : "Capacidade";
                    <div style="display: flex; align-items: flex-start; gap: 1rem; padding: 0.75rem; border: 1px solid var(--border); border-radius: var(--radius); background: color-mix(in srgb, var(--muted) 30%, transparent); overflow: hidden;">
                        <div class="icon-bg @iconBg" style="flex-shrink: 0;"><Icon Name="@(offline ? "wifi-off" : "settings")" Size="16" /></div>
                        <div style="flex: 1; min-width: 0;">
                            <div class="flex items-center gap-2" style="flex-wrap: wrap;">
                                <span class="text-xs text-muted" style="flex-shrink: 0;">T50</span>
                                <span class="font-medium" style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 55%;">@disp.Nome</span>
                                <span class="badge @badgeClass" style="flex-shrink: 0;">@badgeText</span>
                            </div>
                            <p class="text-sm text-muted" style="overflow-wrap: anywhere;">IP: @disp.EnderecoIP @(offline && disp.UltimaConexao.HasValue ? $"· última conexão {DateHelper.Local(disp.UltimaConexao.Value):dd/MM HH:mm}" : "")</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    
    <div class="card">
        <div class="card-header card-header-row">
            <div>
                <div class="card-title"><Icon Name="x-circle" CssClass="text-destructive" /> Últimos Acessos Negados</div>
                <p class="card-description">Tentativas de acesso negadas @(IsHoje ? "hoje" : "em " + dataGrafico.ToString("dd/MM/yyyy"))</p>
            </div>
            <a href="/historico?status=negado" class="btn btn-outline btn-sm">Ver todos</a>
        </div>
        <div class="card-content">
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>Pessoa</th>
                            <th>Ambiente</th>
                            <th>Motivo</th>
                            <th>Hora</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in ultimosNegados)
                        {
                            <tr>
                                <td><span class="flex items-center gap-2"><Icon Name="user" Size="16" CssClass="text-muted" /> @(item.Pessoa?.Nome ?? "Desconhecido")</span></td>
                                <td><span class="flex items-center gap-2 text-muted"><Icon Name="map-pin" Size="16" /> @(item.Ambiente?.Nome ?? $"Ambiente {item.AmbienteId}")</span></td>
                                <td><span class="badge badge-destructive">@(item.MotivoNegacao ?? "-")</span></td>
                                <td><span class="flex items-center gap-2 text-muted"><Icon Name="clock" Size="16" /> @DateHelper.Local(item.DataHora).ToString("HH:mm")</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private int totalPermitidos = 0;
    private int totalNegados = 0;
    private int totalAlertas = 0;
    private int totalPessoas = 0;
    private int[] permitidosPorHora = new int[24];
    private int[] negadosPorHora = new int[24];
    private List<WebAbil8_Sistema_Verificação_dupla.slnx.Model.TentativaAcesso> ultimosNegados = new();
    private List<WebAbil8_Sistema_Verificação_dupla.slnx.Model.DispositivoT50> alertasT50 = new();

    
    private System.Threading.Timer? _refreshTimer;
    private DateTime _ultimaAtualizacao;
    private bool _carregando = false;
    private bool _chartInicializado = false;

    
    private DateTime dataGrafico = DateHelper.Local(DateTime.UtcNow).Date;
    private bool IsHoje => dataGrafico.Date == DateHelper.Local(DateTime.UtcNow).Date;

    private async Task HandleDataChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var nova))
        {
            dataGrafico = nova.Date;
            await HandleRefresh();
        }
    }

    private async Task VoltarParaHoje()
    {
        dataGrafico = DateHelper.Local(DateTime.UtcNow).Date;
        await HandleRefresh();
    }

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    
    private async Task CarregarDados()
    {
        
        permitidosPorHora = new int[24];
        negadosPorHora    = new int[24];

        
        
        var diaLocal     = dataGrafico.Date;
        var diaUtcInicio = DateTime.SpecifyKind(diaLocal, DateTimeKind.Local).ToUniversalTime();
        var diaUtcFim    = diaUtcInicio.AddDays(1);

        var tentativasDia = TentativaRepo.ListarComFiltros(null, null, null, diaUtcInicio, diaUtcFim);
        totalPermitidos = tentativasDia.Count(t => t.AcessoLiberado);
        totalNegados    = tentativasDia.Count(t => !t.AcessoLiberado);

        
        
        
        
        foreach (var t in tentativasDia)
        {
            var hora = DateHelper.Local(t.DataHora).Hour;
            if (t.AcessoLiberado) permitidosPorHora[hora]++;
            else negadosPorHora[hora]++;
        }

        ultimosNegados = TentativaRepo.ListarComFiltros(null, null, false, diaUtcInicio, diaUtcFim)
            .OrderByDescending(t => t.DataHora)
            .Take(5)
            .ToList();

        var pessoas = await PessoaRepo.ListarTodos();
        totalPessoas = pessoas.Count(p => p.Status == "ativo");

        var dispositivos = DispositivoRepo.ListarTodos();
        
        alertasT50   = dispositivos.Where(d => d.DigitaisCadastradas >= 950 || !d.EstaOnline).ToList();
        totalAlertas = alertasT50.Count;

        _ultimaAtualizacao = DateHelper.Local(DateTime.UtcNow);
    }

    private string GetGravidadeBadge(string gravidade) => gravidade switch
    {
        "alta" => "badge-destructive",
        "media" => "badge-warning",
        _ => "badge-muted"
    };

    
    private async Task HandleRefresh()
    {
        _carregando = true;
        StateHasChanged();
        await CarregarDados();
        if (_chartInicializado)
            await JS.InvokeVoidAsync("updateDashboardChart", permitidosPorHora, negadosPorHora);
        _carregando = false;
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _chartInicializado = true;
            await JS.InvokeVoidAsync("renderDashboardChart", "dashboardChart", permitidosPorHora, negadosPorHora);
            
            
            await JS.InvokeVoidAsync("startDashboardClock", "dashboard-clock");

            
            
            
            _refreshTimer = new System.Threading.Timer(async _ =>
            {
                if (!IsHoje) return;
                await InvokeAsync(async () =>
                {
                    await CarregarDados();
                    StateHasChanged();
                    if (_chartInicializado)
                        await JS.InvokeVoidAsync("updateDashboardChart", permitidosPorHora, negadosPorHora);
                });
            }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
        }
    }

    
    public void Dispose()
    {
        _chartInicializado = false;
        _refreshTimer?.Dispose();
    }
}
