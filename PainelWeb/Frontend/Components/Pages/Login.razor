@page "/login"
@layout LoginLayout
@inject NavigationManager Nav
@inject IHttpClientFactory HttpClientFactory
@inject ITokenStore TokenStore
@inject IJSRuntime JS

<div class="login-page">
    <div class="login-blob" style="top: 25%; left: 25%;"></div>
    <div class="login-blob" style="bottom: 25%; right: 25%;"></div>

    <div class="card login-card">
        <div class="card-header" style="text-align: center;">
            <div style="margin: 0 auto 1rem; width: 4rem; height: 4rem; border-radius: 0.75rem; background: color-mix(in srgb, var(--primary) 15%, transparent); display: flex; align-items: center; justify-content: center;">
                <Icon Name="shield" Size="32" CssClass="text-primary" />
            </div>
            <h2 class="text-2xl font-bold">5° CTA</h2>
            <p class="text-muted text-sm">Sistema de Controle de Acesso Biometrico</p>
        </div>
        <div class="card-content">
            <EditForm Model="loginModel" OnValidSubmit="HandleLogin" FormName="loginForm">
                <div class="space-y-sm">
                    <div class="form-group">
                        <label class="form-label" for="email">Login</label>
                        <input id="email" type="text" class="form-input" placeholder="admin"
                               maxlength="40" @bind="loginModel.Email" required />
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="password">Senha</label>
                        <div style="position: relative;">
                            <input id="password" type="@(showPassword ? "text" : "password")" class="form-input"
                                   placeholder="Digite sua senha" maxlength="64" @bind="loginModel.Password" required
                                   style="padding-right: 2.5rem;" />
                            <button type="button" class="btn btn-ghost btn-icon"
                                    style="position: absolute; right: 0; top: 0; height: 100%;"
                                    @onclick="TogglePassword">
                                <Icon Name="@(showPassword ? "eye-off" : "eye")" Size="16" />
                            </button>
                        </div>
                    </div>
                    @if (errorMessage != null)
                    {
                        <div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.75rem; background: color-mix(in srgb, var(--destructive) 10%, transparent); border: 1px solid color-mix(in srgb, var(--destructive) 30%, transparent); border-radius: var(--radius); color: var(--destructive); font-size: 0.875rem;">
                            <Icon Name="x-circle" Size="16" /> @errorMessage
                        </div>
                    }
                    <button type="submit" class="btn btn-primary btn-block" disabled="@isLoading">
                        @(isLoading ? "Entrando..." : "Entrar")
                    </button>
                </div>
            </EditForm>
            <div style="margin-top: 1.5rem; text-align: center;">
                <p class="text-xs text-muted">Acesso restrito a administradores autorizados</p>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginModel loginModel = new();
    private bool showPassword = false;
    private bool isLoading = false;
    private string? errorMessage = null;

    private void TogglePassword() => showPassword = !showPassword;

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient("BancoAPI");
            var response = await client.PostAsJsonAsync("api/auth/login", new
            {
                Login = loginModel.Email,
                Senha = loginModel.Password
            });

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResponse>();
                TokenStore.Token = result?.Token;
                TokenStore.AdminId = result?.AdminId ?? 0;
                TokenStore.NomeCompleto = result?.NomeCompleto ?? "";

                await JS.InvokeVoidAsync("authStorage.save",
                    result?.Token ?? "",
                    result?.AdminId ?? 0,
                    result?.NomeCompleto ?? "");
                Nav.NavigateTo("/");
            }
            else
            {
                errorMessage = "Login ou senha inválidos.";
            }
        }
        catch
        {
            errorMessage = "Erro ao conectar com o servidor.";
        }
        finally
        {
            isLoading = false;
        }
    }

    public class LoginModel
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }

    public class LoginResponse
    {
        public string Token { get; set; } = "";
        public int AdminId { get; set; }
        public string NomeCompleto { get; set; } = "";
    }
}

