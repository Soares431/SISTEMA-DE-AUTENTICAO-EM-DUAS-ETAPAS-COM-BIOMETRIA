        await JS.InvokeVoidAsync("baixarPdf",
            $"{apiUrl}api/export/relatorio-ambiente.pdf?ambienteId={Id}",
            TokenStore.Token,
            $"relatorio_ambiente_{Id}.pdf");
    }

