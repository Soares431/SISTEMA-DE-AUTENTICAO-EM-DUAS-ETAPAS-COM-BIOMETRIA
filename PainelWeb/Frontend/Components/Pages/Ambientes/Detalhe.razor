@page "/ambientes/{Id:int}"
@using WebAbil8_Sistema_Verificação_dupla.slnx.Model
@inject IAmbienteRepository AmbienteRepo
@inject IAmbientePessoaRepository AmbientePessoaRepo
@inject IDispositivoT50Repository DispositivoRepo
@inject IAmbienteT50Repository AmbienteT50Repo
@inject ICameraRepository CameraRepo
@inject IPessoaRepository PessoaRepo
@inject ITentativaAcessoRepository TentativaRepo
@inject ILogAdminRepository LogRepo
@inject ITokenStore TokenStore
@inject NavigationManager Nav
@inject IConfiguration Config
@inject IJSRuntime JS
<div class="space-y">
    @if (ambiente == null)
    {
        <p class="text-muted">Carregando...</p>
    }
    else
    {
        <div class="flex items-center gap-4">
            <a href="/ambientes" class="btn btn-ghost btn-icon"><Icon Name="arrow-left" Size="20" /></a>
            <div class="flex-1"><h1 class="text-2xl font-bold">@ambiente.Nome</h1><p class="text-muted">Criado em @DateHelper.Local(ambiente.DataCriacao).ToString("dd/MM/yyyy")</p></div>
            @if (dispositivo != null && dispositivo.DigitaisCadastradas >= 950)
            {
                <span class="badge badge-warning"><Icon Name="alert-triangle" Size="12" /> Alerta</span>
            }
            else
            {
                <span class="badge badge-success"><Icon Name="wifi" Size="12" /> Online</span>
            }
        </div>

        <div class="tabs-list">
            <button class="tab-trigger @(activeTab == "t50" ? "active" : "")" @onclick='() => activeTab = "t50"'>Dispositivo T50</button>
            <button class="tab-trigger @(activeTab == "pessoas" ? "active" : "")" @onclick='() => activeTab = "pessoas"'>Pessoas com Acesso</button>
            <button class="tab-trigger @(activeTab == "cameras" ? "active" : "")" @onclick='() => activeTab = "cameras"'>Câmeras</button>
            <button class="tab-trigger @(activeTab == "config" ? "active" : "")" @onclick='() => activeTab = "config"'>Configurações</button>
        </div>

        @if (activeTab == "t50")
        {
            <div class="card">
                <div class="card-header card-header-row">
                    <div>
                        <div class="card-title"><Icon Name="settings" Size="20" /> Dispositivos T50 vinculados</div>
                        <p class="card-description">@t50sVinculados.Count terminal(is) — o "principal" recebe os contadores de digitais ao cadastrar pessoas</p>
                    </div>
                    <div class="flex gap-2">
                        <button class="btn btn-outline btn-sm" @onclick="AbrirAdicionarT50">
                            <Icon Name="plus" Size="14" /> Adicionar outro T50
                        </button>
                        <button class="btn btn-primary btn-sm" @onclick="AbrirTrocarT50" disabled="@(!t50sVinculados.Any())">
                            <Icon Name="settings" Size="14" /> Trocar T50 (swap)
                        </button>
                    </div>
                </div>
                <div class="card-content">
                    @if (!t50sVinculados.Any())
                    {
                        <div class="alert alert-warning">Nenhum T50 vinculado ainda. Use "Adicionar outro T50".</div>
                    }
                    else
                    {
                        <table>
                            <thead>
                                <tr>
                                    <th>Nome</th>
                                    <th>IP : Porta</th>
                                    <th>Digitais</th>
                                    <th>Status</th>
                                    <th class="text-right">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var d in t50sVinculados)
                                {
                                    var ehPrincipal = (d.Id == ambiente.DispositivoT50Id);
                                    var pctRow = d.DigitaisCadastradas * 100 / 1000;
                                    <tr>
                                        <td class="font-medium">
                                            @d.Nome
                                            @if (ehPrincipal) { <span class="badge badge-success" style="margin-left:0.5rem;">Principal</span> }
                                        </td>
                                        <td class="font-mono text-sm">@d.EnderecoIP : @d.Porta</td>
                                        <td>
                                            <div class="flex items-center gap-2">
                                                <span class="@(pctRow >= 95 ? "text-destructive" : pctRow >= 85 ? "text-warning" : "")">@d.DigitaisCadastradas / 1000</span>
                                            </div>
                                        </td>
                                        <td>
                                            @if (!d.EstaOnline) { <span class="badge badge-destructive">Offline</span> }
                                            else if (pctRow >= 95) { <span class="badge badge-warning">Crítico</span> }
                                            else { <span class="badge badge-success">Online</span> }
                                        </td>
                                        <td class="text-right">
                                            <div class="flex gap-2 justify-end">
                                                @if (!ehPrincipal)
                                                {
                                                    <button class="btn btn-ghost btn-sm" @onclick="() => HandleTornarPrincipal(d.Id)" title="Tornar este o T50 principal">
                                                        <Icon Name="settings" Size="14" /> Tornar principal
                                                    </button>
                                                }
                                                @if (t50sVinculados.Count > 1)
                                                {
                                                    <button class="btn btn-ghost btn-sm text-destructive" @onclick="() => ConfirmarRemoverT50(d.Id)" title="Desvincular este T50">
                                                        <Icon Name="trash" Size="14" />
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>

            @if (dispositivo != null)
            {
                <div class="card">
                    <div class="card-header"><div class="card-title"><Icon Name="alert-triangle" Size="20" CssClass="text-warning" /> Capacidade Biométrica do Principal (@dispositivo.Nome)</div></div>
                    <div class="card-content space-y-sm">
                        @{
                            var pct = (dispositivo.DigitaisCadastradas * 100 / 1000);
                        }
                        <div class="flex justify-between text-sm"><span class="text-muted">Uso atual</span><span class="font-medium @(pct >= 95 ? "text-destructive" : pct >= 85 ? "text-warning" : "")">@dispositivo.DigitaisCadastradas / 1000</span></div>
                        <div class="progress-bar"><div class="progress-fill" style="width: @pct%; background: @(pct >= 95 ? "var(--destructive)" : pct >= 85 ? "var(--warning)" : "var(--success)");"></div></div>
                        @if (pct >= 95) { <p class="text-sm text-destructive">Capacidade crítica! Remova templates inativos urgentemente.</p> }
                        else if (pct >= 85) { <p class="text-sm text-muted">Acima de 85%. Considere limpar templates inativos.</p> }
                    </div>
                </div>
            }
        }
        else if (activeTab == "pessoas")
        {
            <div class="card">
                <div class="card-header card-header-row">
                    <div><div class="card-title"><Icon Name="users" Size="20" /> Pessoas com Acesso</div><p class="card-description">@pessoas.Count pessoas autorizadas</p></div>
                    <button class="btn btn-primary" @onclick="AbrirModalAdicionarPessoa"><Icon Name="plus" Size="16" /> Adicionar Pessoa</button>
                </div>
                <div class="card-content">
                    <table>
                        <thead><tr><th>Nome</th><th>Cargo</th><th class="text-right">Ações</th></tr></thead>
                        <tbody>
                            @foreach (var p in pessoas)
                            {
                                <tr>
                                    <td class="font-medium">@p.Nome</td>
                                    <td class="text-muted">@p.Cargo</td>
                                    <td class="text-right">
                                        <button class="btn btn-ghost btn-icon text-destructive" @onclick="() => ConfirmarRemoverPessoa(p.Id)"><Icon Name="trash" Size="16" /></button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else if (activeTab == "cameras")
        {
            <div class="card">
                <div class="card-header card-header-row">
                    <div><div class="card-title"><Icon Name="camera" Size="20" /> Câmeras</div><p class="card-description">@cameras.Count câmeras configuradas</p></div>
                    <button class="btn btn-primary" @onclick="() => showAddCamera = true"><Icon Name="plus" Size="16" /> Adicionar Câmera</button>
                </div>
                <div class="card-content">
                    <div class="grid grid-2" style="gap: 1.5rem;">
                        @foreach (var cam in cameras)
                        {
                            <div class="card" style="background: color-mix(in srgb, var(--muted) 30%, transparent);">
                                <div class="card-content pt-6">
                                    <div class="aspect-video rounded-lg" style="background: var(--muted); display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;"><Icon Name="camera" Size="48" CssClass="text-muted" /></div>
                                    <div class="flex justify-between items-center"><span class="font-medium">@cam.Nome</span><span class="badge @(cam.Ativa ? "badge-success" : "badge-muted")">@(cam.Ativa ? "Ativa" : "Inativa")</span></div>
                                    <p class="text-sm font-mono text-muted">@(cam.UrlRTSP ?? "-")</p>
                                    <button class="btn btn-outline btn-block mt-4" disabled="@(!cam.Ativa)">Ver Ao Vivo</button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
        else if (activeTab == "config")
        {
            <div class="card">
                <div class="card-header"><div class="card-title"><Icon Name="clock" Size="20" /> Tempo de Espera de Gravação</div><p class="card-description">Tempo em segundos que o sistema aguarda após uma tentativa de acesso para salvar a gravação</p></div>
                <div class="card-content space-y-sm">
                    <div class="flex items-center gap-4"><input type="number" class="form-input w-32" @bind="tempoEspera" min="30" max="120" /><span class="text-muted">segundos</span></div>
                    <button class="btn btn-primary" @onclick="HandleSalvarConfig" disabled="@isSalvandoConfig">
                        @if (isSalvandoConfig) { <span class="spinner"></span><span>Salvando…</span> } else { <span>Salvar Configurações</span> }
                    </button>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><div class="card-title text-destructive"><Icon Name="trash" Size="20" /> Zona de Risco</div><p class="card-description">Excluir este ambiente permanentemente</p></div>
                <div class="card-content flex items-center justify-between">
                    <div>
                        <p class="text-muted">Remove o ambiente, todas as @cameras.Count câmera(s), @pessoas.Count vínculo(s) de pessoa e o histórico de tentativas vinculado.</p>
                        <p class="text-sm text-muted">Pessoas que ficarem sem nenhum ambiente serão inativadas automaticamente.</p>
                    </div>
                    <a class="btn btn-outline" href="/historico?ambienteId=@Id"><Icon Name="file-text" Size="16" /> Ver no Histórico</a>
                    <button class="btn btn-outline text-destructive" @onclick="() => showConfirmExcluir = true">Excluir Ambiente</button>
                </div>
            </div>
        }
    }
</div>

@if (showAddPessoa)
{
    <div class="modal-overlay">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header"><h3>Adicionar Pessoa</h3><p>Selecione uma pessoa para conceder acesso a este ambiente</p></div>
            <div class="modal-body">
                @if (pessoasDisponiveis.Count == 0)
                {
                    <p class="text-muted">Todas as pessoas cadastradas já têm acesso a este ambiente.</p>
                }
                else
                {
                    <div class="form-group">
                        <label class="form-label">Pessoa</label>
                        <select class="form-select" @bind="pessoaSelecionadaId">
                            @foreach (var p in pessoasDisponiveis)
                            {
                                <option value="@p.Id">@p.Nome - @p.Cargo</option>
                            }
                        </select>
                    </div>
                    @if (dispositivo != null && dispositivo.DigitaisCadastradas >= 1000)
                    {
                        <div class="alert alert-warning">
                            <strong>T50 cheio (1000 digitais).</strong> Não há mais slots para nova biometria.
                            A pessoa será adicionada em <strong>modo Somente Senha</strong> (não usará digital neste ambiente).
                        </div>
                        <label class="flex items-center gap-2 text-sm">
                            <input type="checkbox" @bind="aceitouSomenteSenha" /> Confirmo adicionar em modo Somente Senha
                        </label>
                    }
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="() => showAddPessoa = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="HandleAdicionarPessoa"
                    disabled="@(isAdicionandoPessoa || pessoasDisponiveis.Count == 0 || (dispositivo != null && dispositivo.DigitaisCadastradas >= 1000 && !aceitouSomenteSenha))">
                    @if (isAdicionandoPessoa) { <span class="spinner"></span><span>Adicionando…</span> } else { <span>Adicionar</span> }
                </button>
            </div>
        </div>
    </div>
}

@if (showConfirmRemoverPessoa)
{
    <div class="modal-overlay">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Remover Pessoa do Ambiente</h3>
                <p>Confirme antes de prosseguir</p>
            </div>
            <div class="modal-body">
                <p>Deseja remover o acesso desta pessoa a <strong>@ambiente?.Nome</strong>? Se for o único ambiente vinculado, a pessoa será inativada automaticamente.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="() => showConfirmRemoverPessoa = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="HandleConfirmarRemoverPessoa">Remover</button>
            </div>
        </div>
    </div>
}

@if (showAddCamera)
{
    <div class="modal-overlay">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header"><h3>Adicionar Câmera</h3><p>Configure uma nova câmera para este ambiente</p></div>
            <div class="modal-body space-y-sm">
                <div class="form-group"><label class="form-label">Nome</label><input class="form-input" maxlength="80" placeholder="Ex: Câmera Principal" @bind="novaCameraNome" @bind:event="oninput" /></div>
                <div class="form-group"><label class="form-label">URL RTSP</label><input class="form-input" maxlength="255" placeholder="rtsp://..." @bind="novaCameraRtsp" @bind:event="oninput" /></div>
                <div class="form-group">
                    <label class="form-label">URL HLS <span class="text-muted text-sm">(opcional, feed ao vivo)</span></label>
                    <input class="form-input" maxlength="255" placeholder="http://ip:8888/path/index.m3u8" @bind="novaCameraHls" @bind:event="oninput" />
                </div>
                <div class="form-group"><label class="form-label">Endereço ONVIF</label><input class="form-input" maxlength="255" placeholder="http://ip:porta/onvif/device_service" @bind="novaCameraOnvif" @bind:event="oninput" /></div>
                <div class="form-group">
                    <label class="form-label">Tipo</label>
                    <select class="form-select" @bind="novaCameraTipo">
                        <option value="interna">Interna</option>
                        <option value="externa">Externa</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="() => showAddCamera = false" disabled="@isAdicionandoCamera">Cancelar</button>
                <button class="btn btn-primary" @onclick="HandleAdicionarCamera" disabled="@isAdicionandoCamera">
                    @if (isAdicionandoCamera) { <span class="spinner"></span><span>Adicionando…</span> } else { <span>Adicionar</span> }
                </button>
            </div>
        </div>
    </div>
}

@if (showTrocarT50 && ambiente != null)
{
    <div class="modal-overlay">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Trocar T50 principal (swap)</h3>
                <p>Faz swap dos contadores de digitais entre o T50 atual e outro já vinculado</p>
            </div>
            <div class="modal-body space-y-sm">
                @if (errTrocarT50 != null) { <div class="alert alert-danger">@errTrocarT50</div> }
                <div class="form-group">
                    <label class="form-label">Principal atual</label>
                    <p class="font-mono text-muted">@(dispositivo?.Nome ?? "(nenhum)") · @(dispositivo?.EnderecoIP ?? "-") · @(dispositivo?.DigitaisCadastradas ?? 0) digitais</p>
                </div>
                <div class="form-group">
                    <label class="form-label">Novo principal <span class="text-destructive">*</span></label>
                    @{
                        var trocaveis = t50sVinculados.Where(d => d.Id != ambiente.DispositivoT50Id).ToList();
                    }
                    @if (trocaveis.Any())
                    {
                        <select class="form-select" @bind="novoT50IdSelecionado">
                            @foreach (var d in trocaveis)
                            {
                                <option value="@d.Id">@d.Nome (@d.EnderecoIP) — @d.DigitaisCadastradas/1000 digitais</option>
                            }
                        </select>
                        <p class="text-xs text-muted">Lista apenas T50s já vinculados a este ambiente. Use "Adicionar outro T50" para vincular um novo antes.</p>
                    }
                    else
                    {
                        <p class="text-sm text-muted">Não há outros T50 vinculados a este ambiente. Adicione um primeiro.</p>
                    }
                </div>
                <div class="alert alert-warning">
                    <strong>Swap de digitais:</strong> os contadores DigitaisCadastradas dos dois T50 são trocados.
                    Caso 1: A=100, B=0 → A=0, B=100. Caso 2: A=50, B=80 → A=80, B=50.
                    Em produção, as biometrias físicas precisam ser re-sincronizadas com os terminais.
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="() => showTrocarT50 = false" disabled="@isTrocandoT50">Cancelar</button>
                <button class="btn btn-primary" @onclick="HandleTrocarT50" disabled="@(isTrocandoT50 || !trocaveis.Any() || novoT50IdSelecionado == 0 || novoT50IdSelecionado == ambiente.DispositivoT50Id)">
                    @if (isTrocandoT50) { <span class="spinner"></span><span>Trocando…</span> } else { <span>Confirmar swap</span> }
                </button>
            </div>
        </div>
    </div>
}

@if (showAddT50 && ambiente != null)
{
    <div class="modal-overlay">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Adicionar outro T50</h3>
                <p>Vincula um terminal adicional a este ambiente</p>
            </div>
            <div class="modal-body space-y-sm">
                @if (errAddT50 != null) { <div class="alert alert-danger">@errAddT50</div> }
                @{
                    var t50sLivres = todosT50.Where(d => !t50sVinculados.Any(v => v.Id == d.Id)).ToList();
                }
                <div class="form-group">
                    <label class="form-label">T50 disponível <span class="text-destructive">*</span></label>
                    @if (t50sLivres.Any())
                    {
                        <select class="form-select" @bind="novoT50ParaAdicionarId">
                            @foreach (var d in t50sLivres)
                            {
                                <option value="@d.Id">@d.Nome (@d.EnderecoIP) — @d.DigitaisCadastradas/1000 digitais</option>
                            }
                        </select>
                        <p class="text-xs text-muted">O novo T50 começa sem nenhum vínculo de pessoa — admin deve cadastrar biometrias separadamente. Use "Tornar principal" se quiser que ele receba os próximos cadastros.</p>
                    }
                    else
                    {
                        <p class="text-sm text-muted">Todos os T50 cadastrados já estão neste ambiente. <a href="/dispositivos" class="text-primary">Cadastrar novo T50</a></p>
                    }
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="() => showAddT50 = false" disabled="@isAdicionandoT50">Cancelar</button>
                <button class="btn btn-primary" @onclick="HandleAdicionarT50" disabled="@(isAdicionandoT50 || !t50sLivres.Any() || novoT50ParaAdicionarId == 0)">
                    @if (isAdicionandoT50) { <span class="spinner"></span><span>Vinculando…</span> } else { <span>Vincular</span> }
                </button>
            </div>
        </div>
    </div>
}

@if (showConfirmRemoverT50 != 0 && ambiente != null)
{
    <div class="modal-overlay">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Desvincular T50 do ambiente</h3>
                <p>O T50 continua cadastrado no sistema — só perde o vínculo com este ambiente</p>
            </div>
            <div class="modal-body">
                @{
                    var t50ParaRemover = t50sVinculados.FirstOrDefault(d => d.Id == showConfirmRemoverT50);
                }
                <p>Desvincular <strong>@(t50ParaRemover?.Nome ?? "T50")</strong> deste ambiente?</p>
                @if (t50ParaRemover != null && t50ParaRemover.Id == ambiente.DispositivoT50Id)
                {
                    <div class="alert alert-warning">Este é o T50 principal. Outro T50 vinculado será promovido a principal automaticamente.</div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="() => showConfirmRemoverT50 = 0">Cancelar</button>
                <button class="btn btn-primary text-destructive" @onclick="HandleRemoverT50">Desvincular</button>
            </div>
        </div>
    </div>
}

@if (showConfirmExcluir && ambiente != null)
{
    <div class="modal-overlay">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Excluir Ambiente Permanentemente</h3>
                <p>Esta ação não pode ser desfeita</p>
            </div>
            <div class="modal-body space-y-sm">
                <div class="alert alert-danger">
                    O ambiente <strong>@ambiente.Nome</strong> e todos os seus dados serão removidos permanentemente:
                    <ul style="margin-top:0.5rem; padding-left:1.25rem;">
                        <li>@cameras.Count câmera(s) cadastrada(s)</li>
                        <li>@pessoas.Count vínculo(s) de acesso de pessoa</li>
                        <li>Histórico de tentativas de acesso ao ambiente</li>
                    </ul>
                </div>
                <div class="form-group">
                    <label class="form-label">Digite o nome exato para confirmar: <strong>@ambiente.Nome</strong></label>
                    <input class="form-input" @bind="nomeConfirmacaoExcluir" placeholder="@ambiente.Nome" />
                </div>
                @if (erroExcluir != null) { <div class="alert alert-danger">@erroExcluir</div> }
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="() => { showConfirmExcluir = false; nomeConfirmacaoExcluir = string.Empty; erroExcluir = null; }">Cancelar</button>
                <button class="btn btn-primary text-destructive" @onclick="HandleConfirmarExcluir" disabled="@(nomeConfirmacaoExcluir != ambiente.Nome || isExcluindo)">@(isExcluindo ? "Excluindo..." : "Excluir Permanentemente")</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private string activeTab = "t50";
    private bool showAddPessoa = false;
    private bool showAddCamera = false;
    private bool showConfirmRemoverPessoa = false;
    private bool showConfirmExcluir = false;
    private bool isExcluindo = false;
    private bool isSalvandoConfig = false;
    private bool isAdicionandoCamera = false;
    private bool isAdicionandoPessoa = false;
    private bool showTrocarT50 = false;
    private bool isTrocandoT50 = false;
    private string? errTrocarT50 = null;
    private int novoT50IdSelecionado = 0;
    private List<DispositivoT50> dispositivosDisponiveis = new();
    // Multi-T50: lista de T50s vinculados ao ambiente + lista global de T50s
    private List<DispositivoT50> t50sVinculados = new();
    private List<DispositivoT50> todosT50 = new();
    private bool showAddT50 = false;
    private bool isAdicionandoT50 = false;
    private string? errAddT50 = null;
    private int novoT50ParaAdicionarId = 0;
    private int showConfirmRemoverT50 = 0; // ID do T50 a remover (0 = modal fechado)

    private void RecarregarT50s()
    {
        todosT50 = DispositivoRepo.ListarTodos();
        t50sVinculados = AmbienteT50Repo.ListarT50sDoAmbiente(Id);
    }

    private void AbrirAdicionarT50()
    {
        errAddT50 = null;
        RecarregarT50s();
        var livres = todosT50.Where(d => !t50sVinculados.Any(v => v.Id == d.Id)).ToList();
        novoT50ParaAdicionarId = livres.FirstOrDefault()?.Id ?? 0;
        showAddT50 = true;
    }

    private async Task HandleAdicionarT50()
    {
        if (ambiente == null || novoT50ParaAdicionarId == 0) return;
        isAdicionandoT50 = true;
        StateHasChanged();
        await Task.Yield();
        try
        {
            AmbienteT50Repo.Adicionar(ambiente.Id, novoT50ParaAdicionarId, ehPrincipal: false);
            LogRepo.Registrar(TokenStore.AdminId, "Adicionar", "AmbienteT50", ambiente.Id);
            RecarregarT50s();
            showAddT50 = false;
        }
        catch (Exception ex) { errAddT50 = ex.Message; }
        finally { isAdicionandoT50 = false; }
    }

    private void HandleTornarPrincipal(int t50Id)
    {
        if (ambiente == null) return;
        AmbienteT50Repo.DefinirPrincipal(ambiente.Id, t50Id);
        LogRepo.Registrar(TokenStore.AdminId, "Atualizar", "AmbienteT50", ambiente.Id);
        // Recarrega ambiente para refletir o novo DispositivoT50Id principal
        ambiente = AmbienteRepo.BuscarPorId(Id);
        dispositivo = DispositivoRepo.ListarTodos().FirstOrDefault(d => d.Id == ambiente!.DispositivoT50Id);
        RecarregarT50s();
    }

    private void ConfirmarRemoverT50(int t50Id) => showConfirmRemoverT50 = t50Id;

    private void HandleRemoverT50()
    {
        if (ambiente == null || showConfirmRemoverT50 == 0) return;
        AmbienteT50Repo.Remover(ambiente.Id, showConfirmRemoverT50);
        LogRepo.Registrar(TokenStore.AdminId, "Remocao", "AmbienteT50", ambiente.Id);
        // Recarrega ambiente para refletir possível mudança de principal
        ambiente = AmbienteRepo.BuscarPorId(Id);
        dispositivo = DispositivoRepo.ListarTodos().FirstOrDefault(d => d.Id == ambiente!.DispositivoT50Id);
        RecarregarT50s();
        showConfirmRemoverT50 = 0;
    }

    private void AbrirTrocarT50()
    {
        errTrocarT50 = null;
        // Trocar agora só permite T50s já vinculados ao ambiente (swap interno)
        RecarregarT50s();
        novoT50IdSelecionado = t50sVinculados.FirstOrDefault(d => d.Id != ambiente!.DispositivoT50Id)?.Id ?? 0;
        showTrocarT50 = true;
    }

    private async Task HandleTrocarT50()
    {
        if (ambiente == null) return;
        if (novoT50IdSelecionado == 0) { errTrocarT50 = "Selecione um T50."; return; }
        if (novoT50IdSelecionado == ambiente.DispositivoT50Id) { errTrocarT50 = "O T50 selecionado já é o principal."; return; }

        var atual = DispositivoRepo.ListarTodos().FirstOrDefault(d => d.Id == ambiente.DispositivoT50Id);
        var novo  = DispositivoRepo.ListarTodos().FirstOrDefault(d => d.Id == novoT50IdSelecionado);
        if (novo == null) { errTrocarT50 = "T50 selecionado não existe mais."; return; }

        isTrocandoT50 = true;
        StateHasChanged();
        await Task.Yield();
        try
        {
            // SWAP dos contadores de digitais entre o T50 atual e o novo principal.
            // Caso 1: atual=100, novo=0 → atual=0, novo=100.
            // Caso 2: atual=50, novo=80 → atual=80, novo=50.
            if (atual != null)
            {
                var tmp = atual.DigitaisCadastradas;
                atual.DigitaisCadastradas = novo.DigitaisCadastradas;
                novo.DigitaisCadastradas = tmp;
                DispositivoRepo.Atualizar(atual);
                DispositivoRepo.Atualizar(novo);
            }
            // Define o novo principal (também atualiza ambiente.DispositivoT50Id internamente)
            AmbienteT50Repo.DefinirPrincipal(ambiente.Id, novoT50IdSelecionado);
            LogRepo.Registrar(TokenStore.AdminId, "Atualizar", "Ambiente", ambiente.Id);
            ambiente = AmbienteRepo.BuscarPorId(Id);
            dispositivo = novo;
            RecarregarT50s();
            showTrocarT50 = false;
        }
        catch (Exception ex) { errTrocarT50 = ex.Message; }
        finally { isTrocandoT50 = false; }
    }
    private string nomeConfirmacaoExcluir = "";
    private string? erroExcluir = null;
    private long pessoaIdParaRemover = 0;
    private Ambiente? ambiente = null;
    private DispositivoT50? dispositivo = null;
    private List<Pessoa> pessoas = new();
    private List<Pessoa> pessoasDisponiveis = new();
    private List<WebAbil8_Sistema_Verificação_dupla.slnx.Model.Camera> cameras = new();
    private int tempoEspera = 60;
    private long pessoaSelecionadaId = 0;
    private bool aceitouSomenteSenha = false;
    private string novaCameraNome = "";
    private string novaCameraRtsp = "";
    private string novaCameraHls = "";
    private string novaCameraOnvif = "";
    private string novaCameraTipo = "interna";

    protected override async Task OnInitializedAsync()
    {
        ambiente = AmbienteRepo.BuscarPorId(Id);
        if (ambiente != null)
        {
            tempoEspera = ambiente.TempoEsperaGravacaoSeg;
            dispositivo = DispositivoRepo.ListarTodos().FirstOrDefault(d => d.Id == ambiente.DispositivoT50Id);
            RecarregarT50s();
        }
        pessoas = AmbientePessoaRepo.ListarPessoasDoAmbiente(Id);
        cameras = await CameraRepo.ListarPorAmbiente(Id);
        AtualizarPessoasDisponiveis(await PessoaRepo.ListarTodos());
    }

    private void AtualizarPessoasDisponiveis(List<Pessoa> todas)
    {
        var idsComAcesso = pessoas.Select(p => p.Id).ToHashSet();
        pessoasDisponiveis = todas.Where(p => !idsComAcesso.Contains(p.Id)).ToList();
        pessoaSelecionadaId = pessoasDisponiveis.FirstOrDefault()?.Id ?? 0;
    }

    private async Task AbrirModalAdicionarPessoa()
    {
        AtualizarPessoasDisponiveis(await PessoaRepo.ListarTodos());
        showAddPessoa = true;
    }

    private void ConfirmarRemoverPessoa(long pessoaId)
    {
        pessoaIdParaRemover = pessoaId;
        showConfirmRemoverPessoa = true;
    }

    private async Task HandleConfirmarRemoverPessoa()
    {
        await HandleRemoverPessoa(pessoaIdParaRemover);
        showConfirmRemoverPessoa = false;
        pessoaIdParaRemover = 0;
    }

    private async Task HandleRemoverPessoa(long pessoaId)
    {
        AmbientePessoaRepo.RemoverPessoa(Id, pessoaId);
        LogRepo.Registrar(TokenStore.AdminId, "Remocao", "Pessoa", (int)pessoaId);
        pessoas = AmbientePessoaRepo.ListarPessoasDoAmbiente(Id);
        // Inativa a pessoa se ficou sem nenhum ambiente (bug #8)
        var ambientesDaPessoa = AmbientePessoaRepo.ListarAmbientesDaPessoa(pessoaId);
        if (ambientesDaPessoa.Count == 0)
            await PessoaRepo.AlterarStatus(pessoaId, false);
        // Decrementa o contador de digitais do dispositivo
        if (dispositivo != null && dispositivo.DigitaisCadastradas > 0)
        {
            dispositivo.DigitaisCadastradas--;
            DispositivoRepo.Atualizar(dispositivo);
        }
    }

    private async Task HandleAdicionarPessoa()
    {
        if (pessoaSelecionadaId == 0) return;
        var t50Cheio = dispositivo != null && dispositivo.DigitaisCadastradas >= 1000;
        if (t50Cheio && !aceitouSomenteSenha) return;

        isAdicionandoPessoa = true;
        StateHasChanged();
        await Task.Yield();
        try
        {
        AmbientePessoaRepo.AdicionarPessoa(new AmbientePessoa { AmbienteId = Id, PessoaId = pessoaSelecionadaId });
        await PessoaRepo.AlterarStatus(pessoaSelecionadaId, true);
        LogRepo.Registrar(TokenStore.AdminId, "Adicionar", "Pessoa", (int)pessoaSelecionadaId);

        var pessoaAdd = await PessoaRepo.BuscarPorId(pessoaSelecionadaId);

        // doc_tecnica §5.2 passo 3: T50 cheio → força modo somente_senha na pessoa.
        // Não incrementa o contador de digitais (não vai cadastrar biometria neste T50).
        if (t50Cheio)
        {
            if (pessoaAdd != null && pessoaAdd.modoAcesso != "somente_senha")
            {
                pessoaAdd.modoAcesso = "somente_senha";
                await PessoaRepo.Atualizar(pessoaAdd);
            }
        }
        else if (dispositivo != null)
        {
            dispositivo.DigitaisCadastradas++;
            DispositivoRepo.Atualizar(dispositivo);

            // doc_tecnica §5.9: Reativação — se há templateBackup, restaura biometria
            // (em produção o upload pro T50 acontece via Anviz SDK no Worker; aqui marcamos no banco).
            if (pessoaAdd != null
                && pessoaAdd.modoAcesso == "digital_e_senha"
                && pessoaAdd.templateBackup != null
                && pessoaAdd.templateBackup.Length > 0
                && pessoaAdd.biometriaCadastrada == null)
            {
                await PessoaRepo.MarcarBiometriaCadastrada(pessoaAdd.Id);
                LogRepo.Registrar(TokenStore.AdminId, "RestauracaoBiometria", "Pessoa", (int)pessoaAdd.Id);
            }
        }

        pessoas = AmbientePessoaRepo.ListarPessoasDoAmbiente(Id);
        AtualizarPessoasDisponiveis(await PessoaRepo.ListarTodos());
        showAddPessoa = false;
        aceitouSomenteSenha = false;
        }
        finally { isAdicionandoPessoa = false; }
    }

    private async Task HandleAdicionarCamera()
    {
        if (string.IsNullOrWhiteSpace(novaCameraNome)) return;
        isAdicionandoCamera = true;
        StateHasChanged();
        await Task.Yield();
        try
        {
            var novaCamera = new WebAbil8_Sistema_Verificação_dupla.slnx.Model.Camera
            {
                Nome = novaCameraNome,
                AmbienteId = Id,
                UrlRTSP = novaCameraRtsp,
                UrlHLS = string.IsNullOrWhiteSpace(novaCameraHls) ? null : novaCameraHls,
                EnderecoONVIF = string.IsNullOrWhiteSpace(novaCameraOnvif) ? null : novaCameraOnvif,
                Tipo = novaCameraTipo,
                Ativa = true
            };
            await CameraRepo.Adicionar(novaCamera);
            LogRepo.Registrar(TokenStore.AdminId, "Adicionar", "Camera", novaCamera.Id);
            cameras = await CameraRepo.ListarPorAmbiente(Id);
            showAddCamera = false;
            novaCameraNome = novaCameraRtsp = novaCameraHls = novaCameraOnvif = "";
        }
        finally { isAdicionandoCamera = false; }
    }

    private async Task HandleSalvarConfig()
    {
        if (ambiente == null) return;
        isSalvandoConfig = true;
        StateHasChanged();
        await Task.Yield();
        try
        {
            ambiente.TempoEsperaGravacaoSeg = Math.Clamp(tempoEspera, 30, 120);
            AmbienteRepo.Atualizar(ambiente);
            LogRepo.Registrar(TokenStore.AdminId, "Atualizar", "Ambiente", Id);
        }
        finally { isSalvandoConfig = false; }
    }

    private async Task HandleConfirmarExcluir()
    {
        if (ambiente == null) return;
        erroExcluir = null;
        isExcluindo = true;
        try
        {
            var ambienteId = ambiente.Id;
            var ambienteNome = ambiente.Nome;

            // Snapshot das pessoas vinculadas antes de remover — para inativar órfãs depois
            var pessoasVinculadas = AmbientePessoaRepo.ListarPessoasDoAmbiente(ambienteId)
                .Select(p => p.Id).ToList();

            // 1. Remove todas as câmeras do ambiente
            foreach (var cam in cameras)
                await CameraRepo.Remover(cam.Id);

            // 2. Remove todos os vínculos AmbientePessoa
            foreach (var pessoaId in pessoasVinculadas)
                AmbientePessoaRepo.RemoverPessoa(ambienteId, pessoaId);

            // 3. Remove todas as tentativas de acesso do ambiente
            // (FK obrigatória — sem remover, o delete do ambiente falha)
            var tentativas = TentativaRepo.ListarPorAmbiente(ambienteId);
            foreach (var t in tentativas)
                TentativaRepo.Remover(t.Id);

            // 4. Inativa pessoas que ficaram sem nenhum ambiente
            foreach (var pessoaId in pessoasVinculadas)
            {
                var aindaTemAmbiente = AmbientePessoaRepo.ListarAmbientesDaPessoa(pessoaId).Any();
                if (!aindaTemAmbiente)
                    await PessoaRepo.AlterarStatus(pessoaId, false);
            }

            // 5. Remove o próprio ambiente
            AmbienteRepo.Remover(ambienteId);
            LogRepo.Registrar(TokenStore.AdminId, "Remocao", "Ambiente", ambienteId);

            Nav.NavigateTo("/ambientes");
        }
        catch (Exception ex)
        {
            erroExcluir = ex.Message;
            isExcluindo = false;
        }
    }

