@page "/ambientes"
@using WebAbil8_Sistema_Verificação_dupla.slnx.Model
@inject IAmbienteRepository AmbienteRepo
@inject IAmbientePessoaRepository AmbientePessoaRepo
@inject IDispositivoT50Repository DispositivoRepo
@inject ILogAdminRepository LogRepo
@inject ITokenStore TokenStore

<div class="space-y">
    <div class="flex items-center justify-between" style="flex-wrap: wrap; gap: 1rem;">
        <div>
            <h1 class="text-2xl font-bold">Ambientes</h1>
            <p class="text-muted">Gerencie os ambientes e dispositivos T50</p>
        </div>
        <button class="btn btn-primary" @onclick="() => showDialog = true">
            <Icon Name="plus" Size="16" /> Novo Ambiente
        </button>
    </div>

    <div class="flex gap-4" style="flex-wrap: wrap;">
        <div class="input-icon-wrapper flex-1" style="min-width: 200px;">
            <Icon Name="search" />
            <input class="form-input" placeholder="Buscar ambientes..." @bind="search" @bind:event="oninput" />
        </div>
        <select class="form-select" style="width: 180px;" @bind="alertaFilter">
            <option value="todos">Todos os status</option>
            <option value="online">T50 Online</option>
            <option value="offline">T50 Offline</option>
            <option value="alerta">Com Alerta</option>
            <option value="ok">Sem Alerta</option>
        </select>
        <select class="form-select" style="width: 180px;" @bind="sortOpcao">
            <option value="nome_az">Nome A→Z</option>
            <option value="nome_za">Nome Z→A</option>
            <option value="digitais_mais">Mais Digitais</option>
            <option value="digitais_menos">Menos Digitais</option>
        </select>
    </div>

    <div class="grid grid-3">
        @foreach (var amb in SortedAmbientes)
        {
            var dispositivo = dispositivos.FirstOrDefault(d => d.Id == amb.DispositivoT50Id);
            var pessoasCount = AmbientePessoaRepo.ContarPessoasPorAmbiente(amb.Id);
            var emAlerta = dispositivo != null && dispositivo.DigitaisCadastradas >= 950;

            <div class="card">
                <div class="card-header">
                    <div class="flex items-center gap-3">
                        <div class="icon-bg icon-bg-primary"><Icon Name="building" Size="20" /></div>
                        <div>
                            <div class="card-title">@amb.Nome</div>
                            <p class="card-description">Dispositivo T50 ID: @amb.DispositivoT50Id</p>
                        </div>
                    </div>
                </div>
                <div class="card-content space-y-sm">
                    @if (dispositivo == null)
                    {
                        <span class="badge badge-muted"><Icon Name="wifi-off" Size="12" /> Sem T50</span>
                    }
                    else if (!dispositivo.EstaOnline)
                    {
                        <span class="badge badge-destructive"><Icon Name="wifi-off" Size="12" /> Offline (@(dispositivo.DigitaisCadastradas) digitais)</span>
                    }
                    else if (emAlerta)
                    {
                        <span class="badge badge-warning"><Icon Name="alert-triangle" Size="12" /> T50 Alerta (@(dispositivo.DigitaisCadastradas) digitais)</span>
                    }
                    else
                    {
                        <span class="badge badge-success"><Icon Name="wifi" Size="12" /> Online (@(dispositivo.DigitaisCadastradas) digitais)</span>
                    }
                    <div class="grid grid-2">
                        <div><p class="text-muted text-sm">Pessoas com Acesso</p><p class="font-medium">@pessoasCount</p></div>
                        <div><p class="text-muted text-sm">Tempo Espera</p><p class="font-medium">@amb.TempoEsperaGravacaoSeg s</p></div>
                    </div>
                    <a href="/ambientes/@amb.Id" class="btn btn-outline btn-block">Ver Detalhes <Icon Name="chevron-right" Size="16" /></a>
                </div>
            </div>
        }
    </div>

    @if (!SortedAmbientes.Any())
    {
        <div class="card">
            <div class="card-content pt-6" style="text-align: center; padding: 3rem;">
                <Icon Name="building" Size="48" CssClass="text-muted" /><p class="font-medium mt-4">Nenhum ambiente encontrado</p><p class="text-muted">Tente ajustar os filtros de busca</p>
            </div>
        </div>
    }
</div>

@if (showDialog)
{
    <div class="modal-overlay" @onclick="() => showDialog = false">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header"><h3>Criar Novo Ambiente</h3><p>Adicione um novo ambiente ao sistema de controle de acesso</p></div>
            <div class="modal-body space-y-sm">
                <div class="form-group"><label class="form-label">Nome do Ambiente</label><input class="form-input" maxlength="80" placeholder="Ex: Sala de Reuniões" @bind="novoNome" @bind:event="oninput" /></div>
                <div class="form-group">
                    <label class="form-label">Dispositivo T50</label>
                    @if (dispositivos.Any())
                    {
                        <select class="form-select" @bind="novoT50Id">
                            @foreach (var d in dispositivos)
                            {
                                <option value="@d.Id">@d.Nome (@d.EnderecoIP)</option>
                            }
                        </select>
                    }
                    else
                    {
                        <p class="text-sm text-muted">Nenhum dispositivo T50 cadastrado.</p>
                    }
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="() => showDialog = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="HandleCriar">Criar Ambiente</button>
            </div>
        </div>
    </div>
}

@code {
    private string search = "";
    private string alertaFilter = "todos";
    private string sortOpcao = "nome_az";
    private bool showDialog = false;
    private string novoNome = "";
    private int novoT50Id = 0;
    private List<Ambiente> todosAmbientes = new();
    private List<DispositivoT50> dispositivos = new();

    protected override void OnInitialized()
    {
        todosAmbientes = AmbienteRepo.ListarTodos();
        dispositivos = DispositivoRepo.ListarTodos();
        if (dispositivos.Any()) novoT50Id = dispositivos.First().Id;
    }

    private IEnumerable<Ambiente> FilteredAmbientes => todosAmbientes.Where(a =>
    {
        if (!string.IsNullOrEmpty(search) && !a.Nome.Contains(search, StringComparison.OrdinalIgnoreCase))
            return false;
        var disp = dispositivos.FirstOrDefault(d => d.Id == a.DispositivoT50Id);
        return alertaFilter switch
        {
            "online" => disp != null && disp.EstaOnline,
            "offline" => disp == null || !disp.EstaOnline,
            "alerta" => disp != null && disp.DigitaisCadastradas >= 950,
            "ok" => disp != null && disp.DigitaisCadastradas < 950 && disp.EstaOnline,
            _ => true,
        };
    });

    private IEnumerable<Ambiente> SortedAmbientes => sortOpcao switch
    {
        "nome_za" => FilteredAmbientes.OrderByDescending(a => a.Nome),
        "digitais_mais" => FilteredAmbientes.OrderByDescending(a => dispositivos.FirstOrDefault(d => d.Id == a.DispositivoT50Id)?.DigitaisCadastradas ?? 0),
        "digitais_menos" => FilteredAmbientes.OrderBy(a => dispositivos.FirstOrDefault(d => d.Id == a.DispositivoT50Id)?.DigitaisCadastradas ?? 0),
        _ => FilteredAmbientes.OrderBy(a => a.Nome),
    };

    private void HandleCriar()
    {
        if (string.IsNullOrWhiteSpace(novoNome)) return;
        var ambiente = new Ambiente
        {
            Nome = novoNome,
            DispositivoT50Id = novoT50Id,
            TempoEsperaGravacaoSeg = 60,
            DataCriacao = DateTime.UtcNow
        };
        AmbienteRepo.Adicionar(ambiente);
        LogRepo.Registrar(TokenStore.AdminId, "Adicionar", "Ambiente", ambiente.Id);
        todosAmbientes = AmbienteRepo.ListarTodos();
        showDialog = false;
        novoNome = "";
        novoT50Id = dispositivos.FirstOrDefault()?.Id ?? 0;
    }
}