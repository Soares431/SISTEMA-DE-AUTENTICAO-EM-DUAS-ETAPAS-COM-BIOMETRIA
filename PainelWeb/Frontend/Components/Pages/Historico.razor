@* =============================================================================
   Historico.razor - Histórico completo de tentativas de acesso
   Features: 4 cards de resumo, filtros (busca, status, ambiente, período),
             tabela com data/hora, pessoa, status (Permitido/Negado),
             motivo da negação e link para gravação de vídeo,
             ordenação por coluna, navegação clicável para entidades
   Rota: /historico
   ============================================================================= *@
@page "/historico"
@using WebAbil8_Sistema_Verificação_dupla.slnx.Model
@inject ITentativaAcessoRepository TentativaRepo
@inject IAmbienteRepository AmbienteRepo
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IConfiguration Config
@inject ITokenStore TokenStore

<div class="space-y">
    <div class="flex items-center justify-between" style="flex-wrap: wrap; gap: 1rem;">
        <div><h1 class="text-2xl font-bold">Histórico de Acessos</h1><p class="text-muted">Todas as tentativas de entrada com detalhes</p></div>
        <div class="flex gap-2">
            <button class="btn btn-outline" @onclick="ExportarCsv"><Icon Name="download" Size="16" /> CSV</button>
            <button class="btn btn-outline" @onclick="ExportarPdf"><Icon Name="file-text" Size="16" /> PDF</button>
        </div>
    </div>

    <div class="grid grid-4">
        <div class="card"><div class="card-content pt-6"><div class="flex items-center gap-3"><div class="icon-bg icon-bg-primary"><Icon Name="history" Size="20" /></div><div><p class="stat-value">@todasTentativas.Count</p><p class="text-sm text-muted">Total de Registros</p></div></div></div></div>
        <div class="card"><div class="card-content pt-6"><div class="flex items-center gap-3"><div class="icon-bg icon-bg-success"><Icon Name="check-circle" Size="20" /></div><div><p class="stat-value">@todasTentativas.Count(h => h.AcessoLiberado)</p><p class="text-sm text-muted">Acessos Permitidos</p></div></div></div></div>
        <div class="card"><div class="card-content pt-6"><div class="flex items-center gap-3"><div class="icon-bg icon-bg-destructive"><Icon Name="x-circle" Size="20" /></div><div><p class="stat-value">@todasTentativas.Count(h => !h.AcessoLiberado)</p><p class="text-sm text-muted">Acessos Negados</p></div></div></div></div>
        <div class="card"><div class="card-content pt-6"><div class="flex items-center gap-3"><div class="icon-bg icon-bg-warning"><Icon Name="video" Size="20" /></div><div><p class="stat-value">@todasTentativas.Count(h => h.GravacaoPath != null)</p><p class="text-sm text-muted">Com Gravação</p></div></div></div></div>
    </div>

    <div class="card">
        <div class="card-header"><div class="card-title"><Icon Name="filter" Size="20" /> Filtros</div></div>
        <div class="card-content">
            <div class="grid grid-4" style="gap: 1rem;">
                <div class="input-icon-wrapper" style="grid-column: span 2;"><Icon Name="search" /><input class="form-input" placeholder="Buscar por pessoa ou ambiente..." @bind="search" @bind:event="oninput" /></div>
                <select class="form-select" @bind="statusFilter">
                    <option value="todos">Todos</option>
                    <option value="permitido">Permitido</option>
                    <option value="negado">Negado</option>
                </select>
                <select class="form-select" @bind="ambFilter">
                    <option value="todos">Todos</option>
                    @foreach (var a in ambientes)
                    {
                        <option value="@a.Id">@a.Nome</option>
                    }
                </select>
                <select class="form-select" @bind="tipoFilter">
                    <option value="todos">Tipo (todos)</option>
                    <option value="digital_id">Digital + ID</option>
                    <option value="senha_id">Senha + ID</option>
                </select>
                <select class="form-select" @bind="gravacaoFilter">
                    <option value="todos">Gravação (qualquer)</option>
                    <option value="com">Com gravação</option>
                    <option value="sem">Sem gravação</option>
                </select>
                <div class="form-group" style="grid-column: span 2;">
                    <label class="form-label">Período</label>
                    <div class="flex gap-2 items-center">
                        <input type="date" class="form-input" @bind="dataInicio" />
                        <span class="text-muted">até</span>
                        <input type="date" class="form-input" @bind="dataFim" />
                        <button class="btn btn-ghost btn-sm" @onclick="LimparDatas">Limpar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-content pt-6">
            @if (todasTentativas.Count >= 500)
            {
                <p class="text-sm text-muted" style="margin-bottom: 0.75rem;">Exibindo os 500 registros mais recentes. Use filtros ou exporte o CSV para ver todos.</p>
            }
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th @onclick="@(() => AlternarOrdem("dataHora"))" style="cursor:pointer;user-select:none">Data/Hora @SortIcon("dataHora")</th>
                            <th @onclick="@(() => AlternarOrdem("pessoa"))" style="cursor:pointer;user-select:none">Pessoa @SortIcon("pessoa")</th>
                            <th @onclick="@(() => AlternarOrdem("ambiente"))" style="cursor:pointer;user-select:none">Ambiente @SortIcon("ambiente")</th>
                            <th @onclick="@(() => AlternarOrdem("status"))" style="cursor:pointer;user-select:none">Status @SortIcon("status")</th>
                            <th>Motivo</th>
                            <th>Gravação</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Sorted)
                        {
                            <tr>
                                <td><div class="flex items-center gap-2"><Icon Name="clock" Size="16" CssClass="text-muted" /><div><p class="font-mono text-sm">@DateHelper.Local(item.DataHora).ToString("dd/MM/yyyy")</p><p class="font-mono text-xs text-muted">@DateHelper.Local(item.DataHora).ToString("HH:mm:ss")</p></div></div></td>
                                <td>
                                    @if (item.PessoaId.HasValue)
                                    {
                                        <a href="/pessoas/@item.PessoaId" class="flex items-center gap-2" style="text-decoration:none;cursor:pointer">
                                            <Icon Name="user" Size="16" CssClass="text-muted" />
                                            <span>@(item.Pessoa?.Nome ?? $"ID {item.PessoaId}")</span>
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="flex items-center gap-2 text-muted"><Icon Name="user-x" Size="16" /> Não cadastrado</span>
                                    }
                                </td>
                                <td>
                                    <a href="/ambientes/@item.AmbienteId" class="flex items-center gap-2 text-muted" style="text-decoration:none;cursor:pointer">
                                        <Icon Name="map-pin" Size="16" />
                                        @(item.Ambiente?.Nome ?? ambientes.FirstOrDefault(a => a.Id == item.AmbienteId)?.Nome ?? $"Ambiente {item.AmbienteId}")
                                    </a>
                                </td>
                                <td><span class="badge @(item.AcessoLiberado ? "badge-success" : "badge-destructive")"><Icon Name="@(item.AcessoLiberado ? "check-circle" : "x-circle")" Size="12" /> @(item.AcessoLiberado ? "Permitido" : "Negado")</span></td>
                                <td class="text-muted">@(item.MotivoNegacao ?? "-")</td>
                                <td>@if (item.GravacaoPath != null) {
                                    <button class="btn btn-ghost btn-sm text-primary" @onclick="() => AbrirGravacao(item.Id)"><Icon Name="video" Size="16" /> Ver</button>
                                } else {
                                    <span class="text-sm text-muted">-</span>
                                }</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private string search = "";
    private string statusFilter = "todos";
    private string ambFilter = "todos";
    private string tipoFilter = "todos";
    private string gravacaoFilter = "todos";
    private string sortColumn = "dataHora";
    private bool sortAsc = false;
    private DateTime? dataInicio = null;
    private DateTime? dataFim = null;
    private List<TentativaAcesso> todasTentativas = new();
    private List<Ambiente> ambientes = new();

    protected override Task OnInitializedAsync()
    {
        todasTentativas = TentativaRepo.ListarTodos()
            .OrderByDescending(t => t.DataHora)
            .Take(500)
            .ToList();
        ambientes = AmbienteRepo.ListarTodos();
        return Task.CompletedTask;
    }

    private IEnumerable<TentativaAcesso> Filtered => todasTentativas.Where(h =>
        (string.IsNullOrEmpty(search) ||
         (h.Pessoa?.Nome.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false) ||
         (h.Ambiente?.Nome.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false)) &&
        (statusFilter == "todos" || (statusFilter == "permitido" ? h.AcessoLiberado : !h.AcessoLiberado)) &&
        (ambFilter == "todos" || h.AmbienteId.ToString() == ambFilter) &&
        (tipoFilter == "todos" || h.TipoVerificacao == tipoFilter) &&
        (gravacaoFilter == "todos" || (gravacaoFilter == "com" ? h.GravacaoPath != null : h.GravacaoPath == null)) &&
        (dataInicio == null || h.DataHora.Date >= dataInicio.Value.Date) &&
        (dataFim == null || h.DataHora.Date <= dataFim.Value.Date));

    private IEnumerable<TentativaAcesso> Sorted => sortColumn switch
    {
        "pessoa" => sortAsc ? Filtered.OrderBy(h => h.Pessoa?.Nome ?? "") : Filtered.OrderByDescending(h => h.Pessoa?.Nome ?? ""),
        "ambiente" => sortAsc ? Filtered.OrderBy(h => h.Ambiente?.Nome ?? "") : Filtered.OrderByDescending(h => h.Ambiente?.Nome ?? ""),
        "status" => sortAsc ? Filtered.OrderBy(h => h.AcessoLiberado) : Filtered.OrderByDescending(h => h.AcessoLiberado),
        _ => sortAsc ? Filtered.OrderBy(h => h.DataHora) : Filtered.OrderByDescending(h => h.DataHora),
    };

    private void AlternarOrdem(string coluna)
    {
        if (sortColumn == coluna) sortAsc = !sortAsc;
        else { sortColumn = coluna; sortAsc = true; }
    }

    private string SortIcon(string coluna) =>
        sortColumn == coluna ? (sortAsc ? " ▲" : " ▼") : "";

    private void LimparDatas() { dataInicio = null; dataFim = null; }

    private async Task AbrirGravacao(int tentativaId)
    {
        var apiUrl = Config["BancoApiUrl"] ?? "http://localhost:5018/";
        await JS.InvokeVoidAsync("abrirGravacao", apiUrl, tentativaId, TokenStore.Token);
    }

    private async Task ExportarPdf()
    {
        var apiUrl = Config["BancoApiUrl"] ?? "http://localhost:5018/";
        await JS.InvokeVoidAsync("baixarPdf", apiUrl + "api/export/historico.pdf", TokenStore.Token, "historico.pdf");
    }

    private async Task ExportarCsv()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Data/Hora,Pessoa,Ambiente,Status,Motivo,Gravacao");
        foreach (var item in Sorted)
        {
            var pessoa = item.Pessoa?.Nome ?? $"ID {item.PessoaId}";
            var amb = item.Ambiente?.Nome ?? ambientes.FirstOrDefault(a => a.Id == item.AmbienteId)?.Nome ?? $"Ambiente {item.AmbienteId}";
            var status = item.AcessoLiberado ? "Permitido" : "Negado";
            var motivo = item.MotivoNegacao ?? "";
            var gravacao = item.GravacaoPath ?? "";
            sb.AppendLine($"{DateHelper.Local(item.DataHora):dd/MM/yyyy HH:mm:ss},\"{pessoa}\",\"{amb}\",{status},{motivo},{gravacao}");
        }
        await JS.InvokeVoidAsync("downloadCsv", $"historico_{DateTime.Now:yyyyMMdd_HHmm}.csv", sb.ToString());
    }
}
