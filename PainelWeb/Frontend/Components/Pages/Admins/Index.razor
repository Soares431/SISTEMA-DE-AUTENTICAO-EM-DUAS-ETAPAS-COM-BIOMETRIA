@page "/admins"
@using WebAbil8_Sistema_Verificação_dupla.slnx.Model
@inject IAdministradorRepository AdminRepo
@inject ILogAdminRepository LogRepo
@inject ITokenStore TokenStore
@inject IJSRuntime JS
@inject IConfiguration Config

<div class="space-y">
    <div class="flex items-center justify-between" style="flex-wrap: wrap; gap: 1rem;">
        <div><h1 class="text-2xl font-bold">Administradores</h1><p class="text-muted">Gestão de usuários administrativos do sistema</p></div>
        <div class="flex gap-2 items-center">
            <button class="btn btn-outline" @onclick="ExportarCsv"><Icon Name="download" Size="16" /> CSV</button>
            <button class="btn btn-outline" @onclick="ExportarPdf"><Icon Name="file-text" Size="16" /> PDF</button>
        </div>
    </div>
    <p class="text-muted text-sm"><Icon Name="info" Size="14" /> Criação de administradores apenas via acesso direto ao banco de dados</p>

    <div class="flex gap-4" style="flex-wrap: wrap;">
        <div class="input-icon-wrapper flex-1" style="min-width: 200px;">
            <Icon Name="search" /><input class="form-input" placeholder="Buscar por nome, cargo ou email..." @bind="search" @bind:event="oninput" />
        </div>
    </div>

    <div class="card">
        <div class="card-content pt-6">
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th @onclick="@(() => AlternarOrdem("nome"))" style="cursor:pointer;user-select:none">Nome Completo @SortIcon("nome")</th>
                            <th @onclick="@(() => AlternarOrdem("cargo"))" style="cursor:pointer;user-select:none">Cargo / Patente @SortIcon("cargo")</th>
                            <th @onclick="@(() => AlternarOrdem("email"))" style="cursor:pointer;user-select:none">Email @SortIcon("email")</th>
                            <th @onclick="@(() => AlternarOrdem("datacriacao"))" style="cursor:pointer;user-select:none">Criado em @SortIcon("datacriacao")</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in Sorted)
                        {
                            <tr>
                                <td><span class="font-semibold">@a.NomeCompleto</span></td>
                                <td class="text-muted">@(a.Cargo ?? "-")</td>
                                <td class="text-muted text-sm">@(a.Email ?? "-")</td>
                                <td class="text-muted text-sm">@DateHelper.Local(a.DataCriacao).ToString("dd/MM/yyyy")</td>
                                <td><a href="/admins/@a.Id" class="btn btn-ghost btn-sm">Ver <Icon Name="chevron-right" Size="16" /></a></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!Sorted.Any())
            {
                <div style="text-align:center; padding:2rem;">
                    <Icon Name="shield" Size="48" CssClass="text-muted" />
                    <p class="font-medium mt-4">Nenhum administrador encontrado</p>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string search = "";
    private string sortColumn = "nome";
    private bool sortAsc = true;
    private List<Administrador> todosAdmins = new();

    protected override void OnInitialized()
    {
        todosAdmins = AdminRepo.ListarTodos();
    }

    private IEnumerable<Administrador> Filtered => todosAdmins.Where(a =>
        string.IsNullOrEmpty(search) ||
        a.NomeCompleto.Contains(search, StringComparison.OrdinalIgnoreCase) ||
        (a.Cargo?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false) ||
        (a.Email?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false));

    private IEnumerable<Administrador> Sorted => sortColumn switch
    {
        "cargo" => sortAsc ? Filtered.OrderBy(a => a.Cargo) : Filtered.OrderByDescending(a => a.Cargo),
        "email" => sortAsc ? Filtered.OrderBy(a => a.Email) : Filtered.OrderByDescending(a => a.Email),
        "datacriacao" => sortAsc ? Filtered.OrderBy(a => a.DataCriacao) : Filtered.OrderByDescending(a => a.DataCriacao),
        _ => sortAsc ? Filtered.OrderBy(a => a.NomeCompleto) : Filtered.OrderByDescending(a => a.NomeCompleto),
    };

    private void AlternarOrdem(string coluna)
    {
        if (sortColumn == coluna) sortAsc = !sortAsc;
        else { sortColumn = coluna; sortAsc = true; }
    }

    private string SortIcon(string coluna) =>
        sortColumn == coluna ? (sortAsc ? " ▲" : " ▼") : "";

    private async Task ExportarPdf()
    {
        var apiUrl = Config["BancoApiUrl"] ?? "http://localhost:5018/";
        var qs = !string.IsNullOrEmpty(search) ? $"?search={Uri.EscapeDataString(search)}" : "";
        var sufixo = !string.IsNullOrEmpty(search) ? $"_busca-{Slug(search)}" : "";
        await JS.InvokeVoidAsync("baixarPdf",
            apiUrl + "api/export/admins.pdf" + qs,
            TokenStore.Token,
            $"admins{sufixo}.pdf");
    }

    private async Task ExportarCsv()
    {
        var sb = new System.Text.StringBuilder();
        // Por segurança: NÃO exporta Login.
        sb.AppendLine("Nome Completo,CPF,Cargo,Email,Telefone,Cadastro");
        foreach (var a in Sorted)
        {
            sb.AppendLine($"\"{a.NomeCompleto}\",\"{FormatHelper.FormatarCpf(a.Cpf)}\",\"{a.Cargo ?? ""}\",\"{a.Email ?? ""}\",\"{FormatHelper.FormatarTelefone(a.Telefone)}\",\"{DateHelper.Local(a.DataCriacao):dd/MM/yyyy}\"");
        }
        var sufixo = !string.IsNullOrEmpty(search) ? $"_busca-{Slug(search)}" : "";
        await JS.InvokeVoidAsync("downloadCsv",
            $"admins_{DateTime.Now:yyyyMMdd_HHmm}{sufixo}.csv",
            sb.ToString());
    }

    private static string Slug(string s) =>
        new string((s ?? "").Where(c => char.IsLetterOrDigit(c) || c == '-').ToArray()).ToLower();
}
