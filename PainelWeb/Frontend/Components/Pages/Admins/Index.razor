@page "/admins"
@using WebAbil8_Sistema_Verificação_dupla.slnx.Model
@inject IAdministradorRepository AdminRepo
@inject ILogAdminRepository LogRepo
@inject ITokenStore TokenStore

<div class="space-y">
    <div class="flex items-center justify-between" style="flex-wrap: wrap; gap: 1rem;">
        <div><h1 class="text-2xl font-bold">Administradores</h1><p class="text-muted">Gestão de usuários administrativos do sistema</p></div>
        <button class="btn btn-primary" @onclick="() => showDialog = true"><Icon Name="plus" Size="16" /> Novo Administrador</button>
    </div>

    <div class="flex gap-4" style="flex-wrap: wrap;">
        <div class="input-icon-wrapper flex-1" style="min-width: 200px;">
            <Icon Name="search" /><input class="form-input" placeholder="Buscar por nome, login ou cargo..." @bind="search" @bind:event="oninput" />
        </div>
    </div>

    <div class="card">
        <div class="card-content pt-6">
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th @onclick="@(() => AlternarOrdem("id"))" style="cursor:pointer;user-select:none">ID @SortIcon("id")</th>
                            <th @onclick="@(() => AlternarOrdem("nome"))" style="cursor:pointer;user-select:none">Nome Completo @SortIcon("nome")</th>
                            <th @onclick="@(() => AlternarOrdem("login"))" style="cursor:pointer;user-select:none">Login @SortIcon("login")</th>
                            <th @onclick="@(() => AlternarOrdem("cargo"))" style="cursor:pointer;user-select:none">Cargo / Patente @SortIcon("cargo")</th>
                            <th @onclick="@(() => AlternarOrdem("email"))" style="cursor:pointer;user-select:none">Email @SortIcon("email")</th>
                            <th @onclick="@(() => AlternarOrdem("datacriacao"))" style="cursor:pointer;user-select:none">Criado em @SortIcon("datacriacao")</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in Sorted)
                        {
                            <tr>
                                <td class="font-mono text-sm text-muted">@a.Id</td>
                                <td><span class="font-semibold">@a.NomeCompleto</span></td>
                                <td class="font-mono text-sm">@a.Login</td>
                                <td class="text-muted">@(a.Cargo ?? "-")</td>
                                <td class="text-muted text-sm">@(a.Email ?? "-")</td>
                                <td class="text-muted text-sm">@a.DataCriacao.ToString("dd/MM/yyyy")</td>
                                <td><a href="/admins/@a.Id" class="btn btn-ghost btn-sm">Ver <Icon Name="chevron-right" Size="16" /></a></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!Sorted.Any())
            {
                <div style="text-align:center; padding:2rem;">
                    <Icon Name="shield" Size="48" CssClass="text-muted" />
                    <p class="font-medium mt-4">Nenhum administrador encontrado</p>
                </div>
            }
        </div>
    </div>
</div>

@if (showDialog)
{
    <div class="modal-overlay" @onclick="FecharDialog">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header"><h3>Cadastrar Administrador</h3><p>Adicione um novo usuário administrativo</p></div>
            <div class="modal-body space-y-sm">
                @if (erroCadastro != null)
                {
                    <div class="alert alert-danger">@erroCadastro</div>
                }
                <div class="grid grid-2">
                    <div class="form-group"><label class="form-label">Nome Completo *</label><input class="form-input" @bind="novoNome" /></div>
                    <div class="form-group"><label class="form-label">Login *</label><input class="form-input" @bind="novoLogin" /></div>
                </div>
                <div class="grid grid-2">
                    <div class="form-group"><label class="form-label">Senha *</label><input class="form-input" type="password" @bind="novaSenha" /></div>
                    <div class="form-group"><label class="form-label">Confirmar Senha *</label><input class="form-input" type="password" @bind="confirmarSenha" /></div>
                </div>
                <div class="grid grid-2">
                    <div class="form-group"><label class="form-label">CPF</label><input class="form-input" placeholder="000.000.000-00" @bind="novoCpf" /></div>
                    <div class="form-group"><label class="form-label">Cargo / Patente</label><input class="form-input" placeholder="Ex: Capitão" @bind="novoCargo" /></div>
                </div>
                <div class="grid grid-2">
                    <div class="form-group"><label class="form-label">Email</label><input class="form-input" type="email" @bind="novoEmail" /></div>
                    <div class="form-group"><label class="form-label">Telefone</label><input class="form-input" placeholder="(00) 00000-0000" @bind="novoTelefone" /></div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="FecharDialog">Cancelar</button>
                <button class="btn btn-primary" @onclick="HandleCadastrar" disabled="@isCadastrando">
                    @(isCadastrando ? "Cadastrando..." : "Cadastrar")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private string search = "";
    private string sortColumn = "nome";
    private bool sortAsc = true;
    private bool showDialog = false;
    private bool isCadastrando = false;
    private string? erroCadastro = null;
    private List<Administrador> todosAdmins = new();

    private string novoNome = "";
    private string novoLogin = "";
    private string novaSenha = "";
    private string confirmarSenha = "";
    private string novoCpf = "";
    private string novoCargo = "";
    private string novoEmail = "";
    private string novoTelefone = "";

    protected override void OnInitialized()
    {
        todosAdmins = AdminRepo.ListarTodos();
    }

    private IEnumerable<Administrador> Filtered => todosAdmins.Where(a =>
        string.IsNullOrEmpty(search) ||
        a.NomeCompleto.Contains(search, StringComparison.OrdinalIgnoreCase) ||
        a.Login.Contains(search, StringComparison.OrdinalIgnoreCase) ||
        (a.Cargo?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false) ||
        (a.Email?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false));

    private IEnumerable<Administrador> Sorted => sortColumn switch
    {
        "id" => sortAsc ? Filtered.OrderBy(a => a.Id) : Filtered.OrderByDescending(a => a.Id),
        "login" => sortAsc ? Filtered.OrderBy(a => a.Login) : Filtered.OrderByDescending(a => a.Login),
        "cargo" => sortAsc ? Filtered.OrderBy(a => a.Cargo) : Filtered.OrderByDescending(a => a.Cargo),
        "email" => sortAsc ? Filtered.OrderBy(a => a.Email) : Filtered.OrderByDescending(a => a.Email),
        "datacriacao" => sortAsc ? Filtered.OrderBy(a => a.DataCriacao) : Filtered.OrderByDescending(a => a.DataCriacao),
        _ => sortAsc ? Filtered.OrderBy(a => a.NomeCompleto) : Filtered.OrderByDescending(a => a.NomeCompleto),
    };

    private void AlternarOrdem(string coluna)
    {
        if (sortColumn == coluna) sortAsc = !sortAsc;
        else { sortColumn = coluna; sortAsc = true; }
    }

    private string SortIcon(string coluna) =>
        sortColumn == coluna ? (sortAsc ? " ▲" : " ▼") : "";

    private void FecharDialog()
    {
        showDialog = false;
        erroCadastro = null;
        novoNome = novoLogin = novaSenha = confirmarSenha = novoCpf = novoCargo = novoEmail = novoTelefone = "";
    }

    private void HandleCadastrar()
    {
        if (string.IsNullOrWhiteSpace(novoNome) || string.IsNullOrWhiteSpace(novoLogin) || string.IsNullOrWhiteSpace(novaSenha))
        {
            erroCadastro = "Nome completo, login e senha são obrigatórios.";
            return;
        }
        if (novaSenha != confirmarSenha)
        {
            erroCadastro = "As senhas não coincidem.";
            return;
        }
        if (novaSenha.Length < 6)
        {
            erroCadastro = "A senha deve ter pelo menos 6 caracteres.";
            return;
        }
        if (AdminRepo.LoginExiste(novoLogin))
        {
            erroCadastro = $"O login '{novoLogin}' já está em uso.";
            return;
        }

        isCadastrando = true;
        erroCadastro = null;
        try
        {
            var admin = new Administrador
            {
                NomeCompleto = novoNome.Trim(),
                Login = novoLogin.Trim(),
                SenhaHash = BCrypt.Net.BCrypt.HashPassword(novaSenha, workFactor: 10),
                Cpf = string.IsNullOrWhiteSpace(novoCpf) ? null : novoCpf.Trim(),
                Cargo = string.IsNullOrWhiteSpace(novoCargo) ? null : novoCargo.Trim(),
                Email = string.IsNullOrWhiteSpace(novoEmail) ? null : novoEmail.Trim(),
                Telefone = string.IsNullOrWhiteSpace(novoTelefone) ? null : novoTelefone.Trim(),
                DataCriacao = DateTime.UtcNow
            };
            var salvo = AdminRepo.Adicionar(admin);
            LogRepo.Registrar(TokenStore.AdminId, "Adicionar", "Administrador", salvo.Id);
            todosAdmins = AdminRepo.ListarTodos();
            FecharDialog();
        }
        catch (Exception ex)
        {
            erroCadastro = ex.Message;
        }
        finally
        {
            isCadastrando = false;
        }
    }
}
