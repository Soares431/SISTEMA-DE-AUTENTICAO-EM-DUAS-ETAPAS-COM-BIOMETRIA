@page "/pessoas/{Id:long}"
@using WebAbil8_Sistema_Verificação_dupla.slnx.Model
@inject IPessoaRepository PessoaRepo
@inject ITentativaAcessoRepository TentativaRepo
@inject IAmbientePessoaRepository AmbientePessoaRepo
@inject IAmbienteRepository AmbienteRepo
@inject ICodigoRepository CodigoRepo
@inject ISenhaRepository SenhaRepo
@inject ILogAdminRepository LogRepo
@inject ITokenStore TokenStore
@inject NavigationManager Nav
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS

<div class="space-y">
    @if (pessoa == null)
    {
        <p class="text-muted">Carregando...</p>
    }
    else
    {
        <div class="flex items-center gap-4">
            <a href="/pessoas" class="btn btn-ghost btn-icon"><Icon Name="arrow-left" Size="20" /></a>
            <div class="flex-1"><h1 class="text-2xl font-bold">@pessoa.Nome</h1><p class="text-muted">@pessoa.Cargo</p></div>
            <span class="badge @(pessoa.Status == "ativo" ? "badge-success" : "badge-muted")">@pessoa.Status</span>
        </div>

        <div class="grid grid-1-2" style="gap: 1.5rem;">
            <!-- Profile Sidebar -->
            <div class="card">
                <div class="card-content pt-6" style="text-align: center;">
                    <div class="avatar avatar-lg" style="margin: 0 auto 1rem;">@GetInitials(pessoa.Nome)</div>
                    <h2 class="text-xl font-semibold">@pessoa.Nome</h2><p class="text-muted">@pessoa.Cargo</p>
                    <div style="text-align: left; margin-top: 1.5rem;" class="space-y-xs">
                        <div class="flex items-center gap-3 text-sm">
                            <Icon Name="hash" Size="16" CssClass="text-muted" />
                            <span class="text-muted">ID T50:</span>
                            <span class="font-mono font-semibold">@(pessoa.CodigoUsuario ?? "—")</span>
                        </div>
                        <div class="flex items-center gap-3 text-sm"><Icon Name="mail" Size="16" CssClass="text-muted" /> @pessoa.Email</div>
                        <div class="flex items-center gap-3 text-sm">
                            <Icon Name="fingerprint" Size="16" CssClass="text-muted" />
                            <span class="badge @(pessoa.biometriaCadastrada != null ? "badge-success" : "badge-warning")">
                                Biometria @(pessoa.biometriaCadastrada != null ? "cadastrada" : "pendente")
                            </span>
                        </div>
                        <div class="flex items-center gap-3 text-sm"><Icon Name="clock" Size="16" CssClass="text-muted" /><span class="text-muted">Ultimo acesso: @(DateHelper.Local(pessoa.dataUltimoAcesso)?.ToString("dd/MM/yyyy HH:mm") ?? "-")</span></div>
                    </div>
                    <div class="mt-6 pt-6 border-t space-y-xs">
                        <button class="btn btn-outline btn-block" @onclick="() => showEdit = true"><Icon Name="edit" Size="16" /> Editar Perfil</button>
                        <button class="btn btn-outline btn-block" @onclick="HandleReenviarSenha" disabled="@isReenviando">
                            @if (isReenviando) { <span class="spinner"></span><span>Reenviando…</span> }
                            else { <Icon Name="mail" Size="16" /> <span>Reenviar ID + Senha</span> }
                        </button>
                        <button class="btn btn-outline btn-block" @onclick="() => showConfirmReset = true"><Icon Name="refresh" Size="16" /> Resetar Biometria</button>
                        @if (pessoa.Status == "ativo")
                        {
                            <button class="btn btn-outline btn-block text-destructive" @onclick="() => showConfirmInativar = true"><Icon Name="user-x" Size="16" /> Inativar Pessoa</button>
                        }
                        <button class="btn btn-ghost btn-block text-destructive" style="margin-top:0.5rem;" @onclick="() => showConfirmExcluir = true"><Icon Name="trash" Size="16" /> Excluir Permanentemente</button>
                    </div>
                </div>
            </div>

            <!-- Content Area -->
            <div class="space-y">
                <div class="tabs-list">
                    <button class="tab-trigger @(tab == "ambientes" ? "active" : "")" @onclick='() => tab = "ambientes"'>Ambientes com Acesso</button>
                    <button class="tab-trigger @(tab == "historico" ? "active" : "")" @onclick='() => tab = "historico"'>Histórico de Entradas</button>
                </div>

                @if (tab == "ambientes")
                {
                    <div class="card">
                        <div class="card-header"><div class="card-title"><Icon Name="key" Size="20" /> Ambientes com Acesso</div><p class="card-description">@ambientesPessoa.Count ambientes autorizados</p></div>
                        <div class="card-content">
                            <table>
                                <thead><tr><th>Ambiente</th><th>Ação</th></tr></thead>
                                <tbody>
                                    @foreach (var amb in ambientesPessoa)
                                    {
                                        <tr>
                                            <td class="font-medium"><span class="flex items-center gap-2"><Icon Name="map-pin" Size="16" CssClass="text-muted" /> @amb.Nome</span></td>
                                            <td class="text-right"><button class="btn btn-ghost btn-sm text-destructive" @onclick="() => ConfirmarRemoverAcesso(amb.Id)">Remover Acesso</button></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card">
                        <div class="card-header card-header-row"><div><div class="card-title"><Icon Name="history" Size="20" /> Histórico de Entradas</div><p class="card-description">Últimas tentativas de acesso</p></div><a href="/historico" class="btn btn-outline btn-sm">Ver Todos</a></div>
                        <div class="card-content">
                            <table>
                                <thead><tr><th>Data/Hora</th><th>Ambiente</th><th>Status</th></tr></thead>
                                <tbody>
                                    @foreach (var t in historico)
                                    {
                                        <tr>
                                            <td class="font-mono text-sm text-muted">@DateHelper.Local(t.DataHora).ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>@(t.Ambiente?.Nome ?? $"Ambiente {t.AmbienteId}")</td>
                                            <td><span class="badge @(t.AcessoLiberado ? "badge-success" : "badge-destructive")"><Icon Name="@(t.AcessoLiberado ? "check-circle" : "x-circle")" Size="12" /> @(t.AcessoLiberado ? "Permitido" : "Negado")</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@if (showEdit && pessoa != null)
{
    <div class="modal-overlay" @onclick="() => showEdit = false">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header"><h3>Editar Perfil</h3><p>Atualize as informacoes da pessoa</p></div>
            <div class="modal-body space-y-sm">
                <div class="form-group"><label class="form-label">Nome</label><input class="form-input" maxlength="100" @bind="editNome" /></div>
                <div class="form-group"><label class="form-label">Email</label><input class="form-input" type="email" maxlength="150" @bind="editEmail" /></div>
                <div class="form-group"><label class="form-label">Cargo</label><input class="form-input" maxlength="100" @bind="editCargo" /></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="() => showEdit = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="HandleSalvarEdicao">Salvar</button>
            </div>
        </div>
    </div>
}

@if (showConfirmInativar && pessoa != null)
{
    <div class="modal-overlay" @onclick="() => showConfirmInativar = false">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Inativar Pessoa</h3>
                <p>Confirme a operação antes de prosseguir</p>
            </div>
            <div class="modal-body">
                <p>Ao inativar <strong>@pessoa.Nome</strong>, a pessoa perderá acesso a todos os <strong>@ambientesPessoa.Count ambiente(s)</strong> cadastrado(s). Para reativar, adicione-a novamente a um ambiente.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="() => showConfirmInativar = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="HandleConfirmarInativar">Confirmar</button>
            </div>
        </div>
    </div>
}

@if (showConfirmRemoverAcesso && pessoa != null)
{
    <div class="modal-overlay" @onclick="() => showConfirmRemoverAcesso = false">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Remover Acesso ao Ambiente</h3>
                <p>Confirme antes de prosseguir</p>
            </div>
            <div class="modal-body">
                <p>Deseja remover o acesso de <strong>@pessoa.Nome</strong> a este ambiente? Se for o último ambiente vinculado, a pessoa será inativada automaticamente.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="() => showConfirmRemoverAcesso = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="HandleConfirmarRemoverAcesso">Remover</button>
            </div>
        </div>
    </div>
}

@if (showConfirmExcluir && pessoa != null)
{
    <div class="modal-overlay" @onclick="() => { showConfirmExcluir = false; nomeConfirmacaoExcluir = string.Empty; erroExcluir = null; }">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Excluir Pessoa Permanentemente</h3>
                <p>Esta ação não pode ser desfeita</p>
            </div>
            <div class="modal-body space-y-sm">
                <div class="alert alert-danger">Todos os dados de <strong>@pessoa.Nome</strong> serão removidos permanentemente, incluindo histórico de acessos e biometria.</div>
                <div class="form-group">
                    <label class="form-label">Digite o nome exato para confirmar: <strong>@pessoa.Nome</strong></label>
                    <input class="form-input" @bind="nomeConfirmacaoExcluir" placeholder="@pessoa.Nome" />
                </div>
                @if (erroExcluir != null) { <div class="alert alert-danger">@erroExcluir</div> }
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="() => { showConfirmExcluir = false; nomeConfirmacaoExcluir = string.Empty; erroExcluir = null; }">Cancelar</button>
                <button class="btn btn-primary text-destructive" @onclick="HandleConfirmarExcluir" disabled="@(nomeConfirmacaoExcluir != pessoa.Nome)">Excluir Permanentemente</button>
            </div>
        </div>
    </div>
}

@if (showConfirmReset && pessoa != null)
{
    <div class="modal-overlay" @onclick="() => showConfirmReset = false">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Resetar Biometria</h3>
                <p>Confirme a operação antes de prosseguir</p>
            </div>
            <div class="modal-body">
                <p>O template biométrico de <strong>@pessoa.Nome</strong> será apagado. A pessoa precisará recadastrar a digital no próximo acesso.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="() => showConfirmReset = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="HandleConfirmarReset">Confirmar Reset</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public long Id { get; set; }
    private string tab = "ambientes";
    private bool showEdit = false;
    private bool showConfirmInativar = false;
    private bool showConfirmReset = false;
    private bool showConfirmRemoverAcesso = false;
    private bool showConfirmExcluir = false;
    private int ambienteIdParaRemover = 0;
    private string nomeConfirmacaoExcluir = "";
    private string? erroExcluir = null;
    private bool isReenviando = false;
    private Pessoa? pessoa = null;
    private List<Ambiente> ambientesPessoa = new();
    private List<TentativaAcesso> historico = new();
    private string editNome = "";
    private string editEmail = "";
    private string editCargo = "";

    protected override async Task OnInitializedAsync()
    {
        pessoa = await PessoaRepo.BuscarPorId(Id);
        if (pessoa != null)
        {
            editNome = pessoa.Nome;
            editEmail = pessoa.Email;
            editCargo = pessoa.Cargo;

            ambientesPessoa = AmbientePessoaRepo.ListarAmbientesDaPessoa(pessoa.Id);

            historico = TentativaRepo.ListarPorPessoa(pessoa.Id)
                .OrderByDescending(t => t.DataHora)
                .Take(10)
                .ToList();
        }
    }

    private string GetInitials(string nome) => string.Join("", nome.Split(' ').Take(2).Select(n => n[0])).ToUpper();

    private async Task HandleReenviarSenha()
    {
        if (pessoa == null || isReenviando) return;
        isReenviando = true;
        try
        {
            var client = HttpClientFactory.CreateClient("BancoAPI");
            client.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", TokenStore.Token);
            var resp = await client.PostAsync($"api/person/{pessoa.Id}/reenviar-credenciais", null);
            if (resp.IsSuccessStatusCode)
                await JS.InvokeVoidAsync("alert", "Credenciais (ID + senha) reenviadas. Verifique o email do usuário (ou o console do servidor caso SMTP esteja indisponível).");
            else
                await JS.InvokeVoidAsync("alert", $"Falha ao reenviar (HTTP {(int)resp.StatusCode}).");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Erro: {ex.Message}");
        }
        finally
        {
            isReenviando = false;
        }
    }

    private async Task HandleSalvarEdicao()
    {
        if (pessoa == null) return;
        if (string.IsNullOrWhiteSpace(editNome) || string.IsNullOrWhiteSpace(editEmail) || string.IsNullOrWhiteSpace(editCargo))
            return;
        if (!System.Text.RegularExpressions.Regex.IsMatch(editEmail, @"^[^@\s]+@[^@\s]+\.[^@\s]+$"))
            return;
        if (editNome.Length > 100 || editEmail.Length > 150 || editCargo.Length > 100)
            return;

        pessoa.Nome = editNome;
        pessoa.Email = editEmail;
        pessoa.Cargo = editCargo;
        await PessoaRepo.Atualizar(pessoa);
        LogRepo.Registrar(TokenStore.AdminId, "Atualizar", "Pessoa", (int)pessoa.Id);
        showEdit = false;
    }

    private async Task HandleRemoverAcesso(int ambienteId)
    {
        if (pessoa == null) return;
        AmbientePessoaRepo.RemoverPessoa(ambienteId, pessoa.Id);
        LogRepo.Registrar(TokenStore.AdminId, "Remocao", "Pessoa", (int)pessoa.Id);
        ambientesPessoa = AmbientePessoaRepo.ListarAmbientesDaPessoa(pessoa.Id);
        // Se ficou sem nenhum ambiente, inativa a pessoa
        if (ambientesPessoa.Count == 0 && pessoa.Status == "ativo")
        {
            await PessoaRepo.AlterarStatus(pessoa.Id, false);
            pessoa.Status = "inativo";
        }
    }

    private void ConfirmarRemoverAcesso(int ambienteId)
    {
        ambienteIdParaRemover = ambienteId;
        showConfirmRemoverAcesso = true;
    }

    private async Task HandleConfirmarRemoverAcesso()
    {
        await HandleRemoverAcesso(ambienteIdParaRemover);
        showConfirmRemoverAcesso = false;
        ambienteIdParaRemover = 0;
    }

    private async Task HandleConfirmarInativar()
    {
        if (pessoa == null) return;
        foreach (var amb in ambientesPessoa)
            AmbientePessoaRepo.RemoverPessoa(amb.Id, pessoa.Id);
        await PessoaRepo.AlterarStatus(pessoa.Id, false);
        LogRepo.Registrar(TokenStore.AdminId, "Inativacao", "Pessoa", (int)pessoa.Id);
        pessoa = await PessoaRepo.BuscarPorId(Id);
        ambientesPessoa = AmbientePessoaRepo.ListarAmbientesDaPessoa(pessoa!.Id);
        showConfirmInativar = false;
    }

    private async Task HandleConfirmarExcluir()
    {
        if (pessoa == null) return;
        erroExcluir = null;
        try
        {
            // 1. Remove vínculos com ambientes
            foreach (var amb in AmbientePessoaRepo.ListarAmbientesDaPessoa(pessoa.Id))
                AmbientePessoaRepo.RemoverPessoa(amb.Id, pessoa.Id);

            // 2. Libera CodigoUsuario de volta ao pool
            if (!string.IsNullOrEmpty(pessoa.CodigoUsuario))
            {
                try { CodigoRepo.Liberar(pessoa.CodigoUsuario); }
                catch { /* código já liberado ou inexistente */ }
            }

            // 3. Libera a senha de volta ao pool
            try
            {
                foreach (var s in SenhaRepo.ListarTodos().Where(x => x.PessoaId == pessoa.Id))
                {
                    s.EmUso = false;
                    s.PessoaId = null;
                    SenhaRepo.Atualizar(s);
                }
            }
            catch { /* senha não localizada */ }

            // 4. Auditoria + remove pessoa
            LogRepo.Registrar(TokenStore.AdminId, "Remocao", "Pessoa", (int)pessoa.Id);
            await PessoaRepo.Remover(pessoa.Id);
            Nav.NavigateTo("/pessoas");
        }
        catch (Exception ex)
        {
            erroExcluir = ex.Message;
        }
    }

    private async Task HandleConfirmarReset()
    {
        if (pessoa == null) return;
        pessoa.biometriaCadastrada = null;
        pessoa.templateBackup = null;
        await PessoaRepo.Atualizar(pessoa);
        LogRepo.Registrar(TokenStore.AdminId, "ResetBiometria", "Pessoa", (int)pessoa.Id);
        pessoa = await PessoaRepo.BuscarPorId(Id);
        showConfirmReset = false;
    }
}
