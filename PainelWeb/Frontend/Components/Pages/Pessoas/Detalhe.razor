@page "/pessoas/{Id:long}"
@using WebAbil8_Sistema_Verificação_dupla.slnx.Model
@inject IPessoaRepository PessoaRepo
@inject ITentativaAcessoRepository TentativaRepo
@inject IAmbientePessoaRepository AmbientePessoaRepo
@inject IAmbienteRepository AmbienteRepo
@inject IAmbienteT50Repository AmbienteT50Repo
@inject IPessoaT50Repository PessoaT50Repo
@inject IT50PendenciaRepository T50PendenciaRepo
@inject IDispositivoT50Repository DispositivoRepo
@inject ICodigoRepository CodigoRepo
@inject ISenhaRepository SenhaRepo
@inject ISlotAs608OrfaoRepository SlotOrfaoRepo
@inject ILogAdminRepository LogRepo
@inject ITokenStore TokenStore
@inject NavigationManager Nav
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS

<div class="space-y">
    @if (pessoa == null)
    {
        <p class="text-muted">Carregando...</p>
    }
    else
    {
        <div class="flex items-center gap-4">
            <a href="/pessoas" class="btn btn-ghost btn-icon"><Icon Name="arrow-left" Size="20" /></a>
            <div class="flex-1"><h1 class="text-2xl font-bold">@pessoa.Nome</h1><p class="text-muted">@pessoa.Cargo</p></div>
            <span class="badge @(pessoa.Status == "ativo" ? "badge-success" : "badge-muted")">@pessoa.Status</span>
        </div>

        <div class="grid grid-1-2" style="gap: 1.5rem;">

            <div class="card">
                <div class="card-content pt-6" style="text-align: center;">
                    <div class="avatar avatar-lg" style="margin: 0 auto 1rem;">@GetInitials(pessoa.Nome)</div>
                    <h2 class="text-xl font-semibold">@pessoa.Nome</h2><p class="text-muted">@pessoa.Cargo</p>
                    <div style="text-align: left; margin-top: 1.5rem;" class="space-y-xs">
                        <div class="flex items-center gap-3 text-sm">
                            <Icon Name="hash" Size="16" CssClass="text-muted" />
                            <span class="text-muted">ID T50:</span>
                            <span class="font-mono font-semibold">@(pessoa.CodigoUsuario ?? "—")</span>
                        </div>
                        <div class="flex items-center gap-3 text-sm">
                            <Icon Name="file-text" Size="16" CssClass="text-muted" />
                            <span class="text-muted">CPF:</span>
                            <span class="font-mono">@FormatHelper.FormatarCpf(pessoa.Cpf)</span>
                        </div>
                        <div class="flex items-center gap-3 text-sm"><Icon Name="mail" Size="16" CssClass="text-muted" /> @pessoa.Email</div>
                        <div class="flex items-center gap-3 text-sm">
                            <Icon Name="fingerprint" Size="16" CssClass="text-muted" />
                            <span class="badge @(pessoa.biometriaCadastrada != null ? "badge-success" : "badge-warning")">
                                Biometria @(pessoa.biometriaCadastrada != null ? "cadastrada" : "pendente")
                            </span>
                        </div>
                        <div class="flex items-center gap-3 text-sm"><Icon Name="calendar" Size="16" CssClass="text-muted" /><span class="text-muted">Cadastro: @(DateHelper.Local(pessoa.dataCadastro)?.ToString("dd/MM/yyyy") ?? "-")</span></div>
                        <div class="flex items-center gap-3 text-sm"><Icon Name="clock" Size="16" CssClass="text-muted" /><span class="text-muted">Último acesso: @(DateHelper.Local(pessoa.dataUltimoAcesso)?.ToString("dd/MM/yyyy HH:mm") ?? "-")</span></div>
                    </div>
                    <div class="mt-6 pt-6 border-t space-y-xs">
                        <button class="btn btn-primary btn-block" @onclick="AbrirModalAddAmbientes"><Icon Name="plus" Size="16" /> Adicionar a Ambientes</button>
                        <button class="btn btn-outline btn-block" @onclick="() => showEdit = true"><Icon Name="edit" Size="16" /> Editar Perfil</button>
                        <button class="btn btn-outline btn-block" @onclick="HandleReenviarSenha" disabled="@isReenviando">
                            @if (isReenviando) { <span class="spinner"></span><span>Reenviando…</span> }
                            else { <Icon Name="mail" Size="16" /> <span>Reenviar ID + Senha</span> }
                        </button>
                        <button class="btn btn-outline btn-block" @onclick="() => showConfirmReset = true"><Icon Name="refresh" Size="16" /> Resetar Biometria</button>
                        @if (pessoa.Status == "ativo")
                        {
                            <button class="btn btn-outline btn-block text-destructive" @onclick="() => showConfirmInativar = true"><Icon Name="user-x" Size="16" /> Inativar Pessoa</button>
                        }
                        <button class="btn btn-ghost btn-block text-destructive" style="margin-top:0.5rem;" @onclick="() => showConfirmExcluir = true"><Icon Name="trash" Size="16" /> Excluir Permanentemente</button>
                    </div>
                </div>
            </div>

            <div class="space-y">
                <div class="tabs-list">
                    <button class="tab-trigger @(tab == "ambientes" ? "active" : "")" @onclick='() => tab = "ambientes"'>Ambientes com Acesso</button>
                    <button class="tab-trigger @(tab == "historico" ? "active" : "")" @onclick='() => tab = "historico"'>Histórico de Entradas</button>
                </div>

                @if (tab == "ambientes")
                {
                    <div class="card">
                        <div class="card-header"><div class="card-title"><Icon Name="key" Size="20" /> Ambientes com Acesso</div><p class="card-description">@ambientesPessoa.Count ambientes autorizados</p></div>
                        <div class="card-content">
                            <table>
                                <thead><tr><th>Ambiente</th><th>Ação</th></tr></thead>
                                <tbody>
                                    @foreach (var amb in ambientesPessoa)
                                    {
                                        <tr>
                                            <td class="font-medium"><span class="flex items-center gap-2"><Icon Name="map-pin" Size="16" CssClass="text-muted" /> @amb.Nome</span></td>
                                            <td class="text-right"><button class="btn btn-ghost btn-sm text-destructive" @onclick="() => ConfirmarRemoverAcesso(amb.Id)">Remover Acesso</button></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card">
                        <div class="card-header card-header-row"><div><div class="card-title"><Icon Name="history" Size="20" /> Histórico de Entradas</div><p class="card-description">Últimas tentativas de acesso</p></div><a href="/historico?pessoaId=@pessoa.Id" class="btn btn-outline btn-sm">Ver Todos</a></div>
                        <div class="card-content">
                            <table>
                                <thead><tr><th>Data/Hora</th><th>Ambiente</th><th>Status</th></tr></thead>
                                <tbody>
                                    @foreach (var t in historico)
                                    {
                                        <tr>
                                            <td class="font-mono text-sm text-muted">@DateHelper.Local(t.DataHora).ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>@(t.Ambiente?.Nome ?? $"Ambiente {t.AmbienteId}")</td>
                                            <td><span class="badge @(t.AcessoLiberado ? "badge-success" : "badge-destructive")"><Icon Name="@(t.AcessoLiberado ? "check-circle" : "x-circle")" Size="12" /> @(t.AcessoLiberado ? "Permitido" : "Negado")</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@if (showEdit && pessoa != null)
{
    <div class="modal-overlay">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header"><h3>Editar Perfil</h3><p>Atualize as informacoes da pessoa</p></div>
            <div class="modal-body space-y-sm">
                <div class="form-group">
                    <label class="form-label">Nome</label>
                    <input class="form-input" maxlength="100" onkeyup="window.maskTextoSeguro(this, 100)"
                           @bind="editNome" @bind:event="oninput" />
                </div>
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input class="form-input" type="email" maxlength="150"
                           @bind="editEmail" @bind:event="oninput" />
                </div>
                <div class="form-group">
                    <label class="form-label">Cargo</label>
                    <input class="form-input" maxlength="100" onkeyup="window.maskTextoSeguro(this, 100)"
                           @bind="editCargo" @bind:event="oninput" />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="() => showEdit = false" disabled="@isSalvandoEdicao">Cancelar</button>
                <button class="btn btn-primary" @onclick="HandleSalvarEdicao" disabled="@isSalvandoEdicao">
                    @if (isSalvandoEdicao) { <span class="spinner"></span><span>Salvando…</span> } else { <span>Salvar</span> }
                </button>
            </div>
        </div>
    </div>
}

@if (showConfirmInativar && pessoa != null)
{
    <div class="modal-overlay">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Inativar Pessoa</h3>
                <p>Confirme a operação antes de prosseguir</p>
            </div>
            <div class="modal-body">
                <p>Ao inativar <strong>@pessoa.Nome</strong>, a pessoa perderá acesso a todos os <strong>@ambientesPessoa.Count ambiente(s)</strong> cadastrado(s). Para reativar, adicione-a novamente a um ambiente.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="() => showConfirmInativar = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="HandleConfirmarInativar">Confirmar</button>
            </div>
        </div>
    </div>
}

@if (showConfirmRemoverAcesso && pessoa != null)
{
    <div class="modal-overlay">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Remover Acesso ao Ambiente</h3>
                <p>Confirme antes de prosseguir</p>
            </div>
            <div class="modal-body">
                <p>Deseja remover o acesso de <strong>@pessoa.Nome</strong> a este ambiente? Se for o último ambiente vinculado, a pessoa será inativada automaticamente.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="() => showConfirmRemoverAcesso = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="HandleConfirmarRemoverAcesso">Remover</button>
            </div>
        </div>
    </div>
}

@if (showConfirmExcluir && pessoa != null)
{
    <div class="modal-overlay">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Excluir Pessoa Permanentemente</h3>
                <p>Esta ação não pode ser desfeita</p>
            </div>
            <div class="modal-body space-y-sm">
                <div class="alert alert-danger">Todos os dados de <strong>@pessoa.Nome</strong> serão removidos permanentemente, incluindo histórico de acessos e biometria.</div>
                <div class="form-group">
                    <label class="form-label">Digite o nome exato para confirmar: <strong>@pessoa.Nome</strong></label>
                    <input class="form-input" @bind="nomeConfirmacaoExcluir" placeholder="@pessoa.Nome" />
                </div>
                @if (erroExcluir != null) { <div class="alert alert-danger">@erroExcluir</div> }
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="() => { showConfirmExcluir = false; nomeConfirmacaoExcluir = string.Empty; erroExcluir = null; }" disabled="@isExcluindo">Cancelar</button>
                <button class="btn btn-primary text-destructive" @onclick="HandleConfirmarExcluir" disabled="@(nomeConfirmacaoExcluir != pessoa.Nome || isExcluindo)">
                    @if (isExcluindo) { <span class="spinner"></span><span>Excluindo…</span> }
                    else { <span>Excluir Permanentemente</span> }
                </button>
            </div>
        </div>
    </div>
}

@if (showConfirmReset && pessoa != null)
{
    <div class="modal-overlay">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Resetar Biometria</h3>
                <p>Confirme a operação antes de prosseguir</p>
            </div>
            <div class="modal-body">
                <p>O template biométrico de <strong>@pessoa.Nome</strong> será apagado. A pessoa precisará recadastrar a digital no próximo acesso.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="() => showConfirmReset = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="HandleConfirmarReset">Confirmar Reset</button>
            </div>
        </div>
    </div>
}

@if (showAddAmbientes && pessoa != null)
{
    <div class="modal-overlay">
        <div class="modal modal-lg" @onclick:stopPropagation="true" style="max-width:960px; width:92vw;">
            <div class="modal-header">
                <h3>Adicionar @pessoa.Nome a Ambientes</h3>
                <p>Selecione um ou mais ambientes. A pessoa será cadastrada em todos os T50 de cada um.</p>
            </div>
            <div class="modal-body">
                <div class="flex items-center gap-4" style="flex-wrap:wrap;">
                    <div class="input-icon-wrapper flex-1" style="min-width:220px;">
                        <Icon Name="search" />
                        <input class="form-input" placeholder="Buscar ambientes..." @bind="addAmbienteBusca" @bind:event="oninput" />
                    </div>
                    <select class="form-select" style="width:170px;" @bind="addAmbienteSort">
                        <option value="nome_az">Nome A→Z</option>
                        <option value="nome_za">Nome Z→A</option>
                        <option value="digitais_max">Mais digitais</option>
                        <option value="digitais_min">Menos digitais</option>
                    </select>
                    <button class="btn btn-outline btn-sm" @onclick="ToggleSelecionarTodos">
                        @(TodosAmbientesSelecionaveisMarcados ? "Desmarcar todos" : "Selecionar todos")
                    </button>
                </div>

                @if (todosAmbientes.Count == 0)
                {
                    <div class="alert alert-warning" style="margin-top:1rem;">Nenhum ambiente cadastrado.</div>
                }
                else if (!AmbientesFiltradosOrdenados.Any())
                {
                    <p class="text-muted" style="margin-top:1rem;">Nenhum ambiente bate com os filtros.</p>
                }
                else
                {
                    <div class="grid grid-3" style="margin-top:1rem; gap:0.75rem;">
                        @foreach (var amb in AmbientesFiltradosOrdenados)
                        {
                            var jaVinculado = ambientesPessoa.Any(a => a.Id == amb.Id);
                            var selecionado = ambientesSelecionados.Contains(amb.Id);
                            var t50sDoAmb = t50sPorAmbiente.TryGetValue(amb.Id, out var list) ? list : new();
                            var digitaisTexto = t50sDoAmb.Any()
                                ? string.Join(" + ", t50sDoAmb.Select(d => $"{d.DigitaisCadastradas}/1000"))
                                : "sem T50";
                            <button type="button"
                                    style="text-align:left; cursor:@(jaVinculado ? "not-allowed" : "pointer"); background:transparent; border:@(selecionado ? "2px solid var(--primary)" : "1px solid var(--border)"); border-radius:8px; opacity:@(jaVinculado ? "0.55" : "1"); padding:1rem; position:relative; transition:border-color 0.15s;"
                                    disabled="@jaVinculado"
                                    @onclick="() => ToggleAmbienteSelecionado(amb.Id)">
                                <div style="position:absolute; top:0.6rem; right:0.6rem;">
                                    @if (jaVinculado)
                                    {
                                        <span class="badge badge-success" style="font-size:0.7rem;">Já vinculada</span>
                                    }
                                    else if (selecionado)
                                    {
                                        <Icon Name="check-circle" Size="22" CssClass="text-primary" />
                                    }
                                </div>
                                <div class="flex items-center gap-2">
                                    <Icon Name="map-pin" Size="18" CssClass="text-muted" />
                                    <h3 class="font-semibold" style="margin:0;">@amb.Nome</h3>
                                </div>
                                <p class="text-xs text-muted" style="margin-top:0.5rem;">
                                    @t50sDoAmb.Count T50 · @digitaisTexto
                                </p>
                            </button>
                        }
                    </div>
                }

                @if (erroAddAmbientes != null)
                {
                    <div class="alert alert-danger" style="margin-top:1rem;">@erroAddAmbientes</div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="FecharModalAddAmbientes" disabled="@isAddingAmbientes">Cancelar</button>
                <button class="btn btn-primary" @onclick="HandleConfirmarAddAmbientes" disabled="@(isAddingAmbientes || ambientesSelecionados.Count == 0)">
                    @if (isAddingAmbientes) { <span class="spinner"></span><span>Adicionando...</span> }
                    else { <span>Adicionar (@ambientesSelecionados.Count)</span> }
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public long Id { get; set; }
    private string tab = "ambientes";
    private bool showEdit = false;
    private bool showConfirmInativar = false;
    private bool showConfirmReset = false;
    private bool showConfirmRemoverAcesso = false;
    private bool showConfirmExcluir = false;
    private int ambienteIdParaRemover = 0;
    private string nomeConfirmacaoExcluir = "";
    private string? erroExcluir = null;
    private bool isReenviando = false;
    private bool isSalvandoEdicao = false;
    private Pessoa? pessoa = null;
    private List<Ambiente> ambientesPessoa = new();
    private List<TentativaAcesso> historico = new();
    private string editNome = "";
    private string editEmail = "";
    private string editCargo = "";

    private bool showAddAmbientes = false;
    private string addAmbienteBusca = "";
    private string addAmbienteSort = "nome_az";
    private bool isAddingAmbientes = false;
    private string? erroAddAmbientes = null;
    private List<Ambiente> todosAmbientes = new();
    private Dictionary<int, List<DispositivoT50>> t50sPorAmbiente = new();
    private HashSet<int> ambientesSelecionados = new();

    private IEnumerable<Ambiente> AmbientesFiltradosOrdenados
    {
        get
        {
            var q = todosAmbientes.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(addAmbienteBusca))
                q = q.Where(a => a.Nome.Contains(addAmbienteBusca, StringComparison.OrdinalIgnoreCase));
            return addAmbienteSort switch
            {
                "nome_za" => q.OrderByDescending(a => a.Nome),
                "digitais_max" => q.OrderByDescending(a => t50sPorAmbiente.TryGetValue(a.Id, out var l) ? l.Sum(d => d.DigitaisCadastradas) : 0),
                "digitais_min" => q.OrderBy(a => t50sPorAmbiente.TryGetValue(a.Id, out var l) ? l.Sum(d => d.DigitaisCadastradas) : 0),
                _ => q.OrderBy(a => a.Nome),
            };
        }
    }

    private bool TodosAmbientesSelecionaveisMarcados
    {
        get
        {
            var idsVinculados = ambientesPessoa.Select(a => a.Id).ToHashSet();
            var selecionaveis = AmbientesFiltradosOrdenados.Where(a => !idsVinculados.Contains(a.Id)).Select(a => a.Id).ToList();
            return selecionaveis.Any() && selecionaveis.All(id => ambientesSelecionados.Contains(id));
        }
    }

    private void AbrirModalAddAmbientes()
    {
        todosAmbientes = AmbienteRepo.ListarTodos();
        t50sPorAmbiente = todosAmbientes.ToDictionary(
            a => a.Id,
            a => AmbienteT50Repo.ListarT50sDoAmbiente(a.Id));
        ambientesSelecionados = new HashSet<int>();
        addAmbienteBusca = "";
        addAmbienteSort = "nome_az";
        erroAddAmbientes = null;
        showAddAmbientes = true;
    }

    private void FecharModalAddAmbientes()
    {
        showAddAmbientes = false;
        ambientesSelecionados = new HashSet<int>();
        addAmbienteBusca = "";
        erroAddAmbientes = null;
    }

    private void ToggleAmbienteSelecionado(int ambienteId)
    {
        if (ambientesSelecionados.Contains(ambienteId)) ambientesSelecionados.Remove(ambienteId);
        else ambientesSelecionados.Add(ambienteId);
        erroAddAmbientes = null;
    }

    private void ToggleSelecionarTodos()
    {
        var idsVinculados = ambientesPessoa.Select(a => a.Id).ToHashSet();
        var selecionaveis = AmbientesFiltradosOrdenados.Where(a => !idsVinculados.Contains(a.Id)).Select(a => a.Id).ToList();
        if (selecionaveis.All(id => ambientesSelecionados.Contains(id)))
        {
            foreach (var id in selecionaveis) ambientesSelecionados.Remove(id);
        }
        else
        {
            foreach (var id in selecionaveis) ambientesSelecionados.Add(id);
        }
    }

    private async Task HandleConfirmarAddAmbientes()
    {
        if (pessoa == null || ambientesSelecionados.Count == 0) return;

        isAddingAmbientes = true;
        erroAddAmbientes = null;
        StateHasChanged();
        await Task.Yield();
        try
        {

            if (pessoa.modoAcesso == "digital_e_senha")
            {
                foreach (var ambId in ambientesSelecionados)
                {
                    if (!t50sPorAmbiente.TryGetValue(ambId, out var t50s)) continue;
                    foreach (var t50 in t50s)
                    {
                        if (PessoaT50Repo.EstaCadastrada(pessoa.Id, t50.Id)) continue;
                        if (t50.DigitaisCadastradas >= 1000)
                        {
                            var amb = todosAmbientes.First(a => a.Id == ambId);
                            erroAddAmbientes = $"T50 '{t50.Nome}' do ambiente '{amb.Nome}' está cheio (1000/1000). Remova templates inativos primeiro.";
                            return;
                        }
                    }
                }
            }

            foreach (var ambId in ambientesSelecionados.ToList())
            {
                if (AmbientePessoaRepo.PessoaTemAcesso(ambId, pessoa.Id)) continue;

                AmbientePessoaRepo.AdicionarPessoa(new AmbientePessoa { AmbienteId = ambId, PessoaId = pessoa.Id });
                LogRepo.Registrar(TokenStore.AdminId, "Adicionar", "Pessoa", (int)pessoa.Id);

                if (pessoa.modoAcesso == "digital_e_senha"
                    && t50sPorAmbiente.TryGetValue(ambId, out var t50s))
                {
                    foreach (var t50 in t50s)
                    {
                        if (!PessoaT50Repo.EstaCadastrada(pessoa.Id, t50.Id))
                        {
                            PessoaT50Repo.Adicionar(pessoa.Id, t50.Id);
                            T50PendenciaRepo.Enfileirar("adicionar", pessoa.Id, t50.Id);
                        }
                    }

                    if (pessoa.templateBackup != null
                        && pessoa.templateBackup.Length > 0
                        && pessoa.biometriaCadastrada == null)
                    {
                        await PessoaRepo.MarcarBiometriaCadastrada(pessoa.Id);
                        LogRepo.Registrar(TokenStore.AdminId, "RestauracaoBiometria", "Pessoa", (int)pessoa.Id);
                    }
                }
            }

            if (pessoa.Status != "ativo")
            {
                await PessoaRepo.AlterarStatus(pessoa.Id, true);
            }

            pessoa = await PessoaRepo.BuscarPorId(Id);
            ambientesPessoa = AmbientePessoaRepo.ListarAmbientesDaPessoa(Id);
            showAddAmbientes = false;
            ambientesSelecionados = new HashSet<int>();
            addAmbienteBusca = "";
        }
        catch (Exception ex)
        {
            erroAddAmbientes = ex.Message;
        }
        finally { isAddingAmbientes = false; }
    }

    protected override async Task OnInitializedAsync()
    {
        pessoa = await PessoaRepo.BuscarPorId(Id);
        if (pessoa != null)
        {
            editNome = pessoa.Nome;
            editEmail = pessoa.Email;
            editCargo = pessoa.Cargo;

            ambientesPessoa = AmbientePessoaRepo.ListarAmbientesDaPessoa(pessoa.Id);

            historico = TentativaRepo.ListarPorPessoa(pessoa.Id)
                .OrderByDescending(t => t.DataHora)
                .Take(10)
                .ToList();
        }
    }

    private string GetInitials(string nome) => string.Join("", nome.Split(' ').Take(2).Select(n => n[0])).ToUpper();

    private async Task HandleReenviarSenha()
    {
        if (pessoa == null || isReenviando) return;
        isReenviando = true;
        try
        {
            var client = HttpClientFactory.CreateClient("BancoAPI");
            client.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", TokenStore.Token);
            var resp = await client.PostAsync($"api/person/{pessoa.Id}/reenviar-credenciais", null);
            if (resp.IsSuccessStatusCode)
                await JS.InvokeVoidAsync("alert", "Credenciais (ID + senha) reenviadas. Verifique o email do usuário (ou o console do servidor caso SMTP esteja indisponível).");
            else
                await JS.InvokeVoidAsync("alert", $"Falha ao reenviar (HTTP {(int)resp.StatusCode}).");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Erro: {ex.Message}");
        }
        finally
        {
            isReenviando = false;
        }
    }

    private async Task HandleSalvarEdicao()
    {
        if (pessoa == null) return;
        if (string.IsNullOrWhiteSpace(editNome) || string.IsNullOrWhiteSpace(editEmail) || string.IsNullOrWhiteSpace(editCargo))
            return;
        if (!FormatHelper.EmailValido(editEmail))
            return;
        if (editNome.Length > 100 || editCargo.Length > 100)
            return;

        isSalvandoEdicao = true;
        StateHasChanged();
        await Task.Yield();
        try
        {
            pessoa.Nome = editNome;
            pessoa.Email = editEmail;
            pessoa.Cargo = editCargo;
            await PessoaRepo.Atualizar(pessoa);
            LogRepo.Registrar(TokenStore.AdminId, "Atualizar", "Pessoa", (int)pessoa.Id);
            showEdit = false;
        }
        finally { isSalvandoEdicao = false; }
    }

    private async Task HandleRemoverAcesso(int ambienteId)
    {
        if (pessoa == null) return;

        var t50sDoAmbRemovido = AmbienteT50Repo.ListarT50sDoAmbiente(ambienteId).Select(t => t.Id).ToList();
        var outrosAmbientes = ambientesPessoa.Where(a => a.Id != ambienteId).Select(a => a.Id).ToList();
        var t50sEmOutrosAmbientes = outrosAmbientes
            .SelectMany(aid => AmbienteT50Repo.ListarT50sDoAmbiente(aid).Select(t => t.Id))
            .ToHashSet();

        AmbientePessoaRepo.RemoverPessoa(ambienteId, pessoa.Id);
        LogRepo.Registrar(TokenStore.AdminId, "Remocao", "Pessoa", (int)pessoa.Id);

        foreach (var t50Id in t50sDoAmbRemovido)
        {
            if (!t50sEmOutrosAmbientes.Contains(t50Id) && PessoaT50Repo.EstaCadastrada(pessoa.Id, t50Id))
            {
                PessoaT50Repo.Remover(pessoa.Id, t50Id);
                T50PendenciaRepo.Enfileirar("remover", pessoa.Id, t50Id);
            }
        }

        ambientesPessoa = AmbientePessoaRepo.ListarAmbientesDaPessoa(pessoa.Id);

        if (ambientesPessoa.Count == 0 && pessoa.Status == "ativo")
        {
            await PessoaRepo.AlterarStatus(pessoa.Id, false);
            try { await PessoaRepo.EnfileirarSlotParaApagar(pessoa.Id); } catch {  }
            pessoa.Status = "inativo";
        }
    }

    private void ConfirmarRemoverAcesso(int ambienteId)
    {
        ambienteIdParaRemover = ambienteId;
        showConfirmRemoverAcesso = true;
    }

    private async Task HandleConfirmarRemoverAcesso()
    {
        await HandleRemoverAcesso(ambienteIdParaRemover);
        showConfirmRemoverAcesso = false;
        ambienteIdParaRemover = 0;
    }

    private async Task HandleConfirmarInativar()
    {
        if (pessoa == null) return;

        var ambientesSnap = ambientesPessoa.ToList();
        var t50sUnicos = ambientesSnap
            .SelectMany(a => AmbienteT50Repo.ListarT50sDoAmbiente(a.Id))
            .Select(t => t.Id)
            .Distinct()
            .ToList();

        foreach (var amb in ambientesSnap)
            AmbientePessoaRepo.RemoverPessoa(amb.Id, pessoa.Id);

        foreach (var t50Id in t50sUnicos)
        {
            if (PessoaT50Repo.EstaCadastrada(pessoa.Id, t50Id))
            {
                PessoaT50Repo.Remover(pessoa.Id, t50Id);
                T50PendenciaRepo.Enfileirar("remover", pessoa.Id, t50Id);
            }
        }

        await PessoaRepo.AlterarStatus(pessoa.Id, false);
        try { await PessoaRepo.EnfileirarSlotParaApagar(pessoa.Id); } catch {  }

        LogRepo.Registrar(TokenStore.AdminId, "Inativacao", "Pessoa", (int)pessoa.Id);
        pessoa = await PessoaRepo.BuscarPorId(Id);
        ambientesPessoa = AmbientePessoaRepo.ListarAmbientesDaPessoa(pessoa!.Id);
        showConfirmInativar = false;
    }

    private bool isExcluindo;

    private async Task HandleConfirmarExcluir()
    {
        if (pessoa == null || isExcluindo) return;
        erroExcluir = null;
        isExcluindo = true;

        StateHasChanged();
        await Task.Yield();
        try
        {

            var ambientesPessoa = AmbientePessoaRepo.ListarAmbientesDaPessoa(pessoa.Id);

            var t50sUnicos = ambientesPessoa
                .SelectMany(a => AmbienteT50Repo.ListarT50sDoAmbiente(a.Id))
                .Select(t => t.Id)
                .Distinct()
                .ToList();

            foreach (var amb in ambientesPessoa)
                AmbientePessoaRepo.RemoverPessoa(amb.Id, pessoa.Id);

            foreach (var t50Id in t50sUnicos)
            {
                if (PessoaT50Repo.EstaCadastrada(pessoa.Id, t50Id))
                {
                    PessoaT50Repo.Remover(pessoa.Id, t50Id);
                    T50PendenciaRepo.Enfileirar("remover", pessoa.Id, t50Id);
                }
            }

            if (!string.IsNullOrEmpty(pessoa.CodigoUsuario))
            {
                try { CodigoRepo.Liberar(pessoa.CodigoUsuario); }
                catch {  }
            }

            try
            {
                foreach (var s in SenhaRepo.ListarTodos().Where(x => x.PessoaId == pessoa.Id))
                {
                    s.EmUso = false;
                    s.PessoaId = null;
                    SenhaRepo.Atualizar(s);
                }
            }
            catch {  }

            if (pessoa.SlotAs608 != null)
            {
                try { await SlotOrfaoRepo.Adicionar(pessoa.SlotAs608.Value); }
                catch {  }
            }

            LogRepo.Registrar(TokenStore.AdminId, "Remocao", "Pessoa", (int)pessoa.Id);
            await PessoaRepo.Remover(pessoa.Id);
            Nav.NavigateTo("/pessoas");
        }
        catch (Exception ex)
        {
            erroExcluir = ex.Message;
        }
        finally
        {
            isExcluindo = false;
        }
    }

    private async Task HandleConfirmarReset()
    {
        if (pessoa == null) return;
        pessoa.biometriaCadastrada = null;
        pessoa.templateBackup = null;
        await PessoaRepo.Atualizar(pessoa);

        try { await PessoaRepo.EnfileirarSlotParaApagar(pessoa.Id); } catch {  }

        LogRepo.Registrar(TokenStore.AdminId, "ResetBiometria", "Pessoa", (int)pessoa.Id);
        pessoa = await PessoaRepo.BuscarPorId(Id);
        showConfirmReset = false;
    }
