@page "/pessoas"
@using WebAbil8_Sistema_Verificação_dupla.slnx.Model
@inject IPessoaRepository PessoaRepo
@inject ISenhaRepository SenhaRepo
@inject ICodigoRepository CodigoRepo
@inject ILogAdminRepository LogRepo
@inject ITokenStore TokenStore
@inject IJSRuntime JS
@inject IConfiguration Config

<div class="space-y">
    <div class="flex items-center justify-between" style="flex-wrap: wrap; gap: 1rem;">
        <div><h1 class="text-2xl font-bold">Pessoas</h1><p class="text-muted">Gerencie pessoas e permissoes de acesso</p></div>
        <div class="flex gap-2">
            <button class="btn btn-outline" @onclick="ExportarCsv"><Icon Name="download" Size="16" /> CSV</button>
            <button class="btn btn-outline" @onclick="ExportarPdf"><Icon Name="file-text" Size="16" /> PDF</button>
            <button class="btn btn-primary" @onclick="() => showDialog = true"><Icon Name="plus" Size="16" /> Nova Pessoa</button>
        </div>
    </div>

    <div class="flex gap-4" style="flex-wrap: wrap;">
        <div class="input-icon-wrapper flex-1" style="min-width: 200px;">
            <Icon Name="search" /><input class="form-input" placeholder="Buscar por nome, email ou cargo..." @bind="search" @bind:event="oninput" />
        </div>
        <select class="form-select" style="width: 150px;" @bind="statusFilter"><option value="todos">Todos</option><option value="ativo">Ativos</option><option value="inativo">Inativos</option></select>
        <select class="form-select" style="width: 180px;" @bind="modoFilter">
            <option value="todos">Modo (todos)</option>
            <option value="digital_e_senha">Digital + Senha</option>
            <option value="somente_senha">Somente Senha</option>
        </select>
        <select class="form-select" style="width: 180px;" @bind="biometriaFilter">
            <option value="todos">Biometria (todos)</option>
            <option value="sim">Cadastrada</option>
            <option value="nao">Pendente</option>
        </select>
        <select class="form-select" style="width: 200px;" @bind="sortOpcao">
            <option value="nome_az">Nome A→Z</option>
            <option value="nome_za">Nome Z→A</option>
            <option value="status_ativo">Status (Ativo primeiro)</option>
            <option value="status_inativo">Status (Inativo primeiro)</option>
            <option value="cargo_az">Cargo A→Z</option>
            <option value="biometria">Biometria (cadastrada primeiro)</option>
            <option value="cadastro_rec">Cadastro (mais recente)</option>
        </select>
    </div>

    <div class="grid grid-3">
        @foreach (var p in Sorted)
        {
            <div class="card">
                <div class="card-content pt-6">
                    <div class="flex items-start gap-4">
                        <div class="avatar avatar-md">@GetInitials(p.Nome)</div>
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2"><h3 class="font-semibold truncate">@p.Nome</h3><span class="badge @(p.Status == "ativo" ? "badge-success" : "badge-muted")">@p.Status</span></div>
                            <p class="text-sm text-muted">@p.Cargo</p>
                        </div>
                    </div>
                    <div class="mt-4 space-y-xs">
                        <div class="flex items-center gap-2 text-sm text-muted"><Icon Name="mail" Size="16" /><span class="truncate">@p.Email</span></div>
                        <div class="flex items-center gap-2 text-sm">
                            <Icon Name="fingerprint" Size="16" CssClass="text-muted" />
                            <span class="badge @(p.biometriaCadastrada != null ? "badge-success" : "badge-warning")">
                                Biometria @(p.biometriaCadastrada != null ? "cadastrada" : "pendente")
                            </span>
                        </div>
                    </div>
                    <div class="mt-4 pt-4 border-t flex items-center justify-between">
                        <span class="text-sm text-muted">@p.modoAcesso</span>
                        <a href="/pessoas/@p.Id" class="btn btn-ghost btn-sm">Ver Perfil <Icon Name="chevron-right" Size="16" /></a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Sorted.Any())
    {
        <div class="card"><div class="card-content pt-6" style="text-align: center; padding: 3rem;"><Icon Name="user" Size="48" CssClass="text-muted" /><p class="font-medium mt-4">Nenhuma pessoa encontrada</p><p class="text-muted">Tente ajustar os filtros</p></div></div>
    }
</div>

@if (showDialog)
{
    <div class="modal-overlay">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header"><h3>Cadastrar Nova Pessoa</h3><p>Adicione uma nova pessoa ao sistema de controle de acesso</p></div>
            <div class="modal-body space-y-sm">
                @if (isCadastrando)
                {
                    <div class="loading-overlay">
                        <div class="spinner spinner-lg"></div>
                        <div class="loading-text">Cadastrando pessoa, gerando senha e ID…</div>
                    </div>
                }
                @if (senhaMostrada != null)
                {
                    <div class="alert alert-success">
                        <div style="margin-bottom: 0.75rem;">
                            <strong>Pessoa cadastrada!</strong> Anote as informações abaixo:
                        </div>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 0.75rem;">
                            <div>
                                <div class="text-muted text-sm">ID do usuário (T50):</div>
                                <div style="font-size: 1.4rem; font-weight: bold; letter-spacing: 0.2rem;">@pessoaCadastradaCodigo</div>
                            </div>
                            <div>
                                <div class="text-muted text-sm">Senha de acesso:</div>
                                <div style="font-size: 1.4rem; font-weight: bold; letter-spacing: 0.2rem;">@senhaMostrada</div>
                            </div>
                        </div>
                        <div style="padding-top: 0.5rem; border-top: 1px solid rgba(0,0,0,0.1); font-size: 0.85rem;">
                            @(pessoaCadastradaModo == "digital_e_senha" ? "O usuário deverá cadastrar a digital no primeiro acesso." : "O usuário poderá acessar utilizando ID e senha.")
                        </div>
                    </div>
                }
                else if (erroDialog != null)
                {
                    <div class="alert alert-danger">@erroDialog</div>
                }
                else
                {
                    <div class="grid grid-2">
                        <div class="form-group">
                            <label class="form-label">Nome Completo <span class="text-destructive">*</span></label>
                            <input class="form-input @(errNome != null ? "form-input-error" : "")" placeholder="Nome completo" maxlength="100"
                                   onkeyup="window.maskTextoSeguro(this, 100)"
                                   @bind="novoNome" @bind:event="oninput"
                                   @onblur="ValidarNome" />
                            @if (errNome != null) { <p class="text-xs text-destructive">@errNome</p> }
                        </div>
                        <div class="form-group">
                            <label class="form-label">Email <span class="text-destructive">*</span></label>
                            <input class="form-input @(errEmail != null ? "form-input-error" : "")" type="email" placeholder="email@empresa.com" maxlength="150"
                                   @bind="novoEmail" @bind:event="oninput"
                                   @onblur="ValidarEmail" />
                            @if (errEmail != null) { <p class="text-xs text-destructive">@errEmail</p> }
                        </div>
                    </div>
                    <div class="grid grid-2">
                        <div class="form-group">
                            <label class="form-label">CPF <span class="text-destructive">*</span></label>
                            <input class="form-input @(errCpf != null ? "form-input-error" : "")" placeholder="000.000.000-00" maxlength="14"
                                   inputmode="numeric"
                                   onkeyup="window.maskCpf(this)"
                                   @bind="novoCpf" @bind:event="oninput"
                                   @onblur="ValidarCpf" />
                            @if (errCpf != null) { <p class="text-xs text-destructive">@errCpf</p> }
                            else { <p class="text-xs text-muted">Formato: 000.000.000-00</p> }
                        </div>
                        <div class="form-group">
                            <label class="form-label">Cargo <span class="text-destructive">*</span></label>
                            <input class="form-input @(errCargo != null ? "form-input-error" : "")" placeholder="Cargo" maxlength="100"
                                   onkeyup="window.maskTextoSeguro(this, 100)"
                                   @bind="novoCargo" @bind:event="oninput"
                                   @onblur="ValidarCargo" />
                            @if (errCargo != null) { <p class="text-xs text-destructive">@errCargo</p> }
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Modo de Acesso</label>
                        <select class="form-select" @bind="novoModoAcesso">
                            <option value="digital_e_senha">Digital e Senha (ID + Biometria)</option>
                            <option value="somente_senha">Somente Senha (ID + Senha)</option>
                        </select>
                        <p class="text-sm text-muted">Define como esta pessoa poderá se autenticar no dispositivo T50</p>
                    </div>
                }
            </div>
            <div class="modal-footer">
                @if (senhaMostrada != null || erroDialog != null)
                {
                    <button class="btn btn-primary" @onclick="FecharDialog">Fechar</button>
                }
                else
                {
                    <button class="btn btn-outline" @onclick="FecharDialog" disabled="@isCadastrando">Cancelar</button>
                    <button class="btn btn-primary" @onclick="HandleCadastrar" disabled="@isCadastrando">
                        @if (isCadastrando)
                        {
                            <span class="spinner"></span>
                            <span>Cadastrando…</span>
                        }
                        else
                        {
                            <span>Cadastrar</span>
                        }
                    </button>
                }
            </div>
        </div>
    </div>
}

@code {
    private string search = "";
    private string statusFilter = "todos";
    private string modoFilter = "todos";
    private string biometriaFilter = "todos";
    private string sortOpcao = "nome_az";
    private bool showDialog = false;
    private string novoNome = "";
    private string novoEmail = "";
    private string novoCpf = "";
    private string novoCargo = "";
    private string novoModoAcesso = "digital_e_senha";
    private List<Pessoa> todasPessoas = new();
    private string? senhaMostrada = null;
    private long pessoaCadastradaId = 0;
    private string pessoaCadastradaCodigo = "";
    private string pessoaCadastradaModo = "";
    private string? erroDialog = null;
    private bool isCadastrando = false;

    private string? errNome = null;
    private string? errEmail = null;
    private string? errCpf = null;
    private string? errCargo = null;

    private void ValidarNome()
    {
        var n = (novoNome ?? "").Trim();
        if (string.IsNullOrEmpty(n)) errNome = "Nome é obrigatório.";
        else if (n.Length < 3) errNome = "Nome muito curto.";
        else if (n.Length > 100) errNome = "Nome excede 100 caracteres.";
        else errNome = null;
    }

    private void ValidarCargo()
    {
        var c = (novoCargo ?? "").Trim();
        if (string.IsNullOrEmpty(c)) errCargo = "Cargo é obrigatório.";
        else if (c.Length > 100) errCargo = "Cargo excede 100 caracteres.";
        else errCargo = null;
    }

    private void ValidarEmail()
    {
        var e = (novoEmail ?? "").Trim();
        if (string.IsNullOrEmpty(e)) { errEmail = "Email é obrigatório."; return; }
        if (!FormatHelper.EmailValido(e)) { errEmail = "Email inválido."; return; }

        if (todasPessoas.Any(p => string.Equals(p.Email, e, StringComparison.OrdinalIgnoreCase)))
        {
            errEmail = "Já existe uma pessoa cadastrada com este email.";
            return;
        }
        errEmail = null;
    }

    private void ValidarCpf()
    {
        var c = (novoCpf ?? "").Trim();
        if (string.IsNullOrEmpty(c)) { errCpf = "CPF é obrigatório."; return; }
        if (!FormatHelper.CpfValido(c)) { errCpf = "CPF inválido — verifique os dígitos."; return; }
        var digitos = FormatHelper.SoDigitos(c);
        if (todasPessoas.Any(p => FormatHelper.SoDigitos(p.Cpf) == digitos))
        {
            errCpf = "Já existe uma pessoa cadastrada com este CPF.";
            return;
        }
        errCpf = null;
    }

    protected override async Task OnInitializedAsync()
    {
        todasPessoas = await PessoaRepo.ListarTodos();
    }

    private string GetInitials(string nome) => string.Join("", nome.Split(' ').Take(2).Select(n => n[0])).ToUpper();

    private IEnumerable<Pessoa> Filtered => todasPessoas.Where(p =>
        (string.IsNullOrEmpty(search) ||
         p.Nome.Contains(search, StringComparison.OrdinalIgnoreCase) ||
         p.Email.Contains(search, StringComparison.OrdinalIgnoreCase) ||
         p.Cargo.Contains(search, StringComparison.OrdinalIgnoreCase)) &&
        (statusFilter == "todos" || p.Status == statusFilter) &&
        (modoFilter == "todos" || p.modoAcesso == modoFilter) &&
        (biometriaFilter == "todos"
            || (biometriaFilter == "sim" && p.biometriaCadastrada != null)
            || (biometriaFilter == "nao" && p.biometriaCadastrada == null)));

    private IEnumerable<Pessoa> Sorted => sortOpcao switch
    {
        "nome_za" => Filtered.OrderByDescending(p => p.Nome),
        "status_ativo" => Filtered.OrderByDescending(p => p.Status == "ativo"),
        "status_inativo" => Filtered.OrderByDescending(p => p.Status == "inativo"),
        "cargo_az" => Filtered.OrderBy(p => p.Cargo),
        "biometria" => Filtered.OrderByDescending(p => p.biometriaCadastrada.HasValue),
        "cadastro_rec" => Filtered.OrderByDescending(p => p.dataCadastro),
        _ => Filtered.OrderBy(p => p.Nome),
    };

    private void FecharDialog()
    {
        showDialog = false;
        senhaMostrada = null;
        pessoaCadastradaId = 0;
        pessoaCadastradaCodigo = "";
        pessoaCadastradaModo = "";
        erroDialog = null;
        novoNome = novoEmail = novoCpf = novoCargo = "";
        novoModoAcesso = "digital_e_senha";
        errNome = errEmail = errCpf = errCargo = null;
    }

    private async Task HandleCadastrar()
    {
        if (string.IsNullOrWhiteSpace(novoNome) || string.IsNullOrWhiteSpace(novoEmail) ||
            string.IsNullOrWhiteSpace(novoCpf) || string.IsNullOrWhiteSpace(novoCargo)) return;

        ValidarNome();
        ValidarEmail();
        ValidarCpf();
        ValidarCargo();
        if (errNome != null || errEmail != null || errCpf != null || errCargo != null)
        {
            erroDialog = null;
            return;
        }

        isCadastrando = true;
        erroDialog = null;

        StateHasChanged();
        await Task.Yield();

        if (!FormatHelper.CpfValido(novoCpf))
        {
            erroDialog = "CPF inválido — verifique os dígitos.";
            isCadastrando = false;
            return;
        }
        novoCpf = FormatHelper.SoDigitos(novoCpf);

        if (!FormatHelper.EmailValido(novoEmail))
        {
            erroDialog = "Email inválido.";
            isCadastrando = false;
            return;
        }

        if (novoNome.Length > 100 || novoCargo.Length > 100)
        {
            erroDialog = "Algum campo excedeu o tamanho máximo permitido.";
            isCadastrando = false;
            return;
        }

        try
        {

            var codigoDisp = CodigoRepo.BuscarDisponivel();
            if (codigoDisp == null)
            {
                erroDialog = "Não há códigos de usuário disponíveis no sistema (pool esgotado).";
                return;
            }

            var senhaDisp = SenhaRepo.BuscarDisponivel();
            if (senhaDisp == null)
            {
                erroDialog = "Não há senhas disponíveis no sistema. Cadastre senhas antes de adicionar pessoas.";
                return;
            }

            int tentSenha = 0;
            while (senhaDisp.Senha == codigoDisp.Codigo && tentSenha < 5)
            {
                var nova = SenhaRepo.BuscarDisponivel();
                if (nova == null) break;
                senhaDisp = nova;
                tentSenha++;
            }

            var pessoa = new Pessoa
            {
                Nome = novoNome,
                Email = novoEmail,
                Cpf = novoCpf,
                Cargo = novoCargo,
                CodigoUsuario = codigoDisp.Codigo,
                senhaClear = senhaDisp.Senha,
                senhaHash = BCrypt.Net.BCrypt.HashPassword(senhaDisp.Senha, workFactor: 10),
                modoAcesso = novoModoAcesso,
                Status = "inativo",
                dataCadastro = DateTime.UtcNow
            };

            var pessoaSalva = await PessoaRepo.Adicionar(pessoa);

            CodigoRepo.MarcarEmUso(codigoDisp.Codigo, true, pessoaSalva.Id);
            senhaDisp.EmUso = true;
            senhaDisp.PessoaId = pessoaSalva.Id;
            SenhaRepo.Atualizar(senhaDisp);

            LogRepo.Registrar(TokenStore.AdminId, "Adicionar", "Pessoa", (int)pessoaSalva.Id);

            todasPessoas = await PessoaRepo.ListarTodos();
            pessoaCadastradaCodigo = codigoDisp.Codigo;
            pessoaCadastradaId = pessoaSalva.Id;
            pessoaCadastradaModo = novoModoAcesso;
            senhaMostrada = senhaDisp.Senha;
        }
        catch (Exception ex)
        {
            erroDialog = ex.Message;
        }
        finally
        {
            isCadastrando = false;
        }
    }

    private async Task ExportarPdf()
    {
        var apiUrl = Config["BancoApiUrl"] ?? "http://localhost:5018/";
        var qs = MontarQueryFiltros();
        await JS.InvokeVoidAsync("baixarPdf",
            apiUrl + "api/export/pessoas.pdf" + qs,
            TokenStore.Token,
            $"pessoas{SufixoFiltros()}.pdf");
    }

    private async Task ExportarCsv()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Nome Completo,CPF,Cargo");
        foreach (var p in Sorted)
        {
            sb.AppendLine($"\"{p.Nome}\",\"{FormatarCpf(p.Cpf)}\",\"{p.Cargo}\"");
        }
        await JS.InvokeVoidAsync("downloadCsv",
            $"pessoas_{DateTime.Now:yyyyMMdd_HHmm}{SufixoFiltros()}.csv",
            sb.ToString());
    }

    private string MontarQueryFiltros()
    {
        var q = new List<string>();
        if (!string.IsNullOrEmpty(search))    q.Add($"search={Uri.EscapeDataString(search)}");
        if (statusFilter != "todos")          q.Add($"status={statusFilter}");
        if (modoFilter != "todos")            q.Add($"modo={modoFilter}");
        if (biometriaFilter != "todos")       q.Add($"biometria={biometriaFilter}");
        return q.Count > 0 ? "?" + string.Join("&", q) : "";
    }

    private string SufixoFiltros()
    {
        var s = new List<string>();
        if (statusFilter != "todos")          s.Add(statusFilter);
        if (modoFilter != "todos")            s.Add(Slug(modoFilter));
        if (biometriaFilter != "todos")       s.Add($"bio-{biometriaFilter}");
        if (!string.IsNullOrEmpty(search))    s.Add($"busca-{Slug(search)}");
        return s.Count > 0 ? "_" + string.Join("_", s) : "";
    }

    private static string Slug(string s) =>
        new string((s ?? "").Where(c => char.IsLetterOrDigit(c) || c == '-').ToArray()).ToLower();

    private static string FormatarCpf(string? cpf)
    {
        if (string.IsNullOrWhiteSpace(cpf)) return "";
        var d = new string(cpf.Where(char.IsDigit).ToArray());
        if (d.Length != 11) return cpf;
        return $"{d.Substring(0,3)}.{d.Substring(3,3)}.{d.Substring(6,3)}-{d.Substring(9,2)}";
    }
}
