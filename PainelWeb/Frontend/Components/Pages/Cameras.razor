@* =============================================================================
   Cameras.razor - Gerenciamento de câmeras de vigilância
   Features: Grid de câmeras com preview, filtros (busca, status, ambiente),
             modal de visualização ao vivo (RTSP), modal de cadastro de câmera,
             indicador de gravação (REC), estado online/offline
   Rota: /cameras
   ============================================================================= *@
@page "/cameras"
@using WebAbil8_Sistema_Verificação_dupla.slnx.Model
@inject ICameraRepository CameraRepo
@inject IAmbienteRepository AmbienteRepo
@inject ILogAdminRepository LogRepo
@inject ITokenStore TokenStore
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IAsyncDisposable

<div class="space-y">
    <div class="flex items-center justify-between" style="flex-wrap: wrap; gap: 1rem;">
        <div><h1 class="text-2xl font-bold">Câmeras</h1><p class="text-muted">Gerencie câmeras e visualize feeds ao vivo via RTSP</p></div>
        <button class="btn btn-primary" @onclick="() => showCreate = true"><Icon Name="plus" Size="16" /> Nova Câmera</button>
    </div>

    <div class="flex gap-4" style="flex-wrap: wrap;">
        <div class="input-icon-wrapper flex-1" style="min-width: 200px;"><Icon Name="search" /><input class="form-input" placeholder="Buscar por nome ou RTSP..." @bind="search" @bind:event="oninput" /></div>
        <select class="form-select" style="width: 150px;" @bind="ativaFilter">
            <option value="todos">Todos</option>
            <option value="ativa">Ativas</option>
            <option value="inativa">Inativas</option>
        </select>
        <select class="form-select" style="width: 180px;" @bind="ambienteFilter">
            <option value="0">Todos os Ambientes</option>
            @foreach (var a in ambientes)
            {
                <option value="@a.Id">@a.Nome</option>
            }
        </select>
    </div>

    <div class="grid grid-3">
        @foreach (var cam in Filtered)
        {
            <div class="card" style="overflow: hidden;">
                <div class="camera-preview" style="position:relative; aspect-ratio:16/9; background:#000;">
                    @if (cam.Ativa && !string.IsNullOrEmpty(cam.UrlHLS))
                    {
                        @* Player HLS pequeno autoplay mute como preview no card.
                           IDs únicos por câmera para que vários cards possam tocar em paralelo. *@
                        <video id="@($"camPreview_{cam.Id}")"
                               style="width:100%; height:100%; object-fit:cover; display:block;"
                               muted autoplay playsinline></video>
                        <button class="btn btn-icon" style="position: absolute; bottom: 0.75rem; right: 0.75rem; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px);" @onclick="() => OpenLiveView(cam)" title="Ampliar"><Icon Name="maximize" Size="16" CssClass="text-foreground" /></button>
                    }
                    else if (cam.Ativa)
                    {
                        <div class="flex-col items-center gap-2" style="display: flex; justify-content:center; align-items:center; height:100%; flex-direction:column;">
                            <Icon Name="camera" Size="64" CssClass="text-muted" />
                            <span class="text-sm text-muted">URL HLS não configurada</span>
                        </div>
                        <button class="btn btn-icon" style="position: absolute; bottom: 0.75rem; right: 0.75rem; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px);" @onclick="() => OpenLiveView(cam)"><Icon Name="maximize" Size="16" CssClass="text-foreground" /></button>
                    }
                    else
                    {
                        <div class="flex-col items-center gap-2" style="display: flex; justify-content:center; align-items:center; height:100%; flex-direction:column;"><Icon Name="wifi-off" Size="48" CssClass="text-muted" /><span class="text-sm text-muted">Inativa</span></div>
                    }
                </div>
                <div class="card-content" style="padding-top: 1rem;">
                    <div class="flex items-start justify-between">
                        <div class="flex-1 min-w-0">
                            <h3 class="font-semibold truncate">@cam.Nome</h3>
                            <div class="flex items-center gap-2 mt-1"><Icon Name="map-pin" Size="12" CssClass="text-muted" /><span class="text-sm text-muted">@(ambientes.FirstOrDefault(a => a.Id == cam.AmbienteId)?.Nome ?? $"Ambiente {cam.AmbienteId}")</span></div>
                            <p class="text-xs font-mono text-muted" style="margin-top: 0.25rem;">@(cam.UrlRTSP ?? "-")</p>
                        </div>
                        <span class="badge @(cam.Ativa ? "badge-success" : "badge-muted")"><Icon Name="@(cam.Ativa ? "wifi" : "wifi-off")" Size="12" /> @(cam.Ativa ? "Ativa" : "Inativa")</span>
                    </div>
                    <div class="flex items-center gap-2 mt-4 pt-4 border-t">
                        <button class="btn btn-outline btn-sm flex-1" disabled="@(!cam.Ativa)" @onclick="() => OpenLiveView(cam)"><Icon Name="play" Size="16" /> Ao Vivo</button>
                        <a href="/historico?ambienteId=@cam.AmbienteId&gravacao=com" class="btn btn-outline btn-sm flex-1" title="Ver gravações deste ambiente"><Icon Name="video" Size="16" /> Gravações</a>
                        <button class="btn btn-ghost btn-icon" title="Editar" @onclick="() => AbrirEdicao(cam)"><Icon Name="pencil" Size="16" /></button>
                        <button class="btn btn-ghost btn-icon" title="@(cam.Ativa ? "Desativar" : "Ativar")" @onclick="() => HandleToggleAtiva(cam)"><Icon Name="@(cam.Ativa ? "power" : "power-off")" Size="16" /></button>
                        <button class="btn btn-ghost btn-icon text-destructive" @onclick="() => ConfirmarRemover(cam.Id)"><Icon Name="trash" Size="16" /></button>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Filtered.Any())
    {
        <div class="card"><div class="card-content pt-6" style="text-align: center; padding: 3rem;"><Icon Name="camera" Size="48" CssClass="text-muted" /><p class="font-medium mt-4">Nenhuma câmera encontrada</p></div></div>
    }
</div>

@if (showConfirmRemover)
{
    <div class="modal-overlay">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Remover Câmera</h3>
                <p>Esta ação não pode ser desfeita</p>
            </div>
            <div class="modal-body">
                <p>Deseja remover a câmera <strong>@(todasCameras.FirstOrDefault(c => c.Id == cameraIdParaRemover)?.Nome)</strong>? O acesso ao feed ao vivo e histórico de gravações será perdido.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="() => showConfirmRemover = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="HandleConfirmarRemover">Remover</button>
            </div>
        </div>
    </div>
}

@if (liveCamera != null)
{
    <div class="modal-overlay">
        <div class="modal modal-lg" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3><Icon Name="video" Size="20" /> @liveCamera.Nome</h3>
                <p>Visualização ao vivo @(string.IsNullOrEmpty(liveCamera.UrlHLS) ? "(URL HLS não configurada)" : "via HLS — " + liveCamera.UrlHLS)</p>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(liveCamera.UrlHLS))
                {
                    <video id="liveVideo" class="aspect-video rounded-lg"
                           style="width: 100%; background: #000;"
                           controls autoplay muted playsinline></video>
                }
                else
                {
                    <div class="aspect-video rounded-lg" style="background: var(--muted); display: flex; align-items: center; justify-content: center;">
                        <div style="text-align: center;" class="space-y-sm">
                            <Icon Name="camera" Size="96" CssClass="text-muted" />
                            <p class="font-medium">URL HLS não configurada</p>
                            <p class="text-sm text-muted">Browsers não suportam RTSP nativo. Configure a URL HLS desta câmera para ver ao vivo.</p>
                            <p class="text-xs text-muted">RTSP: @(liveCamera.UrlRTSP ?? "-")</p>
                        </div>
                    </div>
                }
            </div>
            <div class="modal-footer justify-between" style="justify-content: space-between;">
                <div class="flex items-center gap-4 text-sm text-muted"><span>Ambiente: @(ambientes.FirstOrDefault(a => a.Id == liveCamera.AmbienteId)?.Nome ?? $"Ambiente {liveCamera.AmbienteId}")</span><span>Tipo: @liveCamera.Tipo</span></div>
                <div class="flex gap-2"><button class="btn btn-outline btn-sm" @onclick="FecharLiveView">Fechar</button></div>
            </div>
        </div>
    </div>
}

@if (showCreate)
{
    <div class="modal-overlay">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header"><h3>Cadastrar Nova Câmera</h3><p>Adicione uma nova câmera ao sistema de monitoramento</p></div>
            <div class="modal-body space-y-sm">
                <div class="form-group"><label class="form-label">Nome da Câmera</label><input class="form-input" maxlength="80" placeholder="Ex: Recepção - Entrada" @bind="novoNome" @bind:event="oninput" /></div>
                <div class="form-group">
                    <label class="form-label">URL RTSP <span class="text-destructive">*</span></label>
                    <input class="form-input" maxlength="255" placeholder="rtsp://localhost:8554/webcam" @bind="novoRtsp" @bind:event="oninput" />
                    <p class="text-xs text-muted">Teste local (MediaMTX+webcam): <code>rtsp://localhost:8554/webcam</code>. Em produção: <code>rtsp://usuario:senha@ip-da-camera:554/stream</code></p>
                </div>
                <div class="form-group">
                    <label class="form-label">URL HLS <span class="text-muted text-sm">(opcional, para feed ao vivo no painel)</span></label>
                    <input class="form-input" maxlength="255" placeholder="http://ip:8888/path/index.m3u8" @bind="novoHls" @bind:event="oninput" />
                    <p class="text-xs text-muted">Convenção MediaMTX: porta 8888. Ex: <code>http://localhost:8888/webcam/index.m3u8</code></p>
                </div>
                <div class="form-group"><label class="form-label">Endereço ONVIF</label><input class="form-input" maxlength="255" placeholder="http://ip:porta/onvif/device_service" @bind="novoOnvif" @bind:event="oninput" /></div>
                <div class="form-group">
                    <label class="form-label">Tipo</label>
                    <select class="form-select" @bind="novoTipo">
                        <option value="interna">Interna</option>
                        <option value="externa">Externa</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Ambiente</label>
                    <select class="form-select" @bind="novoAmbienteId">
                        @foreach (var a in ambientes)
                        {
                            <option value="@a.Id">@a.Nome</option>
                        }
                    </select>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-outline" @onclick="() => showCreate = false">Cancelar</button><button class="btn btn-primary" @onclick="HandleCadastrar">Cadastrar</button></div>
        </div>
    </div>
}

@if (editandoCamera != null)
{
    <div class="modal-overlay">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header"><h3>Editar Câmera</h3><p>Atualize os dados da câmera</p></div>
            <div class="modal-body space-y-sm">
                <div class="form-group"><label class="form-label">Nome</label><input class="form-input" maxlength="80" @bind="editandoCamera.Nome" @bind:event="oninput" /></div>
                <div class="form-group"><label class="form-label">URL RTSP</label><input class="form-input" maxlength="255" @bind="editandoCamera.UrlRTSP" @bind:event="oninput" /></div>
                <div class="form-group">
                    <label class="form-label">URL HLS <span class="text-muted text-sm">(opcional, para feed ao vivo no painel)</span></label>
                    <input class="form-input" maxlength="255" placeholder="http://ip:8888/path/index.m3u8" @bind="editandoCamera.UrlHLS" @bind:event="oninput" />
                </div>
                <div class="form-group"><label class="form-label">Endereço ONVIF</label><input class="form-input" maxlength="255" @bind="editandoCamera.EnderecoONVIF" @bind:event="oninput" /></div>
                <div class="form-group">
                    <label class="form-label">Tipo</label>
                    <select class="form-select" @bind="editandoCamera.Tipo">
                        <option value="interna">Interna</option>
                        <option value="externa">Externa</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Ambiente</label>
                    <select class="form-select" @bind="editandoCamera.AmbienteId">
                        @foreach (var a in ambientes)
                        {
                            <option value="@a.Id">@a.Nome</option>
                        }
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="() => editandoCamera = null">Cancelar</button>
                <button class="btn btn-primary" @onclick="HandleSalvarEdicao">Salvar</button>
            </div>
        </div>
    </div>
}

@code {
    private string search = "";
    private string ativaFilter = "todos";
    private string ambienteFilter = "0";
    private bool showCreate = false;
    private bool showConfirmRemover = false;
    private int cameraIdParaRemover = 0;
    private Camera? liveCamera = null;
    private Camera? editandoCamera = null;
    private List<Camera> todasCameras = new();
    private List<Ambiente> ambientes = new();
    private string novoNome = "";
    private string novoRtsp = "";
    private string novoHls = "";
    private string novoOnvif = "";
    private string novoTipo = "interna";
    private int novoAmbienteId = 0;
    private bool hlsAtivo = false;

    protected override async Task OnInitializedAsync()
    {
        todasCameras = await CameraRepo.ListarComFiltros(null, null);
        ambientes = AmbienteRepo.ListarTodos();
        if (ambientes.Any()) novoAmbienteId = ambientes.First().Id;

        // Pré-aplica filtro de ambiente vindo na URL (?ambienteId=X) — usado pelo link
        // da tab "Câmeras" no detalhe do ambiente
        var uri = new Uri(Nav.Uri);
        var qs = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (qs.TryGetValue("ambienteId", out var amb) && !string.IsNullOrEmpty(amb))
        {
            ambienteFilter = amb.ToString();
        }
    }

    private void OpenLiveView(Camera cam)
    {
        liveCamera = cam;
        hlsAtivo = false; // será iniciado em OnAfterRenderAsync quando o <video> existir
    }

    private async Task FecharLiveView()
    {
        if (hlsAtivo)
        {
            await JS.InvokeVoidAsync("pararHls", "liveVideo");
            hlsAtivo = false;
        }
        liveCamera = null;
    }

    private HashSet<int> previewsAtivos = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Quando o modal abre e a câmera tem URL HLS, dispara o player ampliado.
        if (liveCamera != null && !string.IsNullOrEmpty(liveCamera.UrlHLS) && !hlsAtivo)
        {
            hlsAtivo = true;
            await JS.InvokeVoidAsync("iniciarHls", "liveVideo", liveCamera.UrlHLS);
        }
        // Dispara HLS pequeno em todos os cards de câmeras que têm URL HLS e ainda não rodam.
        // Cada card tem ID camPreview_{id} — verificado/inicializado individualmente.
        foreach (var cam in Filtered)
        {
            if (cam.Ativa && !string.IsNullOrEmpty(cam.UrlHLS) && !previewsAtivos.Contains(cam.Id))
            {
                previewsAtivos.Add(cam.Id);
                try { await JS.InvokeVoidAsync("iniciarHls", $"camPreview_{cam.Id}", cam.UrlHLS); }
                catch { previewsAtivos.Remove(cam.Id); }
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        // Garante que o stream HLS (player ampliado + previews dos cards) é parado quando o usuário sai.
        if (hlsAtivo)
        {
            try { await JS.InvokeVoidAsync("pararHls", "liveVideo"); } catch { }
        }
        foreach (var id in previewsAtivos.ToList())
        {
            try { await JS.InvokeVoidAsync("pararHls", $"camPreview_{id}"); } catch { }
        }
    }

    private void ConfirmarRemover(int id)
    {
        cameraIdParaRemover = id;
        showConfirmRemover = true;
    }

    private async Task HandleConfirmarRemover()
    {
        await HandleRemover(cameraIdParaRemover);
        showConfirmRemover = false;
        cameraIdParaRemover = 0;
    }

    private IEnumerable<Camera> Filtered => todasCameras.Where(c =>
        (string.IsNullOrEmpty(search) || c.Nome.Contains(search, StringComparison.OrdinalIgnoreCase) || (c.UrlRTSP != null && c.UrlRTSP.Contains(search, StringComparison.OrdinalIgnoreCase))) &&
        (ativaFilter == "todos" || (ativaFilter == "ativa" && c.Ativa) || (ativaFilter == "inativa" && !c.Ativa)) &&
        (ambienteFilter == "0" || c.AmbienteId.ToString() == ambienteFilter));

    private async Task HandleRemover(int id)
    {
        await CameraRepo.Remover(id);
        LogRepo.Registrar(TokenStore.AdminId, "Remocao", "Camera", id);
        todasCameras = await CameraRepo.ListarComFiltros(null, null);
    }

    private async Task HandleCadastrar()
    {
        if (string.IsNullOrWhiteSpace(novoNome)) return;
        var novaCamera = new Camera
        {
            Nome = novoNome,
            UrlRTSP = novoRtsp,
            UrlHLS = string.IsNullOrWhiteSpace(novoHls) ? null : novoHls,
            EnderecoONVIF = string.IsNullOrWhiteSpace(novoOnvif) ? null : novoOnvif,
            Tipo = novoTipo,
            AmbienteId = novoAmbienteId,
            Ativa = true
        };
        await CameraRepo.Adicionar(novaCamera);
        LogRepo.Registrar(TokenStore.AdminId, "Adicionar", "Camera", novaCamera.Id);
        todasCameras = await CameraRepo.ListarComFiltros(null, null);
        showCreate = false;
        novoNome = novoRtsp = novoHls = novoOnvif = "";
    }

    private async Task HandleToggleAtiva(Camera cam)
    {
        cam.Ativa = !cam.Ativa;
        await CameraRepo.Atualizar(cam);
        LogRepo.Registrar(TokenStore.AdminId, "Atualizar", "Camera", cam.Id);
        todasCameras = await CameraRepo.ListarComFiltros(null, null);
    }

    private void AbrirEdicao(Camera cam)
    {
        // Cópia para o admin poder cancelar sem mutar a referência da listagem
        editandoCamera = new Camera
        {
            Id = cam.Id,
            Nome = cam.Nome,
            UrlRTSP = cam.UrlRTSP,
            UrlHLS = cam.UrlHLS,
            EnderecoONVIF = cam.EnderecoONVIF,
            Tipo = cam.Tipo,
            AmbienteId = cam.AmbienteId,
            Ativa = cam.Ativa
        };
    }

    private async Task HandleSalvarEdicao()
    {
        if (editandoCamera == null || string.IsNullOrWhiteSpace(editandoCamera.Nome)) return;
        await CameraRepo.Atualizar(editandoCamera);
        LogRepo.Registrar(TokenStore.AdminId, "Atualizar", "Camera", editandoCamera.Id);
        todasCameras = await CameraRepo.ListarComFiltros(null, null);
        editandoCamera = null;
    }
}