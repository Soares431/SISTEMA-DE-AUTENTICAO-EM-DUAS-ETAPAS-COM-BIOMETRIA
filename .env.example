# ═══════════════════════════════════════════════════════════════
# Variáveis lidas pelo docker-compose.yml
# ═══════════════════════════════════════════════════════════════
# Copie este arquivo pra `.env` (sem o .example) e preencha os
# valores reais. O `.env` NÃO deve ser versionado no Git.
#
#     cp .env.example .env
#     # edite o .env com os dados do cliente
#     docker compose up -d --build
# ═══════════════════════════════════════════════════════════════

# SMTP — usado pelo reenvio de credenciais. Sem isso, o envio cai no
# fallback console (admin vê a senha no log, mas o usuário não recebe email).
# Exemplo para o 5º CTA: smtp.ebmail.eb.mil.br
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# T50M — IP e porta do terminal Anviz que o Worker vai conectar.
# Defaults: 192.168.0.218:5010 (padrão Anviz OAE). Ajuste pro IP que o
# cliente configurou no T50M na rede dele.
T50M_IP=192.168.0.218
T50M_PORTA=5010
